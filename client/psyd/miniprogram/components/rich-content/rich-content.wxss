.rich-content {
  width: 100%;
  padding: 0;
}

.content-block {
  margin-bottom: 24rpx;
}

/* 文本块样式 */
.text-block {
  padding: 0 32rpx;
  line-height: 1.8;
  font-size: 28rpx;
  color: #333;
}

.text-block rich-text {
  width: 100%;
}

/* 图片块样式 */
.image-block {
  width: 100%;
  padding: 0;
}

.content-image {
  width: 100%;
  display: block;
  border-radius: 0;
}

/* 视频块样式 */
.video-block {
  width: 100%;
  padding: 0 32rpx;
}

.content-video {
  width: 100%;
  height: 400rpx;
  border-radius: 8rpx;
  background: #000;
}

/* 说明文字样式 */
.caption {
  padding: 16rpx 32rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
  background: #f5f5f5;
  line-height: 1.5;
}

.image-block .caption {
  padding: 16rpx 32rpx;
  margin: 0;
}

.video-block .caption {
  padding: 16rpx 0 0;
  background: transparent;
}

/* 无内容样式 */
.no-content {
  padding: 80rpx 32rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}
