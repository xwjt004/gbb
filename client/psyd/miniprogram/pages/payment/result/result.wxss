/* 支付结果页面样式 - 儿童影楼欢快风格 */

.result-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #FFF9E6 0%, #FFE9F3 50%, #E6F3FF 100%);
  padding: 80rpx 30rpx 40rpx;
  display: flex;
  flex-direction: column;
}

/* 结果内容 */
.result-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

/* 成功状态 */
.result-success {
  width: 100%;
  text-align: center;
}

.success-icon-wrapper {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52C41A 0%, #73D13D 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(82, 196, 26, 0.4);
  animation: success-bounce 0.6s ease-out;
}

@keyframes success-bounce {
  0% {
    transform: scale(0);
    opacity: 0;
  }
  50% {
    transform: scale(1.1);
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.success-icon {
  font-size: 120rpx;
  color: #FFF;
  font-weight: 700;
}

/* 失败状态 */
.result-fail {
  width: 100%;
  text-align: center;
}

.fail-icon-wrapper {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF4D4F 0%, #FF7875 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(255, 77, 79, 0.4);
  animation: fail-shake 0.6s ease-out;
}

@keyframes fail-shake {
  0%, 100% {
    transform: translateX(0);
  }
  25% {
    transform: translateX(-10rpx);
  }
  75% {
    transform: translateX(10rpx);
  }
}

.fail-icon {
  font-size: 120rpx;
  color: #FFF;
  font-weight: 700;
}

/* 处理中状态 */
.result-pending {
  width: 100%;
  text-align: center;
}

.pending-icon-wrapper {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FAAD14 0%, #FFC53D 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(250, 173, 20, 0.4);
  animation: pending-pulse 1.5s ease-in-out infinite;
}

@keyframes pending-pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

.pending-icon {
  font-size: 120rpx;
}

/* 标题和描述 */
.result-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
}

.fail-title {
  color: #FF4D4F;
}

.result-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 60rpx;
  padding: 0 40rpx;
}

/* 订单摘要 */
.order-summary {
  width: 100%;
  padding: 40rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF5F8 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 157, 0.1);
  margin-top: 40rpx;
}

.summary-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx dashed #FFE5EE;
}

.summary-item:last-child {
  border-bottom: none;
}

.summary-label {
  font-size: 28rpx;
  color: #999;
}

.summary-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.summary-value.amount {
  font-size: 36rpx;
  color: #FF6B9D;
  font-weight: 700;
}

/* 操作按钮 */
.result-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.primary-btn {
  background: linear-gradient(135deg, #FF6B9D 0%, #FFAB8E 100%);
  color: #FFF;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.4);
}

.secondary-btn {
  background: #FFF;
  color: #FF6B9D;
  border: 3rpx solid #FF6B9D;
}

/* 温馨提示 */
.tips-section {
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  margin-bottom: 40rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #FF6B9D;
  margin-bottom: 24rpx;
}

.tips-content {
  font-size: 26rpx;
  color: #666;
  line-height: 2;
}

.tip-item {
  margin-bottom: 12rpx;
}

/* 客服入口 */
.service-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF5F8 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 157, 0.1);
}

.service-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.service-text {
  font-size: 28rpx;
  color: #FF6B9D;
  font-weight: 600;
}
