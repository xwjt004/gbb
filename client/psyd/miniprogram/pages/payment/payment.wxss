/* 支付页面样式 - 儿童影楼欢快风格 */

.payment-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #FFF9E6 0%, #FFE9F3 50%, #E6F3FF 100%);
  padding: 0 0 180rpx 0;
  position: relative;
}

/* 顶部装饰 */
.header-decoration {
  position: relative;
  height: 200rpx;
  overflow: hidden;
}

.decoration-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.15;
}

.circle-1 {
  width: 200rpx;
  height: 200rpx;
  background: #FF6B9D;
  top: -100rpx;
  left: -50rpx;
}

.circle-2 {
  width: 150rpx;
  height: 150rpx;
  background: #FFAB8E;
  top: 20rpx;
  right: 50rpx;
}

.circle-3 {
  width: 100rpx;
  height: 100rpx;
  background: #FF6B9D;
  bottom: 20rpx;
  left: 45%;
}

/* 订单信息卡片 */
.order-card {
  margin: 30rpx;
  padding: 40rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF5F8 100%);
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 157, 0.15);
  border: 3rpx solid rgba(255, 107, 157, 0.1);
}

.card-header {
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx dashed #FFD6E8;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF6B9D;
}

.order-info {
  margin-bottom: 30rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.info-row .label {
  font-size: 28rpx;
  color: #999;
}

.info-row .value {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.info-row .amount {
  color: #FF6B9D;
  font-size: 32rpx;
}

.info-row.discount .value {
  color: #FF9800;
}

/* 应付金额 */
.total-amount {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #FFE5F0 0%, #FFF0F5 100%);
  border-radius: 20rpx;
  margin-top: 20rpx;
}

.total-label {
  font-size: 30rpx;
  color: #666;
  font-weight: 600;
}

.total-value {
  display: flex;
  align-items: baseline;
}

.currency {
  font-size: 32rpx;
  color: #FF6B9D;
  font-weight: 700;
  margin-right: 8rpx;
}

.amount-number {
  font-size: 48rpx;
  color: #FF6B9D;
  font-weight: 700;
}

/* 支付方式 */
.payment-methods {
  margin: 30rpx;
  padding: 40rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFFBFC 100%);
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 157, 0.15);
  border: 3rpx solid rgba(255, 107, 157, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF6B9D;
  margin-bottom: 30rpx;
}

.method-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: #FFF;
  border-radius: 20rpx;
  border: 3rpx solid #FFE5EE;
  margin-bottom: 20rpx;
  transition: all 0.3s;
}

.method-item.selected {
  border-color: #FF6B9D;
  background: linear-gradient(135deg, #FFF0F5 0%, #FFF 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 157, 0.2);
}

.method-left {
  display: flex;
  align-items: center;
}

.method-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
}

.method-icon-text {
  font-size: 60rpx;
  margin-right: 20rpx;
  line-height: 1;
}

.method-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.method-right {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B9D 0%, #FFAB8E 100%);
  color: #FFF;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 157, 0.4);
}

/* 支付协议 */
.payment-agreement {
  margin: 30rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
}

.agreement-label {
  display: flex;
  align-items: center;
}

.agreement-text {
  font-size: 24rpx;
  color: #666;
  margin-left: 16rpx;
}

.agreement-text .link {
  color: #FF6B9D;
  text-decoration: underline;
}

/* 支付按钮 */
.payment-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: linear-gradient(to top, rgba(255, 255, 255, 0.98) 0%, rgba(255, 255, 255, 0.95) 100%);
  box-shadow: 0 -4rpx 20rpx rgba(255, 107, 157, 0.1);
  z-index: 100;
}

.pay-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FFAB8E 100%);
  color: #FFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.4);
  transition: all 0.3s;
}

.pay-btn.disabled {
  background: #FFD6E8;
  box-shadow: none;
  opacity: 0.6;
}

/* 安全提示 */
.security-tips {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  margin-top: 20rpx;
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
}
