page {
  background: #fff5f7;
}

.agreement-page {
  padding: 32rpx 28rpx;
  min-height: 100vh;
}

.agreement-header {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1816;
  text-align: center;
  padding-bottom: 28rpx;
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(255, 105, 180, 0.12);
}

.agreement-content {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(255, 105, 180, 0.08);
}

.section {
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #ff69b4;
  margin-bottom: 12rpx;
}

.section-body {
  font-size: 22rpx;
  color: rgba(26, 24, 22, 0.82);
  line-height: 1.8;
  padding-left: 8rpx;
  margin-bottom: 6rpx;
}

.agreement-footer {
  text-align: center;
  padding-top: 20rpx;
  margin-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
  font-size: 22rpx;
  color: rgba(26, 24, 22, 0.5);
}