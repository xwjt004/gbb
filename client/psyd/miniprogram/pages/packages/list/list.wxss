/* 套系列表页样式 — 3D立体卡片风格 */

/* 容器 */
page {
  padding: 0;
  margin: 0;
}

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F8F6F7 0%, #F0ECEE 100%);
}

/* ===== 分类导航 ===== */
.category-nav {
  background: #fff;
  display: flex;
  align-items: center;
  padding: 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  position: sticky;
  top: 0;
  z-index: 100;
  height: 88rpx;
}

.category-scroll {
  flex: 1;
  white-space: nowrap;
  height: 88rpx;
  line-height: 88rpx;
}

.category-list {
  display: inline-flex;
  padding: 0 20rpx;
  height: 88rpx;
  align-items: center;
}

.category-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
  height: 60rpx;
  margin-right: 16rpx;
  border-radius: 30rpx;
  background: #F5F0F2;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
  font-weight: 500;
}

.category-item.active {
  background: linear-gradient(135deg, #FF9A9E, #FBC2EB);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255,154,158,0.3);
}

/* 团购标签放大突出 */
.gb-filter {
  padding: 0 36rpx !important;
  height: 68rpx !important;
  font-size: 30rpx !important;
  font-weight: 700 !important;
  background: linear-gradient(135deg, #FFF0F0, #FFE4E4) !important;
  border: 2rpx solid rgba(255,107,107,0.2);
}

.gb-filter.active {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E) !important;
  border-color: transparent !important;
  box-shadow: 0 6rpx 20rpx rgba(255,107,107,0.35) !important;
}

.gb-filter-text {
  font-size: 30rpx !important;
  font-weight: 700 !important;
}

.filter-btn {
  padding: 0 24rpx;
  border-left: 2rpx solid #F0E8EB;
  height: 48rpx;
  display: flex;
  align-items: center;
}

.filter-btn text {
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
}

.filter-btn text.active {
  color: #FF9A9E;
  font-weight: 600;
}

/* ===== 套系列表 ===== */
.package-list {
  padding: 16rpx 20rpx 20rpx;
}

/* ===== 套系卡片 — 3D凸起效果 ===== */
.package-card {
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 28rpx;
  overflow: hidden;
  /* 3D凸起效果：多层阴影模拟立体感 */
  box-shadow:
    0 2rpx 4rpx rgba(0,0,0,0.02),
    0 8rpx 24rpx rgba(0,0,0,0.06),
    0 20rpx 48rpx -12rpx rgba(0,0,0,0.1);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  /* 顶部高光线 — 模拟光照 */
  border-top: 2rpx solid rgba(255,255,255,0.8);
}

/* 卡片底部深阴影 — 让卡片"浮"起来 */
.package-card::after {
  content: '';
  position: absolute;
  bottom: -6rpx;
  left: 20rpx;
  right: 20rpx;
  height: 20rpx;
  background: rgba(0,0,0,0.03);
  border-radius: 50%;
  filter: blur(8rpx);
  z-index: -1;
  transition: all 0.3s ease;
}

.package-card:active {
  transform: translateY(-4rpx) scale(1.01);
  box-shadow:
    0 4rpx 8rpx rgba(0,0,0,0.03),
    0 12rpx 32rpx rgba(0,0,0,0.08),
    0 30rpx 60rpx -16rpx rgba(0,0,0,0.12);
}

.package-card:active::after {
  bottom: -10rpx;
  filter: blur(12rpx);
  opacity: 0.6;
}

.package-card:last-child {
  margin-bottom: 0;
}

/* ===== 图片区域 ===== */
.package-image {
  width: 100%;
  position: relative;
  background: #F5F0F2;
  overflow: hidden;
  max-height: 600rpx;
}

.package-image image {
  width: 100%;
  display: block;
}

/* 图片底部渐变过渡 */
.package-image::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60rpx;
  background: linear-gradient(transparent, rgba(255,255,255,0.9));
  pointer-events: none;
}

.popular-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF9A9E);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255,107,107,0.3);
}

/* ===== 信息区域 ===== */
.package-info {
  padding: 28rpx 28rpx 24rpx;
  background: #fff;
  position: relative;
}

/* 套系头部 */
.package-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.package-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D2C33;
  flex: 1;
  margin-right: 16rpx;
  letter-spacing: 1rpx;
}

.category-badge {
  background: linear-gradient(135deg, #FF9A9E, #FBC2EB);
  color: #fff;
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 500;
  white-space: nowrap;
  box-shadow: 0 2rpx 8rpx rgba(255,154,158,0.25);
}

.package-desc {
  font-size: 24rpx;
  color: #A88C96;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.5;
}

/* ===== 价格卡片 ===== */
.price-card {
  background: linear-gradient(135deg, #FFF5F7, #FFE4EC);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  border: 2rpx solid rgba(255,154,158,0.1);
}

.price-section {
  flex: 1;
}

.price-label {
  font-size: 20rpx;
  color: #B8ADB2;
  margin-bottom: 6rpx;
  display: block;
  font-weight: 500;
}

.price-amount {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #FF6B9D;
  font-weight: 600;
  margin-right: 2rpx;
}

.price-number {
  font-size: 40rpx;
  font-weight: 800;
  color: #FF6B9D;
  letter-spacing: -1rpx;
}

.divider {
  width: 2rpx;
  height: 52rpx;
  background: rgba(255,107,157,0.12);
  margin: 0 20rpx;
}

.deposit-section {
  text-align: center;
}

.deposit-label {
  font-size: 20rpx;
  color: #B8ADB2;
  margin-bottom: 6rpx;
  display: block;
  font-weight: 500;
}

.deposit-amount {
  font-size: 28rpx;
  font-weight: 700;
  color: #FF6B6B;
}

/* ===== 底部信息栏 ===== */
.package-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 2rpx solid #F5F0F2;
}

.footer-info {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #B8ADB2;
}

.info-icon {
  margin-right: 6rpx;
  font-size: 24rpx;
}

.info-text {
  color: #B8ADB2;
}

.book-hint {
  display: flex;
  align-items: center;
  color: #FF9A9E;
  font-size: 26rpx;
  font-weight: 600;
}

.book-hint .arrow {
  margin-left: 6rpx;
  font-size: 24rpx;
  transition: transform 0.3s;
}

.package-card:active .arrow {
  transform: translateX(6rpx);
}

/* ===== 加载/空状态 ===== */
.loading,
.empty,
.no-more {
  text-align: center;
  padding: 60rpx 0;
  color: #B8ADB2;
  font-size: 26rpx;
  background: #fff;
  border-radius: 20rpx;
  margin: 16rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.empty image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.4;
}

/* ===== 选择模式提示栏 ===== */
.select-mode-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, #07c160, #05a850);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

.select-mode-cancel {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  padding: 8rpx 20rpx;
  border: 2rpx solid rgba(255,255,255,0.5);
  border-radius: 24rpx;
}

/* ===== 团购视图 ===== */
.group-buy-container {
  padding: 20rpx;
}

/* 发起组团英雄区 */
.group-buy-hero {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FF6B6B, #FF9A9E);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(255,107,107,0.25);
}

.hero-avatar {
  font-size: 56rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.hero-body {
  flex: 1;
}

.hero-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
}

.hero-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

.hero-arrow {
  font-size: 36rpx;
  color: rgba(255,255,255,0.7);
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* 区域标题 */
.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 8rpx 20rpx;
}

.section-title-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #3D2C33;
}

.section-title-count {
  font-size: 24rpx;
  color: #B8ADB2;
  background: #F5F0F2;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* 团购活动卡片 */
.group-buy-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.group-buy-card:active {
  transform: scale(0.98);
}

.gb-card-image {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  background: #F5F0F2;
}

.gb-card-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.gb-card-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #3D2C33;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.gb-card-creator {
  display: flex;
  align-items: center;
  margin: 8rpx 0;
}

.gb-creator-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  margin-right: 8rpx;
  background: #F0E8EB;
}

.gb-creator-name {
  font-size: 22rpx;
  color: #A88C96;
  margin-right: 8rpx;
}

.gb-creator-label {
  font-size: 18rpx;
  color: #FF9A9E;
  background: #FFF5F7;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
}

.gb-card-progress {
  display: flex;
  align-items: center;
  margin: 8rpx 0;
}

.gb-progress-bar {
  flex: 1;
  height: 12rpx;
  background: #F5F0F2;
  border-radius: 6rpx;
  overflow: hidden;
  margin-right: 12rpx;
}

.gb-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF9A9E, #FF6B6B);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.gb-progress-text {
  font-size: 22rpx;
  color: #FF6B6B;
  font-weight: 600;
  white-space: nowrap;
}

.gb-card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.gb-card-price {
  font-size: 32rpx;
  font-weight: 800;
  color: #FF6B9D;
}

.gb-card-time {
  font-size: 20rpx;
  color: #B8ADB2;
}
