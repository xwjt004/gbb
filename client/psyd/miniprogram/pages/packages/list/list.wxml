<!--套系列表页-->
<view class="container">
  <!-- 选择模式提示 -->
  <view wx:if="{{selectMode === 'groupBuy'}}" class="select-mode-bar">
    <text>请选择要团购的套餐</text>
    <text class="select-mode-cancel" bindtap="cancelSelect">取消</text>
  </view>

  <!-- 顶部分类导航 -->
  <view class="category-nav">
    <scroll-view scroll-x class="category-scroll">
      <view class="category-list">
        <view
          class="category-item {{activeCategory === 0 ? 'active' : ''}}"
          bindtap="onCategoryChange"
          data-id="{{0}}"
        >
          <text>全部</text>
        </view>
        <view
          class="category-item {{showPopular ? 'active' : ''}}"
          bindtap="onPopularToggle"
        >
          <text>⭐ 热门</text>
        </view>
        <view
          class="category-item gb-filter {{showGroupBuy ? 'active' : ''}}"
          bindtap="onGroupBuyToggle"
        >
          <text class="gb-filter-text">🔥 团购</text>
        </view>
        <view
          wx:for="{{categories}}"
          wx:key="id"
          class="category-item {{activeCategory === item.id ? 'active' : ''}}"
          bindtap="onCategoryChange"
          data-id="{{item.id}}"
        >
          <text>{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 套系列表 -->
  <view class="package-list" wx:if="{{!showGroupBuy}}">
    <view 
      wx:for="{{packages}}" 
      wx:key="id"
      class="package-card"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <!-- 套系图片 -->
      <view class="package-image">
        <image 
          src="{{item.coverImage || '/images/placeholder.png'}}" 
          mode="widthFix"
          lazy-load
        />
        <!-- 热门标签 -->
        <view wx:if="{{item.isPopular}}" class="popular-tag">
          ⭐ 热门
        </view>
      </view>

      <!-- 套系信息 -->
      <view class="package-info">
        <!-- 套系名称和分类 -->
        <view class="package-header">
          <view class="package-name">{{item.name}}</view>
          <view wx:if="{{item.packageCategory}}" class="category-badge">
            {{item.packageCategory.name}}
          </view>
        </view>
        
        <!-- 套系描述 -->
        <view class="package-desc">{{item.description}}</view>
        
        <!-- 价格信息卡片 -->
        <view class="price-card">
          <view class="price-section">
            <view class="price-label">套系价格</view>
            <view class="price-amount">
              <text class="price-symbol">¥</text>
              <text class="price-number">{{item.price}}</text>
            </view>
          </view>
          <view class="divider"></view>
          <view class="deposit-section" wx:if="{{item.depositAmount}}">
            <view class="deposit-label">预付定金</view>
            <view class="deposit-amount">¥{{item.depositAmount}}</view>
          </view>
        </view>

        <!-- 底部信息栏 -->
        <view class="package-footer">
          <view class="footer-info">
            <text class="info-icon">👁</text>
            <text class="info-text">{{item.salesVolume || 0}}人已购</text>
          </view>
          <view class="book-hint">
            <text>立即预约</text>
            <text class="arrow">→</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading">
      <text>加载中...</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && packages.length === 0}}" class="empty">
      <image src="/images/placeholder.png" mode="aspectFit" />
      <text>暂无套系</text>
    </view>

    <!-- 没有更多 -->
    <view wx:if="{{!hasMore && packages.length > 0}}" class="no-more">
      <text>没有更多了</text>
    </view>
  </view>

  <!-- ===== 团购视图 ===== -->
  <view wx:if="{{showGroupBuy}}" class="group-buy-container">
    <!-- 发起组团按钮 -->
    <view class="group-buy-hero" bindtap="goToGroupBuyStart">
      <view class="hero-avatar">👥</view>
      <view class="hero-body">
        <view class="hero-title">发起组团</view>
        <view class="hero-desc">邀请好友一起拼团，享受更优惠的价格</view>
      </view>
      <view class="hero-arrow">→</view>
    </view>

    <!-- 活动列表标题 -->
    <view class="section-title">
      <text class="section-title-text">正在组团的活动</text>
      <text class="section-title-count">{{groupBuyTotal}}个</text>
    </view>

    <!-- 团购活动卡片列表 -->
    <view wx:for="{{groupBuyList}}" wx:key="id" class="group-buy-card" bindtap="goToGroupBuyDetail" data-id="{{item.id}}">
      <!-- 左侧图片 -->
      <image class="gb-card-image" src="{{item.coverImage}}" mode="aspectFill" />
      <!-- 右侧信息 -->
      <view class="gb-card-info">
        <view class="gb-card-name">{{item.targetName}}</view>
        <!-- 发起人 -->
        <view class="gb-card-creator">
          <image class="gb-creator-avatar" src="{{item.creator.avatar || '/images/placeholder.png'}}" mode="aspectFill" />
          <text class="gb-creator-name">{{item.creator.nickname || '匿名用户'}}</text>
          <text class="gb-creator-label">发起人</text>
        </view>
        <!-- 进度条 -->
        <view class="gb-card-progress">
          <view class="gb-progress-bar">
            <view class="gb-progress-fill" style="width: {{item.progressPercent}}%"></view>
          </view>
          <text class="gb-progress-text">{{item.progress}}/{{item.minCount || 2}}人</text>
        </view>
        <!-- 底部信息 -->
        <view class="gb-card-footer">
          <text class="gb-card-price">¥{{item.price}}</text>
          <text class="gb-card-time">剩余 {{item.remainingTime}}</text>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading">
      <text>加载中...</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && groupBuyList.length === 0}}" class="empty">
      <image src="/images/placeholder.png" mode="aspectFit" />
      <text>暂无组团活动</text>
    </view>

    <!-- 没有更多 -->
    <view wx:if="{{!groupBuyHasMore && groupBuyList.length > 0}}" class="no-more">
      <text>没有更多了</text>
    </view>
  </view>
</view>
