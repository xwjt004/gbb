/* 套系详情页样式 */
.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding-bottom: 120rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.loading-text {
  font-size: 28rpx;
  color: #969799;
}

/* 轮播图 */
.swiper-container {
  position: relative;
  width: 100%;
  height: 750rpx;
  background: #f5f5f5;
}

.image-swiper {
  width: 100%;
  height: 100%;
}

.swiper-image {
  width: 100%;
  height: 100%;
  display: block;
}

.image-indicator {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
}

.popular-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  background: linear-gradient(135deg, #ff976a 0%, #ff6a4a 100%);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(255, 106, 74, 0.4);
}

/* 基本信息区 */
.info-section {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.package-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #323233;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.tag {
  padding: 8rpx 20rpx;
  background: #f2f3f5;
  color: #646566;
  font-size: 24rpx;
  border-radius: 6rpx;
}

.category-tag {
  background: #e8f4ff;
  color: #1989fa;
  font-weight: 500;
}

/* 价格信息 */
.price-container {
  display: flex;
  align-items: stretch;
  padding: 32rpx;
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(252, 182, 159, 0.3);
}

.price-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-right: 24rpx;
  border-right: 2rpx solid rgba(139, 69, 19, 0.2);
}

.price-label {
  font-size: 26rpx;
  color: #8b4513;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.price-value {
  font-size: 52rpx;
  font-weight: 700;
  color: #d32f2f;
  line-height: 1;
}

.price-value::before {
  content: '¥';
  font-size: 32rpx;
  margin-right: 4rpx;
}

.price-sub {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding-left: 24rpx;
  min-width: 160rpx;
}

.deposit-label {
  font-size: 26rpx;
  color: #8b4513;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.deposit-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #ff6b6b;
}

/* 统计信息 */
.stats-container {
  display: flex;
  gap: 32rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-icon {
  font-size: 32rpx;
}

.stat-text {
  font-size: 26rpx;
  color: #646566;
}

/* 服务内容区 */
.service-section {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
}

.title-icon {
  font-size: 32rpx;
}

.service-list {
  max-height: 320rpx;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.service-list.expanded {
  max-height: none;
}

.service-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}

.service-dot {
  color: #07c160;
  font-size: 32rpx;
  margin-right: 16rpx;
  line-height: 1.5;
}

.service-text {
  flex: 1;
  font-size: 28rpx;
  color: #646566;
  line-height: 1.6;
}

.expand-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  color: #1989fa;
  font-size: 26rpx;
  border-top: 1rpx solid #ebedf0;
}

.expand-icon {
  font-size: 20rpx;
}

/* 商品内容区 */
.product-section {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.product-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #f8f9fc;
  border-radius: 12rpx;
}

.product-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #323233;
}

.product-spec {
  font-size: 24rpx;
  color: #969799;
}

.product-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.product-unit {
  font-size: 24rpx;
  color: #969799;
}

.product-qty {
  font-size: 26rpx;
  color: #646566;
  font-weight: 500;
}

/* 套系说明区 */
.description-section {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.description-text {
  font-size: 28rpx;
  color: #646566;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* 温馨提示区 */
.tips-section {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.tips-list {
  background: #fffbe8;
  padding: 24rpx;
  border-radius: 12rpx;
  border-left: 6rpx solid #ff976a;
}

.tip-item {
  font-size: 26rpx;
  color: #646566;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

/* 底部占位 */
.bottom-placeholder {
  height: 120rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.action-btns {
  display: flex;
  gap: 32rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.action-icon {
  font-size: 40rpx;
}

.action-text {
  font-size: 22rpx;
  color: #646566;
}

.book-btn {
  flex: 1;
  background: linear-gradient(135deg, #07c160 0%, #05a850 100%);
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.book-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}
