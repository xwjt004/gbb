page {
  background: #fff5f7;
}

.page {
  padding: 32rpx 28rpx;
  min-height: 100vh;
}

.content {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
  border: 1rpx solid rgba(255,105,180,0.08);
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1816;
  text-align: center;
  margin-bottom: 8rpx;
}

.update-date {
  text-align: center;
  font-size: 22rpx;
  color: rgba(26,24,22,0.5);
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(255,105,180,0.1);
}

.body-text {
  font-size: 24rpx;
  color: rgba(26,24,22,0.82);
  line-height: 1.9;
  margin-bottom: 28rpx;
}

.section {
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #ff69b4;
  margin-bottom: 12rpx;
}

.body {
  font-size: 24rpx;
  color: rgba(26,24,22,0.82);
  line-height: 1.9;
  padding-left: 8rpx;
  margin-bottom: 6rpx;
}

.footer-text {
  text-align: center;
  padding-top: 24rpx;
  margin-top: 20rpx;
  border-top: 1rpx solid rgba(0,0,0,0.04);
  font-size: 22rpx;
  color: rgba(26,24,22,0.4);
}