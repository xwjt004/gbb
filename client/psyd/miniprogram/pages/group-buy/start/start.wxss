.container {
  min-height: 100vh;
  background: #f7f8fa;
  padding: 32rpx;
  padding-bottom: 140rpx;
}

.header {
  text-align: center;
  margin-bottom: 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #323233;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #969799;
  margin-top: 12rpx;
}

.package-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.package-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

.package-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.package-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
  margin-bottom: 16rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.price-label {
  font-size: 24rpx;
  color: #969799;
}

.price-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #ee0a24;
}

.setting-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.setting-label {
  font-size: 28rpx;
  color: #323233;
  font-weight: 500;
}

.counter-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  margin: 32rpx 0;
}

.counter-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #07c160;
  color: #fff;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

.counter-btn:active {
  opacity: 0.8;
}

.counter-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #323233;
  min-width: 100rpx;
  text-align: center;
}

.setting-tip {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #969799;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.06);
}

.start-btn {
  background: linear-gradient(135deg, #07c160 0%, #05a850 100%);
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.start-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.start-btn.disabled {
  opacity: 0.6;
}
