.container {
  min-height: 100vh;
  background: #f7f8fc;
  padding: 20rpx;
}

/* ===== 加载 ===== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #969799;
}

/* ===== 空状态 ===== */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #969799;
  margin-bottom: 32rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #07c160, #05a850);
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

/* ===== 列表 ===== */
.list-wrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.card:active {
  transform: scale(0.98);
  transition: transform 0.15s;
}

/* 顶部 */
.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
}

.card-top.status-ACTIVE {
  background: linear-gradient(135deg, #ffecd2, #fcb69f);
}

.card-top.status-SUCCESS {
  background: linear-gradient(135deg, #d4edda, #c3e6cb);
}

.card-top.status-FAILED {
  background: linear-gradient(135deg, #f8d7da, #f5c6cb);
}

.card-top-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.card-status-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #323233;
}

.card-count {
  font-size: 24rpx;
  color: #666;
  background: rgba(255,255,255,0.7);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.card-arrow {
  font-size: 36rpx;
  color: #999;
  font-weight: 300;
}

/* 主体 */
.card-body {
  display: flex;
  padding: 24rpx 28rpx;
  gap: 20rpx;
}

.card-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #323233;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.card-price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.card-price-label {
  font-size: 22rpx;
  color: #969799;
}

.card-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ee0a24;
}

.card-time {
  font-size: 22rpx;
  color: #bbb;
}

/* 底部 */
.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 28rpx;
  border-top: 1rpx solid #f5f5f5;
}

.card-bottom-left {
  display: flex;
  gap: 12rpx;
}

.tag-creator {
  font-size: 22rpx;
  color: #fff;
  background: #ff6b6b;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.tag-joined {
  font-size: 22rpx;
  color: #07c160;
  background: #e8f5e9;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.card-leave-btn {
  font-size: 24rpx;
  color: #ee0a24;
  padding: 8rpx 24rpx;
  border: 2rpx solid #ee0a24;
  border-radius: 30rpx;
}

.card-leave-btn:active {
  background: #fff0f0;
}
