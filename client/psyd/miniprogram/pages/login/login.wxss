/* ============================================
   登录页面 — 精致柔美风 v2
   ============================================ */

.page {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F7 0%, #FFE4E8 30%, #FFF0F5 60%, #F8F6F7 100%);
  position: relative;
  overflow: hidden;
}

.scroll-view {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 2;
}

/* ===== 装饰元素 ===== */
.deco-circle {
  position: absolute;
  border-radius: 50%;
  z-index: 0;
  pointer-events: none;
}

.c1 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(255,154,158,0.15), transparent 70%);
  top: -200rpx;
  right: -150rpx;
}

.c2 {
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(251,194,235,0.2), transparent 70%);
  bottom: 30%;
  left: -120rpx;
}

.c3 {
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255,228,181,0.25), transparent 70%);
  top: 50%;
  right: -60rpx;
}

.c4 {
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(200,180,255,0.15), transparent 70%);
  top: 25%;
  left: -40rpx;
}

.deco-ring {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(255,154,158,0.1);
  z-index: 0;
  pointer-events: none;
}

.r1 {
  width: 600rpx;
  height: 600rpx;
  top: -250rpx;
  right: -200rpx;
}

.r2 {
  width: 400rpx;
  height: 400rpx;
  top: -150rpx;
  right: -100rpx;
}

/* ===== 底部波浪 ===== */
.wave-area {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 240rpx;
  z-index: 0;
  overflow: hidden;
  pointer-events: none;
}

.wave {
  position: absolute;
  bottom: 0;
  width: 200%;
  height: 200rpx;
  border-radius: 50% 50% 0 0;
}

.wave1 {
  left: 0;
  background: rgba(255,154,158,0.06);
  animation: waveMove 8s ease-in-out infinite alternate;
}

.wave2 {
  left: -50%;
  background: rgba(251,194,235,0.06);
  animation: waveMove 12s ease-in-out infinite alternate-reverse;
}

@keyframes waveMove {
  0% { transform: translateX(0) scaleY(1); }
  100% { transform: translateX(-25%) scaleY(1.2); }
}

/* ===== 品牌区域 ===== */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 50rpx;
  position: relative;
}

.logo-wrapper {
  width: 180rpx;
  height: 180rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.logo-glow {
  position: absolute;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9A9E, #FBC2EB, #FFD1D1);
  box-shadow: 0 16rpx 60rpx rgba(255,154,158,0.4), 0 0 80rpx rgba(255,154,158,0.15);
  animation: glowPulse 3s ease-in-out infinite;
}

@keyframes glowPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.85; transform: scale(1.05); }
}

.logo-icon {
  font-size: 80rpx;
  position: relative;
  z-index: 1;
}

.brand-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #4A2C3A;
  letter-spacing: 3rpx;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(74,44,58,0.06);
}

.brand-slogan {
  font-size: 26rpx;
  color: #B8ADB2;
  letter-spacing: 2rpx;
}

/* ===== 登录卡片 ===== */
.login-card {
  position: relative;
  z-index: 1;
  background: #fff;
  border-radius: 36rpx;
  padding: 48rpx 40rpx 56rpx;
  box-shadow: 0 12rpx 48rpx rgba(255,154,158,0.12), 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.card-header {
  margin-bottom: 48rpx;
  text-align: center;
}

.card-greeting {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #3D2C33;
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
}

.card-desc {
  display: block;
  font-size: 26rpx;
  color: #B8ADB2;
  letter-spacing: 1rpx;
}

/* ===== 微信一键登录按钮 - 大号3D效果 ===== */
.btn-wechat {
  width: 100%;
  height: 120rpx;
  background: linear-gradient(180deg, #07C160 0%, #06AD56 40%, #059B4C 100%);
  border-radius: 60rpx;
  border: none;
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow:
    0 8rpx 0 #047A3E,
    0 12rpx 32rpx rgba(7,193,96,0.4),
    inset 0 2rpx 4rpx rgba(255,255,255,0.3);
  transition: all 0.1s ease;
  letter-spacing: 4rpx;
  position: relative;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

/* 顶部高光 */
.btn-wechat::before {
  content: '';
  position: absolute;
  top: 0;
  left: 10%;
  right: 10%;
  height: 40%;
  background: linear-gradient(180deg, rgba(255,255,255,0.35) 0%, rgba(255,255,255,0) 100%);
  border-radius: 60rpx 60rpx 50% 50%;
  pointer-events: none;
}

.btn-wechat:active {
  transform: translateY(6rpx);
  box-shadow:
    0 2rpx 0 #047A3E,
    0 10rpx 28rpx rgba(7,193,96,0.35);
}

.btn-wechat.btn-loading {
  opacity: 0.8;
  transform: translateY(4rpx);
  box-shadow:
    0 4rpx 0 #047A3E,
    0 6rpx 16rpx rgba(7,193,96,0.25);
}

.btn-wechat::after {
  border: none;
}

.btn-wechat-icon {
  font-size: 44rpx;
  line-height: 1;
}

.btn-wechat-text {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
  color: #FFFFFF;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

/* ===== 错误提示 ===== */
.error-box {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: #FFF0F0;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,107,107,0.1);
}

.error-text {
  font-size: 24rpx;
  color: #FF6B6B;
  line-height: 1.5;
  text-align: center;
}

/* ===== 跳过 ===== */
.skip-area {
  text-align: center;
  margin-top: 36rpx;
  position: relative;
  z-index: 1;
}

.skip-btn {
  font-size: 28rpx;
  color: #C8BCC2;
  padding: 20rpx 40rpx;
  transition: color 0.2s;
}

.skip-btn:active {
  color: #FF9A9E;
}

/* ===== 协议区域（精致大号） ===== */
.agreement {
  margin-top: 48rpx;
  padding: 36rpx 28rpx;
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 6rpx 12rpx;
  background: rgba(255,255,255,0.65);
  border-radius: 28rpx;
  backdrop-filter: blur(4rpx);
}

.agreement-checkbox {
  display: inline-flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  transition: background 0.2s;
}

.agreement-checkbox:active {
  background: rgba(255,154,158,0.12);
}

.check-box {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  border: 3rpx solid #C5B5BD;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.25s ease;
  background: rgba(255,255,255,0.95);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.check-box.checked {
  background: linear-gradient(135deg, #07C160, #06AD56);
  border-color: #07C160;
  box-shadow: 0 4rpx 16rpx rgba(7,193,96,0.35);
  transform: scale(1.05);
}

.check-mark {
  font-size: 30rpx;
  color: #fff;
  font-weight: 700;
}

.agree-text {
  font-size: 28rpx;
  color: #6A5A62;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.agreement-link {
  color: #D9363E;
  font-weight: 600;
  padding: 12rpx 8rpx;
  font-size: 28rpx;
  letter-spacing: 1rpx;
  border-bottom: 2rpx solid rgba(217,54,62,0.25);
  transition: all 0.2s;
}

.agreement-link:active {
  color: #C62A32;
  border-bottom-color: #C62A32;
  background: rgba(217,54,62,0.06);
  border-radius: 6rpx;
}

.agree-text-and {
  font-size: 28rpx;
  color: #A898A0;
  font-weight: 400;
  padding: 0 2rpx;
}

/* ===== 完善资料弹窗 ===== */
.profile-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-modal {
  width: 620rpx;
  max-height: 80vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 36rpx;
  padding: 60rpx 48rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.profile-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D2C33;
  margin-bottom: 12rpx;
}

.profile-desc {
  font-size: 26rpx;
  color: #B8ADB2;
  text-align: center;
}

/* 微信头像区域 */
.profile-avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
}

.avatar-btn {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.profile-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
}

.profile-avatar-placeholder {
  background: linear-gradient(135deg, #FF9A9E, #FBC2EB);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-emoji {
  font-size: 64rpx;
}

.avatar-edit-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: #07C160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #fff;
}

.avatar-edit-badge text {
  font-size: 24rpx;
}

.avatar-tip {
  font-size: 24rpx;
  color: #C8BCC2;
  margin-top: 12rpx;
}

/* 输入字段 */
.profile-field {
  width: 100%;
  margin-bottom: 28rpx;
}

.field-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.field-input {
  width: 100%;
  height: 88rpx;
  background: #F8F6F7;
  border-radius: 20rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #3D2C33;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.field-input:focus {
  border-color: #FF9A9E;
  background: #FFF;
}

.field-ph {
  font-size: 28rpx;
  color: #C8BCC2;
}

/* 手机号绑定按钮 */
.phone-bind-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #07C160, #06AD56);
  border-radius: 20rpx;
  border: none;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

.phone-bind-btn::after {
  border: none;
}

.phone-bind-btn:active {
  opacity: 0.85;
}

.field-bound {
  display: block;
  font-size: 28rpx;
  color: #07C160;
  font-weight: 500;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  background: #F8F6F7;
  border-radius: 20rpx;
}

/* 微信号提示 */
.wxid-tip {
  width: 100%;
  padding: 16rpx 20rpx;
  background: #FFF8E1;
  border-radius: 12rpx;
  margin-bottom: 36rpx;
  text-align: center;
}

.wxid-tip text {
  font-size: 22rpx;
  color: #B8860B;
  line-height: 1.5;
}

/* 操作按钮 */
.profile-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-primary {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07C160, #06AD56);
  border-radius: 48rpx;
  border: none;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.3);
  margin-bottom: 20rpx;
}

.action-primary::after {
  border: none;
}

.action-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.action-skip {
  font-size: 26rpx;
  color: #C8BCC2;
  padding: 16rpx 32rpx;
}
