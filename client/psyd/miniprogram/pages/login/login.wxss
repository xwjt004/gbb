/* 现代简洁的登录页面 */

.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx 60rpx;
}

/* ==================== 品牌区域 ==================== */
.brand-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo-wrapper {
  width: 140rpx;
  height: 140rpx;
  background: #ffffff;
  border-radius: 28rpx;
  margin: 0 auto 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.logo {
  width: 100rpx;
  height: 100rpx;
}

.brand-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.brand-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 1rpx;
}

/* ==================== 登录卡片 ==================== */
.login-card {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.12);
}

.card-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
  margin-bottom: 48rpx;
}

/* ==================== 登录按钮 ==================== */
.login-button {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 48rpx;
  border: none;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s;
}

.login-button.disabled {
  opacity: 0.6;
  box-shadow: none;
}

.login-button::after {
  border: none;
}

/* ==================== 错误提示 ==================== */
.error-tip {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #fff3f3;
  border-radius: 12rpx;
  border-left: 6rpx solid #ff4d4f;
}

.error-tip text {
  font-size: 26rpx;
  color: #ff4d4f;
  line-height: 1.5;
}

/* ==================== 登录说明 ==================== */
.login-desc {
  margin-top: 32rpx;
  text-align: center;
}

.login-desc text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
}

/* ==================== 跳过按钮 ==================== */
.skip-wrapper {
  margin-top: 48rpx;
}

.skip-button {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  padding: 20rpx 40rpx;
  text-decoration: underline;
}
