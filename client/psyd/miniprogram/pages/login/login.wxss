/* ============================================
   登录页面 — 精致柔美风 v2
   ============================================ */

.page {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F7 0%, #FFE4E8 30%, #FFF0F5 60%, #F8F6F7 100%);
  position: relative;
  overflow: hidden;
}

.scroll-view {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 2;
}

/* ===== 装饰元素 ===== */
.deco-circle {
  position: absolute;
  border-radius: 50%;
  z-index: 0;
  pointer-events: none;
}

.c1 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(255,154,158,0.15), transparent 70%);
  top: -200rpx;
  right: -150rpx;
}

.c2 {
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(251,194,235,0.2), transparent 70%);
  bottom: 30%;
  left: -120rpx;
}

.c3 {
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255,228,181,0.25), transparent 70%);
  top: 50%;
  right: -60rpx;
}

.c4 {
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(200,180,255,0.15), transparent 70%);
  top: 25%;
  left: -40rpx;
}

.deco-ring {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(255,154,158,0.1);
  z-index: 0;
  pointer-events: none;
}

.r1 {
  width: 600rpx;
  height: 600rpx;
  top: -250rpx;
  right: -200rpx;
}

.r2 {
  width: 400rpx;
  height: 400rpx;
  top: -150rpx;
  right: -100rpx;
}

/* ===== 底部波浪 ===== */
.wave-area {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 240rpx;
  z-index: 0;
  overflow: hidden;
  pointer-events: none;
}

.wave {
  position: absolute;
  bottom: 0;
  width: 200%;
  height: 200rpx;
  border-radius: 50% 50% 0 0;
}

.wave1 {
  left: 0;
  background: rgba(255,154,158,0.06);
  animation: waveMove 8s ease-in-out infinite alternate;
}

.wave2 {
  left: -50%;
  background: rgba(251,194,235,0.06);
  animation: waveMove 12s ease-in-out infinite alternate-reverse;
}

@keyframes waveMove {
  0% { transform: translateX(0) scaleY(1); }
  100% { transform: translateX(-25%) scaleY(1.2); }
}

/* ===== 品牌区域 ===== */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 50rpx;
  position: relative;
}

.logo-wrapper {
  width: 180rpx;
  height: 180rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.logo-glow {
  position: absolute;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9A9E, #FBC2EB, #FFD1D1);
  box-shadow: 0 16rpx 60rpx rgba(255,154,158,0.4), 0 0 80rpx rgba(255,154,158,0.15);
  animation: glowPulse 3s ease-in-out infinite;
}

@keyframes glowPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.85; transform: scale(1.05); }
}

.logo-icon {
  font-size: 80rpx;
  position: relative;
  z-index: 1;
}

.brand-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #4A2C3A;
  letter-spacing: 3rpx;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(74,44,58,0.06);
}

.brand-slogan {
  font-size: 26rpx;
  color: #B8ADB2;
  letter-spacing: 2rpx;
}

/* ===== 登录卡片 ===== */
.login-card {
  position: relative;
  z-index: 1;
  background: #fff;
  border-radius: 36rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 12rpx 48rpx rgba(255,154,158,0.12), 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.card-header {
  margin-bottom: 40rpx;
  text-align: center;
}

.card-greeting {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #3D2C33;
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
}

.card-desc {
  display: block;
  font-size: 26rpx;
  color: #B8ADB2;
  letter-spacing: 1rpx;
}

/* ===== 主按钮 ===== */
.btn-primary {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07C160, #06AD56);
  border-radius: 48rpx;
  border: none;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  box-shadow: 0 8rpx 32rpx rgba(7,193,96,0.3);
  transition: all 0.3s ease;
  letter-spacing: 2rpx;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(7,193,96,0.2);
}

.btn-primary.btn-loading {
  opacity: 0.6;
  box-shadow: none;
  transform: none;
}

.btn-primary::after {
  border: none;
}

.btn-icon {
  font-size: 32rpx;
}

/* ===== 次按钮 ===== */
.btn-secondary {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #F0E8EB;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: all 0.2s ease;
}

.btn-secondary:active {
  background: #FAF8F9;
  border-color: #E0D5DA;
}

.btn-s-icon {
  font-size: 28rpx;
}

.btn-s-text {
  font-size: 26rpx;
  color: #8A7A82;
  font-weight: 500;
}

/* ===== 错误提示 ===== */
.error-box {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: #FFF0F0;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,107,107,0.1);
}

.error-text {
  font-size: 24rpx;
  color: #FF6B6B;
  line-height: 1.5;
  text-align: center;
}

/* ===== 分隔线 ===== */
.divider {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 36rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #EDE8EA, transparent);
}

.divider-text {
  font-size: 24rpx;
  color: #C8BCC2;
  white-space: nowrap;
}

/* ===== 手机号输入 ===== */
.phone-input-group {
  display: flex;
  align-items: center;
  height: 96rpx;
  background: #F8F6F7;
  border-radius: 20rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.phone-input-group:focus-within {
  border-color: #FF9A9E;
  background: #FFF;
}

.input-prefix {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2C33;
  padding-right: 20rpx;
  border-right: 2rpx solid #EDE8EA;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.phone-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #3D2C33;
  background: transparent;
}

/* ===== 验证码输入 ===== */
.code-input-group {
  display: flex;
  gap: 16rpx;
  margin-bottom: 36rpx;
}

.code-input {
  flex: 1;
  height: 96rpx;
  background: #F8F6F7;
  border-radius: 20rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #3D2C33;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.code-input:focus {
  border-color: #FF9A9E;
  background: #FFF;
}

.code-btn {
  flex-shrink: 0;
  width: 200rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #FF9A9E, #FBC2EB);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
  border: none;
  padding: 0;
  margin: 0;
  transition: all 0.2s;
}

.code-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.code-btn::after {
  border: none;
}

.code-btn-disabled {
  opacity: 0.5;
  transform: none !important;
}

.input-ph {
  font-size: 28rpx;
  color: #C8BCC2;
}

/* ===== 跳过 ===== */
.skip-area {
  text-align: center;
  margin-top: 36rpx;
  position: relative;
  z-index: 1;
}

.skip-btn {
  font-size: 28rpx;
  color: #C8BCC2;
  padding: 20rpx 40rpx;
  transition: color 0.2s;
}

.skip-btn:active {
  color: #FF9A9E;
}

/* ===== 协议 ===== */
.agreement {
  text-align: center;
  margin-top: 36rpx;
  padding-bottom: 48rpx;
  font-size: 22rpx;
  color: #D5CDD1;
  position: relative;
  z-index: 1;
}

.agreement-link {
  color: #FF9A9E;
  text-decoration: underline;
}

/* ===== 完善资料弹窗 ===== */
.profile-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-modal {
  width: 620rpx;
  max-height: 80vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 36rpx;
  padding: 60rpx 48rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.profile-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D2C33;
  margin-bottom: 12rpx;
}

.profile-desc {
  font-size: 26rpx;
  color: #B8ADB2;
  text-align: center;
}

/* 微信头像区域 */
.profile-avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
}

.avatar-btn {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.profile-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
}

.profile-avatar-placeholder {
  background: linear-gradient(135deg, #FF9A9E, #FBC2EB);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-emoji {
  font-size: 64rpx;
}

.avatar-edit-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: #07C160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #fff;
}

.avatar-edit-badge text {
  font-size: 24rpx;
}

.avatar-tip {
  font-size: 24rpx;
  color: #C8BCC2;
  margin-top: 12rpx;
}

/* 输入字段 */
.profile-field {
  width: 100%;
  margin-bottom: 28rpx;
}

.field-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.field-input {
  width: 100%;
  height: 88rpx;
  background: #F8F6F7;
  border-radius: 20rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #3D2C33;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.field-input:focus {
  border-color: #FF9A9E;
  background: #FFF;
}

.field-ph {
  font-size: 28rpx;
  color: #C8BCC2;
}

/* 手机号绑定按钮 */
.phone-bind-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #07C160, #06AD56);
  border-radius: 20rpx;
  border: none;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

.phone-bind-btn::after {
  border: none;
}

.phone-bind-btn:active {
  opacity: 0.85;
}

.field-bound {
  display: block;
  font-size: 28rpx;
  color: #07C160;
  font-weight: 500;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  background: #F8F6F7;
  border-radius: 20rpx;
}

/* 微信号提示 */
.wxid-tip {
  width: 100%;
  padding: 16rpx 20rpx;
  background: #FFF8E1;
  border-radius: 12rpx;
  margin-bottom: 36rpx;
  text-align: center;
}

.wxid-tip text {
  font-size: 22rpx;
  color: #B8860B;
  line-height: 1.5;
}

/* 操作按钮 */
.profile-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-primary {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07C160, #06AD56);
  border-radius: 48rpx;
  border: none;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.3);
  margin-bottom: 20rpx;
}

.action-primary::after {
  border: none;
}

.action-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.action-skip {
  font-size: 26rpx;
  color: #C8BCC2;
  padding: 16rpx 32rpx;
}
