/* 新版登录页面样式（简洁现代） */

.container {
	min-height: 100vh;
	background: #f6f7fb;
	display: flex;
	flex-direction: column;
}

/* 顶部品牌区域 */
.header {
	background: #ffffff;
	padding: 72rpx 40rpx 48rpx;
	text-align: center;
	box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.logo-section {
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 16rpx;
}

.logo-icon {
	width: 120rpx;
	height: 120rpx;
	background: linear-gradient(135deg, #c8232c 0%, #a01d24 100%);
	border-radius: 24rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	box-shadow: 0 8rpx 24rpx rgba(200, 35, 44, 0.25);
}

.brand-name {
	font-size: 42rpx;
	font-weight: 600;
	color: #222;
}

.platform-name {
	font-size: 26rpx;
	color: #8a8a8a;
}

/* 表单卡片 */
.form-section {
	flex: 1;
	background: #ffffff;
	margin: 24rpx 32rpx;
	border-radius: 16rpx;
	padding: 56rpx 40rpx;
	box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.welcome-text {
	text-align: center;
	margin-bottom: 48rpx;
}

.welcome-title {
	font-size: 36rpx;
	font-weight: 500;
	color: #2a2a2a;
}

/* 登录按钮区域 */
.login-actions {
	width: 100%;
}

.login-btn {
	width: 100%;
	height: 88rpx;
	border-radius: 12rpx;
	font-size: 32rpx;
	font-weight: 500;
	border: none;
	display: flex;
	align-items: center;
	justify-content: center;
	transition: all 0.2s ease;
}

.login-btn::after {
	border: none;
}

.login-btn.primary {
	background: #c8232c;
	color: #ffffff;
}

.login-btn.primary:active {
	background: #a01d24;
}

.login-tips {
	text-align: center;
	margin-top: 24rpx;
	font-size: 24rpx;
	color: #9b9b9b;
}

/* 错误提示 */
.error-section {
	margin: 0 32rpx 24rpx;
}

.error-card {
	background: #fff5f5;
	border-left: 4rpx solid #ef4444;
	padding: 24rpx 32rpx;
	border-radius: 12rpx;
	display: flex;
	align-items: center;
	gap: 16rpx;
}

.error-icon {
	font-size: 32rpx;
}

.error-text {
	flex: 1;
	font-size: 26rpx;
	color: #ef4444;
	line-height: 1.6;
}

/* 跳过按钮 */
.skip-section {
	padding: 0 32rpx 60rpx;
}

.skip-btn {
	width: 100%;
	height: 88rpx;
	background: #ffffff;
	color: #666;
	border: 2rpx solid #e5e5e5;
	border-radius: 12rpx;
	font-size: 28rpx;
	display: flex;
	align-items: center;
	justify-content: center;
}

.skip-btn::after {
	border: none;
}

.skip-btn:active {
	background: #f9f9f9;
}

/* ===== 银行风格主题（工商银行红系） ===== */
.bank-theme .logo-icon {
	background: linear-gradient(135deg, #c8232c 0%, #9b1c23 100%);
	box-shadow: 0 8rpx 24rpx rgba(200, 35, 44, 0.28);
}

.bank-theme .brand-name {
	color: #1f1f1f;
}

.bank-theme .welcome-title {
	color: #1f1f1f;
}

.bank-theme .login-btn.primary {
	background: #c8232c;
}

.bank-theme .login-btn.primary:active {
	background: #9b1c23;
}

.bank-theme .skip-btn {
	border-color: #e6e6e6;
	color: #5c5c5c;
}

.bank-theme .header {
	box-shadow: 0 2rpx 8rpx rgba(200, 35, 44, 0.08);
}

.bank-theme .container {
	background: #f7f7f7;
}
