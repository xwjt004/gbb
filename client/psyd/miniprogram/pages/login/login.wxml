<view class="page">
  <!-- 装饰背景层 -->
  <view class="deco-circle c1"></view>
  <view class="deco-circle c2"></view>
  <view class="deco-circle c3"></view>
  <view class="deco-circle c4"></view>
  <view class="deco-ring r1"></view>
  <view class="deco-ring r2"></view>

  <!-- 底部波浪 -->
  <view class="wave-area">
    <view class="wave wave1"></view>
    <view class="wave wave2"></view>
  </view>

  <scroll-view scroll-y class="scroll-view" enhanced show-scrollbar="{{false}}">

    <!-- ===== 顶部品牌区域 ===== -->
    <view class="brand-section">
      <view class="logo-wrapper">
        <view class="logo-glow"></view>
        <text class="logo-icon">📸</text>
      </view>
      <text class="brand-title">乖宝宝儿童影楼</text>
      <text class="brand-slogan">用镜头记录每一份童真</text>
    </view>

    <!-- ===== 微信一键登录 ===== -->
    <view class="login-card">
      <view class="card-header">
        <text class="card-greeting">欢迎回来 💕</text>
        <text class="card-desc">微信授权即可使用全部功能</text>
      </view>

      <button
        class="btn-wechat {{loading ? 'btn-loading' : ''}}"
        bindtap="onLogin"
        disabled="{{loading || !agreed}}"
      >
        <text class="btn-wechat-icon">💬</text>
        <text class="btn-wechat-text">{{loading ? '登录中...' : '一键登录'}}</text>
      </button>

      <view wx:if="{{error}}" class="error-box">
        <text class="error-text">{{error}}</text>
      </view>
    </view>

    <!-- ===== 跳过 ===== -->
    <view class="skip-area">
      <text class="skip-btn" bindtap="skipLogin">暂不登录，先逛逛 ›</text>
    </view>

    <!-- ===== 协议（需主动勾选） ===== -->
    <view class="agreement">
      <label class="agreement-checkbox" bindtap="onAgreementChange">
        <view class="check-box {{agreed ? 'checked' : ''}}">
          <text wx:if="{{agreed}}" class="check-mark">✓</text>
        </view>
        <text class="agree-text">我已阅读并同意</text>
      </label>
      <text class="agreement-link" bindtap="onViewUserAgreement">《用户协议》</text>
      <text class="agree-text-and">和</text>
      <text class="agreement-link" bindtap="onViewPrivacyPolicy">《隐私政策》</text>
    </view>

  </scroll-view>

  <!-- ===== 完善资料弹窗 ===== -->
  <view wx:if="{{showCompleteProfile}}" class="profile-mask" catchtouchmove="preventMove">
    <view class="profile-modal">
      <view class="profile-header">
        <text class="profile-title">完善资料</text>
        <text class="profile-desc">只需一步，让我们更好地为您服务</text>
      </view>

      <!-- 微信头像 -->
      <view class="profile-avatar-section">
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image wx:if="{{tempAvatarPath}}" src="{{tempAvatarPath}}" class="profile-avatar" mode="aspectFill" />
          <view wx:else class="profile-avatar profile-avatar-placeholder">
            <text class="avatar-emoji">👶</text>
          </view>
          <view class="avatar-edit-badge">
            <text>📷</text>
          </view>
        </button>
        <text class="avatar-tip">点击选择头像</text>
      </view>

      <!-- 微信昵称（自动填充） -->
      <view class="profile-field">
        <text class="field-label">昵称</text>
        <input
          class="field-input"
          type="nickname"
          placeholder="点击自动填充昵称"
          placeholder-class="field-ph"
          value="{{nickname}}"
          bindinput="onNicknameInput"
        />
      </view>

      <!-- 手机号绑定 -->
      <view class="profile-field" wx:if="{{!phoneBound}}">
        <text class="field-label">手机号</text>
        <button
          class="phone-bind-btn"
          open-type="getPhoneNumber"
          bindgetphonenumber="onGetPhoneNumber"
        >
          一键绑定手机号
        </button>
      </view>
      <view class="profile-field" wx:else>
        <text class="field-label">手机号</text>
        <text class="field-bound">✅ 已绑定</text>
      </view>

      <!-- 提示：微信号 -->
      <view class="wxid-tip">
        <text>注：暂不支持获取微信号，如需请联系客服设置</text>
      </view>

      <!-- 操作按钮 -->
      <view class="profile-actions">
        <button class="action-primary" bindtap="onSubmitProfile">保存资料</button>
        <view class="action-skip" bindtap="skipCompleteProfile">跳过，稍后完善</view>
      </view>
    </view>
  </view>
</view>
