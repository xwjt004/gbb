page {
  background: #f5f0f2;
}

.container {
  min-height: 100vh;
  padding: 0 0 40rpx;
  background: linear-gradient(180deg, #faf8f9 0%, #f5f0f2 100%);
  display: block;
}

/* ===== 顶部装饰区 ===== */
.hero {
  position: relative;
  padding: 60rpx 32rpx 40rpx;
  text-align: center;
  overflow: hidden;
}

.hero-deco {
  position: absolute;
  top: -120rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(255,154,158,0.08) 0%, rgba(251,194,235,0.05) 50%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #3D2C33;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
  position: relative;
}

.hero-sub {
  display: block;
  font-size: 24rpx;
  color: #C8BCC1;
  letter-spacing: 2rpx;
  position: relative;
}

/* ===== 分类导航 ===== */
.category-scroll {
  white-space: nowrap;
  padding: 0 28rpx 20rpx;
}

.category-list {
  display: inline-flex;
  align-items: center;
  gap: 16rpx;
}

.category-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 36rpx;
  border-radius: 40rpx;
  background: rgba(255,255,255,0.9);
  font-size: 26rpx;
  color: #8a7a80;
  font-weight: 500;
  border: 2rpx solid rgba(232,224,227,0.5);
  transition: all 0.3s;
}

.category-item:active {
  transform: scale(0.95);
}

.category-item.active {
  background: linear-gradient(135deg, #FF9A9E, #FBC2EB);
  color: #fff;
  font-weight: 600;
  border-color: transparent;
  box-shadow: 0 6rpx 20rpx rgba(255,154,158,0.4);
}

/* ===== 筛选栏 ===== */
.filter-bar {
  padding: 0 28rpx 20rpx;
}

.filter-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.photographer-selector {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  background: rgba(255,255,255,0.9);
  border-radius: 40rpx;
  border: 2rpx solid rgba(232,224,227,0.5);
}

.photographer-selector:active {
  background: #f5f0f2;
  transform: scale(0.97);
}

.photographer-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.photographer-label {
  font-size: 26rpx;
  color: #8a7a80;
  font-weight: 500;
  margin-right: 8rpx;
}

.photographer-arrow {
  font-size: 22rpx;
  color: #C8BCC1;
}

/* ===== 摄影师下拉 ===== */
.photographer-dropdown {
  margin: -8rpx 28rpx 20rpx;
  background: rgba(255,255,255,0.96);
  border-radius: 24rpx;
  backdrop-filter: blur(20rpx);
  box-shadow: 0 12rpx 48rpx rgba(61,44,51,0.12);
  overflow: hidden;
  border: 2rpx solid rgba(255,255,255,0.6);
}

.photographer-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #f5f0f2;
}

.photographer-option:last-child {
  border-bottom: none;
}

.photographer-option:active {
  background: #faf8f9;
}

.photographer-option.active {
  background: linear-gradient(135deg, #FFF5F7, #FFE4EC);
}

.photographer-option-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.photographer-option-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2C33;
}

.photographer-option-title {
  font-size: 22rpx;
  color: #A88C96;
}

.photographer-option-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.photographer-option-style {
  font-size: 22rpx;
  color: #FF9A9E;
  background: #FFF5F7;
  padding: 6rpx 18rpx;
  border-radius: 12rpx;
}

.photographer-check {
  font-size: 28rpx;
  color: #FF9A9E;
  font-weight: 700;
}

/* ===== 骨架屏 ===== */
.skeleton {
  padding: 0 28rpx;
}

.skeleton-item {
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.skeleton-image {
  width: 100%;
  padding-bottom: 75%;
  background: linear-gradient(90deg, #f0ecee 25%, #e8e2e5 50%, #f0ecee 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ===== 空状态 ===== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 28rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #A88C96;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #D5C8CD;
}

/* ===== 作品列表 ===== */
.photo-list {
  padding: 0 28rpx;
}

.photo-card {
  width: 100%;
  height: 520rpx;
  margin-bottom: 24rpx;
  background: #f0ecee;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(61,44,51,0.06);
  transition: all 0.2s;
}

.photo-card:active {
  transform: scale(0.98);
  opacity: 0.92;
}

.photo-image {
  width: 100%;
  height: 520rpx;
  display: block;
}

/* ===== 底部提示 ===== */
.footer-tip {
  text-align: center;
  padding: 20rpx 0;
}

.footer-tip-text {
  font-size: 22rpx;
  color: #D5C8CD;
  letter-spacing: 2rpx;
}
