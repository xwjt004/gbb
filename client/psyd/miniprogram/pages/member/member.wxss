.page {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F7 0%, #F8F6F7 30%);
}

.scroll-view {
  width: 100%;
  height: 100vh;
}

/* ===== 顶部装饰 ===== */
.top-deco {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 240rpx;
  background: linear-gradient(180deg, #FFF0F5, transparent);
  pointer-events: none;
}

/* ===== 会员卡片 ===== */
.member-card {
  position: relative;
  margin: 24rpx 24rpx 0;
  border-radius: 32rpx;
  padding: 36rpx 32rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 48rpx rgba(0,0,0,0.06);
}

.card-shine {
  position: absolute;
  top: -50%;
  right: -50%;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(255,255,255,0.4), transparent 70%);
  pointer-events: none;
}

.card-pattern {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15), transparent 70%);
  pointer-events: none;
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.level-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.level-icon {
  font-size: 48rpx;
}

.level-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #4A2C3A;
  letter-spacing: 2rpx;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  border: 3rpx solid rgba(255,255,255,0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.card-data {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255,255,255,0.3);
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
}

.data-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  flex: 1;
}

.data-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #4A2C3A;
}

.data-label {
  font-size: 22rpx;
  color: #8A7A82;
  font-weight: 500;
}

.data-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(0,0,0,0.06);
}

/* ===== 升级进度 ===== */
.upgrade-card {
  margin: 24rpx 24rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.upgrade-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.upgrade-title {
  font-size: 26rpx;
  color: #8A7A82;
}

.upgrade-need {
  font-size: 26rpx;
  font-weight: 700;
  color: #FF6B9D;
}

.upgrade-bar {
  position: relative;
  width: 100%;
  height: 16rpx;
  background: #F0E8EB;
  border-radius: 8rpx;
  overflow: visible;
  margin-bottom: 16rpx;
}

.upgrade-bar-inner {
  height: 100%;
  background: linear-gradient(90deg, #FF9A9E, #FBC2EB, #FFD1E8);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.upgrade-dot {
  position: absolute;
  top: 50%;
  width: 24rpx;
  height: 24rpx;
  background: #fff;
  border: 4rpx solid #FF9A9E;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 0 2rpx 8rpx rgba(255,154,158,0.4);
}

.upgrade-tip {
  font-size: 22rpx;
  color: #C8BCC2;
}

/* ===== 等级阶梯 ===== */
.section {
  margin: 24rpx 24rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.section:active {
  background: #FAF8F9;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3D2C33;
}

.section-more {
  font-size: 24rpx;
  color: #FF9A9E;
}

.level-steps {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 8rpx 0;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  position: relative;
}

.step-item + .step-item::before {
  content: '';
  position: absolute;
  top: 32rpx;
  left: -50%;
  width: 100%;
  height: 4rpx;
  background: #F0E8EB;
  z-index: 0;
}

.step-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #F5F0F2;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
  font-size: 32rpx;
  transition: all 0.3s;
}

.step-unlocked {
  background: linear-gradient(135deg, #FFF0F5, #FFE4EC);
  box-shadow: 0 4rpx 16rpx rgba(255,154,158,0.2);
}

.step-name {
  font-size: 20rpx;
  color: #C8BCC2;
  white-space: nowrap;
}

.step-name-active {
  color: #4A2C3A;
  font-weight: 600;
}

/* ===== 权益网格 ===== */
.benefits-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx 8rpx;
}

.benefit-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 8rpx;
  padding: 12rpx 4rpx;
}

.b-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #FFF0F5, #FFE4EC);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.b-icon {
  font-size: 32rpx;
}

.b-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #4A2C3A;
}

.b-desc {
  font-size: 18rpx;
  color: #B8ADB2;
  line-height: 1.3;
}

.footer-gap {
  height: 48rpx;
}
