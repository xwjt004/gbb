<view class="page">
  <scroll-view scroll-y class="scroll-view" enhanced show-scrollbar="{{false}}">

    <!-- 积分头部 -->
    <view class="points-hero">
      <view class="points-hero-bg"></view>
      <text class="points-hero-value">{{points}}</text>
      <text class="points-hero-label">当前积分</text>
      <view class="points-hero-actions">
        <view class="hero-action" bindtap="contactService">
          <text class="hero-action-icon">📞</text>
          <text class="hero-action-text">联系客服</text>
        </view>
      </view>
    </view>

    <!-- 积分记录 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">积分记录</text>
      </view>

      <!-- 加载中 -->
      <view wx:if="{{loading && records.length === 0}}" class="loading-wrap">
        <text>加载中...</text>
      </view>

      <!-- 空状态 -->
      <view wx:elif="{{records.length === 0}}" class="empty-wrap">
        <text class="empty-text">暂无积分记录</text>
      </view>

      <!-- 记录列表 -->
      <view wx:else class="records-list">
        <view wx:for="{{records}}" wx:key="id" class="record-row">
          <view class="record-left">
            <view class="record-icon-wrap {{item.type === 'INCOME' ? 'icon-income' : 'icon-expense'}}">
              <text>{{item.type === 'INCOME' ? '➕' : '➖'}}</text>
            </view>
            <view class="record-info">
              <text class="record-remark">{{item.remark || item.reason}}</text>
              <text class="record-time">{{item.createdAt}}</text>
            </view>
          </view>
          <text class="record-amount {{item.type === 'INCOME' ? 'amount-income' : 'amount-expense'}}">
            {{item.type === 'INCOME' ? '+' : ''}}{{item.amount}}
          </text>
        </view>
      </view>
    </view>

    <view class="footer-gap"></view>
  </scroll-view>
</view>
