.page {
  width: 100%;
  min-height: 100vh;
  background: #F8F6F7;
}

.scroll-view {
  width: 100%;
  height: 100vh;
}

/* ===== 积分头部 ===== */
.points-hero {
  position: relative;
  margin: 24rpx 24rpx 0;
  border-radius: 32rpx;
  padding: 48rpx 32rpx 36rpx;
  background: linear-gradient(135deg, #FF9A9E, #FBC2EB);
  display: flex;
  flex-direction: column;
  align-items: center;
  overflow: hidden;
  box-shadow: 0 12rpx 48rpx rgba(255,154,158,0.3);
}

.points-hero-bg {
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.15), transparent 60%);
  pointer-events: none;
}

.points-hero-value {
  font-size: 80rpx;
  font-weight: 800;
  color: #fff;
  text-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  margin-bottom: 8rpx;
}

.points-hero-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 24rpx;
}

.points-hero-actions {
  display: flex;
  gap: 32rpx;
}

.hero-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 24rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 16rpx;
}

.hero-action-icon {
  font-size: 28rpx;
}

.hero-action-text {
  font-size: 20rpx;
  color: rgba(255,255,255,0.9);
}

/* ===== 记录区域 ===== */
.section {
  margin: 24rpx 24rpx 0;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  overflow: hidden;
}

.section-header {
  padding: 28rpx 28rpx 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3D2C33;
}

.loading-wrap, .empty-wrap {
  padding: 60rpx 0;
  text-align: center;
  color: #B8ADB2;
  font-size: 26rpx;
}

/* ===== 记录行 ===== */
.record-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F8F6F7;
}

.record-row:last-child {
  border-bottom: none;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.record-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.icon-income {
  background: #E8F8E8;
}

.icon-expense {
  background: #FFF0F0;
}

.record-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.record-remark {
  font-size: 26rpx;
  color: #3D2C33;
}

.record-time {
  font-size: 22rpx;
  color: #C8BCC2;
}

.record-amount {
  font-size: 30rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.amount-income {
  color: #07C160;
}

.amount-expense {
  color: #FF6B6B;
}

.footer-gap {
  height: 48rpx;
}
