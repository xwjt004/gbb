<view class="container">
  <view class="header">
    <view class="logo">🎨</view>
    <text class="title">乖宝宝儿童影楼商城</text>
    <text class="subtitle">微信登录测试</text>
  </view>

  <!-- 登录按钮 -->
  <view class="login-section">
    <button 
      type="primary" 
      class="login-btn" 
      bindtap="testLogin"
      loading="{{loading}}"
    >
      {{loading ? '登录中...' : '测试微信登录'}}
    </button>
    
    <!-- 获取用户信息按钮 -->
    <button 
      wx:if="{{loginResult && !userInfo.nickname}}"
      type="default" 
      class="profile-btn" 
      bindtap="getUserProfile"
    >
      📝 获取用户昵称和头像
    </button>
  </view>

  <!-- 登录结果 -->
  <view class="result-section" wx:if="{{loginResult}}">
    <view class="result-card">
      <view class="result-header">
        <text class="success-icon">✅</text>
        <text class="success-text">登录成功</text>
      </view>
      
      <view class="info-list">
        <view class="info-item">
          <text class="label">用户ID:</text>
          <text class="value">{{userInfo.id}}</text>
        </view>
        <view class="info-item">
          <text class="label">OpenID:</text>
          <text class="value">{{userInfo.openid}}</text>
        </view>
        <view class="info-item">
          <text class="label">昵称:</text>
          <text class="value">{{userInfo.nickname || '未设置'}}</text>
        </view>
        <view class="info-item">
          <text class="label">头像:</text>
          <image wx:if="{{userInfo.avatar}}" class="avatar" src="{{userInfo.avatar}}" mode="aspectFill"></image>
          <text wx:else class="value">未设置</text>
        </view>
        <view class="info-item">
          <text class="label">手机号:</text>
          <text class="value">{{userInfo.phone || '未绑定'}}</text>
        </view>
        <view class="info-item">
          <text class="label">会员等级:</text>
          <text class="value member-level">{{memberLevelText}}</text>
        </view>
      </view>

      <view class="token-section">
        <text class="token-label">Access Token:</text>
        <text class="token-text">{{accessToken}}</text>
      </view>
    </view>

    <!-- 获取手机号按钮 -->
    <button 
      type="default" 
      class="phone-btn" 
      open-type="getPhoneNumber" 
      bindgetphonenumber="getPhoneNumber"
    >
      获取手机号
    </button>

    <!-- 手机号结果 -->
    <view class="phone-result" wx:if="{{phoneNumber}}">
      <text class="success-icon">✅</text>
      <text class="phone-text">手机号: {{phoneNumber}}</text>
    </view>
  </view>

  <!-- 错误信息 -->
  <view class="error-section" wx:if="{{error}}">
    <view class="error-card">
      <text class="error-icon">❌</text>
      <text class="error-text">{{error}}</text>
      <text class="error-hint">提示: 使用真实微信 code 才能成功登录</text>
    </view>
  </view>

  <!-- API 信息 -->
  <view class="api-info">
    <text class="api-title">后端 API:</text>
    <text class="api-url">http://localhost:3000</text>
    <text class="api-endpoint">POST /api/v1/wx-auth/login</text>
  </view>

  <!-- 操作按钮组 -->
  <view class="action-buttons" wx:if="{{loginResult}}">
    <button class="action-btn" bindtap="clearData">清除数据</button>
    <button class="action-btn" bindtap="viewToken">查看完整Token</button>
  </view>

  <!-- 快速导航 -->
  <view class="nav-section">
    <view class="nav-title">🚀 快速导航</view>
    <view class="nav-buttons">
      <button class="nav-btn" bindtap="goToProducts">📦 商品列表</button>
      <button class="nav-btn" bindtap="goToCart">🛒 购物车</button>
      <button class="nav-btn" bindtap="goToOrders">📋 订单列表</button>
      <button class="nav-btn" bindtap="goToPackages">🎁 套系列表</button>
    </view>
  </view>
</view>
