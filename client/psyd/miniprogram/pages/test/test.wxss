/* pages/test/test.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

/* 头部样式 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  padding: 40rpx 0;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  backdrop-filter: blur(10px);
}

.logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.2);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 登录区域 */
.login-section {
  margin-bottom: 40rpx;
}

.login-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  border: none;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  box-shadow: 0 8rpx 16rpx rgba(245, 87, 108, 0.3);
  transition: all 0.3s;
}

.login-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 8rpx rgba(245, 87, 108, 0.3);
}

.profile-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
  border: none;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 16rpx rgba(67, 233, 123, 0.3);
}

.profile-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 8rpx rgba(67, 233, 123, 0.3);
}

/* 结果区域 */
.result-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  font-size: 28rpx;
}

.info-label {
  min-width: 160rpx;
  color: #666;
  font-weight: 500;
}

.info-value {
  flex: 1;
  color: #333;
  word-break: break-all;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #f0f0f0;
}

.member-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.token-value {
  font-size: 24rpx;
  color: #999;
  font-family: 'Courier New', monospace;
  padding: 10rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 手机号授权按钮 */
.phone-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  border: none;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-top: 30rpx;
  box-shadow: 0 8rpx 16rpx rgba(79, 172, 254, 0.3);
}

.phone-number {
  display: block;
  margin-top: 20rpx;
  padding: 20rpx;
  background: #f0f9ff;
  border-radius: 12rpx;
  text-align: center;
  color: #0066cc;
  font-size: 32rpx;
  font-weight: bold;
}

/* 错误提示 */
.error-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  border-left: 6rpx solid #ff4444;
  box-shadow: 0 8rpx 24rpx rgba(255, 68, 68, 0.2);
}

.error-icon {
  font-size: 48rpx;
  display: block;
  text-align: center;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #ff4444;
  line-height: 1.6;
  white-space: pre-wrap;
  text-align: center;
}

/* API 信息 */
.api-info {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  backdrop-filter: blur(10px);
}

.api-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.api-endpoint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.8;
  word-break: break-all;
  font-family: 'Courier New', monospace;
  background: rgba(0, 0, 0, 0.2);
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

/* 操作按钮 */
.action-section {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #fff;
  backdrop-filter: blur(10px);
}

.action-btn:active {
  background: rgba(255, 255, 255, 0.3);
}

/* 提示信息 */
.hint-text {
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 40rpx;
  line-height: 1.6;
}

/* 快速导航 */
.nav-section {
  margin-top: 40rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 30rpx;
  backdrop-filter: blur(10px);
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 24rpx;
  text-align: center;
}

.nav-buttons {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.nav-btn {
  height: 100rpx;
  background: linear-gradient(135deg, #ffd89b 0%, #ff9a76 100%);
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.nav-btn:nth-child(1) {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.nav-btn:nth-child(2) {
  background: linear-gradient(135deg, #ffd89b 0%, #ff9a76 100%);
}

.nav-btn:nth-child(3) {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.nav-btn:nth-child(4) {
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%);
}

