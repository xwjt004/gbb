/* pages/appointment/appointment.wxss */

.appointment-page {
  width: 100%;
  min-height: 100vh;
  background: #f5f7fa;
}

.scroll-container {
  width: 100%;
  height: 100vh;
}

/* 顶部Banner */
.appointment-banner {
  margin-bottom: 32rpx;
  background: linear-gradient(90deg, #FF6F3D 0%, #FFD600 50%, #4CD964 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(255,111,61,0.12);
  padding: 16rpx 0;
}
.banner-img {
  width: 96%;
  height: 240rpx;
  border-radius: 24rpx;
  margin: 0 auto;
  box-shadow: 0 4rpx 16rpx rgba(76,217,100,0.08);
}

.top-banner {
  position: relative;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 100%);
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.banner-subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
}

/* 快速预约区域 */
.quick-book-section {
  background: #ffffff;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.title-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.book-types-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.book-type-card {
  position: relative;
  background: linear-gradient(135deg, #f9fafb 0%, #ffffff 100%);
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
  transition: all 0.3s ease;
  overflow: hidden;
}

.book-type-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.15);
}

.card-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
  text-align: center;
}

.card-desc {
  font-size: 22rpx;
  color: #999999;
  text-align: center;
  line-height: 1.5;
}

.card-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 6rpx 12rpx;
  background: #ff4444;
  color: #ffffff;
  font-size: 20rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.card-badge.hot {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff4444 100%);
}

/* 我的预约区域 */
.my-appointments-section {
  background: #ffffff;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #999999;
}

.arrow {
  font-size: 28rpx;
  margin-left: 4rpx;
}

/* 状态Tab */
.status-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.status-tab {
  position: relative;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #666666;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-tab.active {
  color: #667eea;
  font-weight: 600;
}

.status-tab.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60%;
  height: 4rpx;
  background: #667eea;
  border-radius: 2rpx;
}

.tab-badge {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #ff4444;
  color: #ffffff;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 预约列表 */
.appointment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.appointment-card {
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid #e5e7eb;
  transition: all 0.3s ease;
}

.appointment-card:active {
  background: #f0f2f5;
}

/* 卡片头部 */
.card-header {
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #e5e7eb;
}

.order-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-no {
  font-size: 24rpx;
  color: #999999;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-badge.status-PENDING_PAYMENT {
  background: #fff3e0;
  color: #f57c00;
}

.status-badge.status-PENDING_SHOOTING {
  background: #e3f2fd;
  color: #1976d2;
}

.status-badge.status-COMPLETED {
  background: #e8f5e9;
  color: #388e3c;
}

/* 预约信息 */
.appointment-info {
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.info-row .label {
  font-size: 26rpx;
  color: #666666;
  width: 180rpx;
}

.info-row .value {
  font-size: 26rpx;
  color: #333333;
  flex: 1;
}

.info-row .value.highlight {
  color: #667eea;
  font-weight: 600;
}

/* 操作按钮 */
.card-actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.action-btn {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
  border: none;
}

.action-btn::after {
  border: none;
}

.cancel-btn {
  background: #ffffff;
  color: #999999;
  border: 2rpx solid #e5e7eb;
}

.reschedule-btn {
  background: #ffffff;
  color: #667eea;
  border: 2rpx solid #667eea;
}

.primary-btn {
  background: #667eea;
  color: #ffffff;
}

.detail-btn {
  background: #f9fafb;
  color: #666666;
  border: 2rpx solid #e5e7eb;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

.empty-btn {
  width: 240rpx;
  height: 72rpx;
  background: #667eea;
  color: #ffffff;
  border-radius: 36rpx;
  border: none;
  font-size: 28rpx;
}

.empty-btn::after {
  border: none;
}

/* 加载状态 */
.loading-state {
  padding: 48rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #999999;
}

/* 预约须知 */
.notice-section {
  background: #ffffff;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.notice-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.notice-number {
  min-width: 40rpx;
  height: 40rpx;
  background: #667eea;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

.notice-text {
  flex: 1;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  padding-top: 6rpx;
}

/* 联系客服 */
.contact-section {
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.contact-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 16rpx;
  border: none;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.contact-btn::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
}

/* 底部占位 */
.bottom-placeholder {
  height: 32rpx;
}
