/* 商品列表页样式 */
.product-list-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 20rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #fff;
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.clear-btn {
  font-size: 32rpx;
  color: #999;
  padding: 0 8rpx;
}

.sort-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #f5f5f5;
  border-radius: 40rpx;
}

/* 分类标签 - 支持换行显示 */
.category-tabs {
  display: flex;
  flex-wrap: wrap;  /* 允许换行 */
  gap: 20rpx;       /* 统一间距 */
  padding: 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-item {
  padding: 12rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 40rpx;
  transition: all 0.3s;
  white-space: nowrap;  /* 单个标签内文字不换行 */
}

.category-item.active {
  color: #fff;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  font-weight: bold;
}

/* 商品列表 */
.product-list {
  padding: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.product-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}

.product-card:active {
  transform: scale(0.98);
}

.product-image-wrapper {
  position: relative;
  width: 100%;
  height: 340rpx;
}

.product-image {
  width: 100%;
  height: 100%;
}

.stock-out-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 8rpx 16rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 22rpx;
  border-radius: 8rpx;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-wrapper {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.price-symbol {
  font-size: 24rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.price-value {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.sales-count {
  margin-left: 12rpx;
  font-size: 22rpx;
  color: #999;
}

.cart-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  background: #f5f5f5;
  border-radius: 50%;
  transition: all 0.2s;
}

.cart-btn:active {
  background: #e8e8e8;
}

/* 加载状态 */
.loading-more,
.no-more {
  padding: 40rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

/* 排序菜单 */
.sort-menu-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.sort-menu {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 0;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.sort-menu-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.sort-menu-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.sort-menu-close {
  font-size: 40rpx;
  color: #999;
  padding: 0 16rpx;
}

.sort-option {
  padding: 32rpx 40rpx;
  font-size: 28rpx;
  color: #333;
  transition: all 0.2s;
}

.sort-option.active {
  color: #667eea;
  font-weight: bold;
  background: #f5f5ff;
}

.sort-option:active {
  background: #f5f5f5;
}

/* 选择模式提示栏 */
.select-mode-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, #07c160, #05a850);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

.select-mode-cancel {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  padding: 8rpx 20rpx;
  border: 2rpx solid rgba(255,255,255,0.5);
  border-radius: 24rpx;
}
