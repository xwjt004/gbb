<view class="address-edit-container">
  <view class="form">
    <!-- 收货人 -->
    <view class="form-item">
      <view class="label">收货人</view>
      <input
        class="input"
        placeholder="请输入收货人姓名"
        value="{{form.receiverName}}"
        bindinput="onNameInput"
      />
    </view>

    <!-- 手机号码 -->
    <view class="form-item">
      <view class="label">手机号码</view>
      <input
        class="input"
        type="number"
        placeholder="请输入手机号码"
        value="{{form.phone}}"
        maxlength="11"
        bindinput="onPhoneInput"
      />
    </view>

    <!-- 所在地区 -->
    <view class="form-item">
      <view class="label">所在地区</view>
      <picker
        mode="region"
        value="{{[form.province, form.city, form.district]}}"
        bindchange="onRegionChange"
      >
        <view class="picker">
          <text wx:if="{{form.province}}">{{form.province}} {{form.city}} {{form.district}}</text>
          <text wx:else class="placeholder">请选择省市区</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 详细地址 -->
    <view class="form-item full">
      <view class="label">详细地址</view>
      <textarea
        class="textarea"
        placeholder="请输入详细地址，如街道、楼牌号等"
        value="{{form.detail}}"
        maxlength="200"
        bindinput="onDetailInput"
      ></textarea>
    </view>

    <!-- 邮政编码（可选） -->
    <view class="form-item">
      <view class="label">邮政编码（可选）</view>
      <input
        class="input"
        type="number"
        placeholder="请输入6位邮政编码"
        value="{{form.postalCode}}"
        maxlength="6"
        bindinput="onPostalCodeInput"
      />
    </view>

    <!-- 设为默认 -->
    <view class="form-item">
      <view class="label">设为默认地址</view>
      <switch
        checked="{{form.isDefault}}"
        color="#667eea"
        bindchange="onToggleDefault"
      />
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="footer">
    <button
      class="save-btn {{submitting ? 'disabled' : ''}}"
      bindtap="onSave"
      disabled="{{submitting}}"
    >
      {{submitting ? '保存中...' : '保存'}}
    </button>
  </view>
</view>
