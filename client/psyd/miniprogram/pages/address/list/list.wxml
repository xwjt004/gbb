<view class="address-container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <!-- 空状态 -->
  <view wx:elif="{{addresses.length === 0}}" class="empty">
    <view class="empty-icon">📍</view>
    <view class="empty-text">暂无收货地址</view>
    <button class="add-btn" bindtap="onAddAddress">添加地址</button>
  </view>

  <!-- 地址列表 -->
  <view wx:else class="address-list">
    <view
      wx:for="{{addresses}}"
      wx:key="id"
      class="address-item {{selectMode ? 'selectable' : ''}}"
      data-index="{{index}}"
      bindtap="{{selectMode ? 'onSelectAddress' : ''}}"
    >
      <view class="address-info">
        <view class="address-header">
          <view class="user-info">
            <text class="name">{{item.receiverName}}</text>
            <text class="phone">{{item.phone}}</text>
          </view>
          <view wx:if="{{item.isDefault}}" class="default-tag">默认</view>
        </view>
        
        <view class="address-detail">
          {{item.province}} {{item.city}} {{item.district}} {{item.detail}}
        </view>
      </view>

      <view wx:if="{{!selectMode}}" class="address-actions">
        <view class="action-item" data-id="{{item.id}}" bindtap="onEditAddress" catchtap="onEditAddress">
          <text class="action-icon">✏️</text>
          <text class="action-text">编辑</text>
        </view>
        <view class="action-item" data-id="{{item.id}}" bindtap="onDeleteAddress" catchtap="onDeleteAddress">
          <text class="action-icon">🗑️</text>
          <text class="action-text">删除</text>
        </view>
        <view wx:if="{{!item.isDefault}}" class="action-item" data-id="{{item.id}}" bindtap="onSetDefault" catchtap="onSetDefault">
          <text class="action-icon">⭐</text>
          <text class="action-text">默认</text>
        </view>
      </view>

      <view wx:if="{{selectMode}}" class="select-icon">
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 底部新增按钮 -->
  <view wx:if="{{addresses.length > 0}}" class="footer-bar">
    <button class="add-btn-full" bindtap="onAddAddress">
      <text class="icon">+</text> 新增收货地址
    </button>
  </view>
</view>
