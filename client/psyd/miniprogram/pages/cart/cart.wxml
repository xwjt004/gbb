<!-- 购物车页面 -->
<view class="cart-container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-text">加载中...</view>
  </view>

  <!-- 空购物车 -->
  <view wx:elif="{{cartItems.length === 0}}" class="empty-cart">
    <view class="empty-icon-wrapper">
      <text class="empty-icon-text">🛒</text>
    </view>
    <view class="empty-text">购物车是空的</view>
    <view class="empty-tip">快去挑选心仪的商品吧~</view>
    <button class="continue-btn" bindtap="onContinueShopping">去逛逛</button>
  </view>

  <!-- 购物车列表 -->
  <view wx:else class="cart-content">
    <!-- 顶部操作栏 -->
    <view class="top-bar">
      <view class="select-all" bindtap="onSelectAll">
        <icon class="checkbox" type="{{allSelected ? 'success' : 'circle'}}" size="20"></icon>
        <text class="select-text">全选</text>
      </view>
      <view class="clear-btn" bindtap="onClearCart">清空购物车</view>
    </view>

    <!-- 失效商品提示 -->
    <view wx:if="{{hasInvalidItems}}" class="invalid-tip">
      <view class="tip-text">购物车中有失效商品</view>
      <view class="delete-invalid" bindtap="onDeleteInvalid">删除失效商品</view>
    </view>

    <!-- 商品列表 -->
    <scroll-view class="cart-list" scroll-y>
      <view
        wx:for="{{cartItems}}"
        wx:key="id"
        class="cart-item {{item.isValid ? '' : 'invalid'}}"
      >
        <!-- 选择框 -->
        <view class="item-checkbox" data-index="{{index}}" bindtap="onItemSelect">
          <icon
            class="checkbox"
            type="{{item.selected ? 'success' : 'circle'}}"
            size="20"
          ></icon>
        </view>

        <!-- 商品信息 -->
        <view class="item-content">
          <!-- 商品图片 -->
          <image class="item-image" src="{{item.image}}" mode="aspectFill"></image>

          <!-- 商品详情 -->
          <view class="item-details">
            <view class="item-name">{{item.name}}</view>
            <view class="item-spec">{{item.specification}}</view>
            
            <!-- 失效标签 -->
            <view wx:if="{{!item.isValid}}" class="invalid-tag">已失效</view>

            <!-- 价格和数量 -->
            <view class="item-bottom">
              <view class="item-price">¥{{item.price}}</view>
              
              <!-- 数量控制器 -->
              <view wx:if="{{item.isValid}}" class="quantity-control">
                <view
                  class="quantity-btn minus {{item.quantity <= 1 ? 'disabled' : ''}}"
                  data-index="{{index}}"
                  bindtap="onDecreaseQuantity"
                >-</view>
                <view class="quantity-value">{{item.quantity}}</view>
                <view
                  class="quantity-btn plus {{item.quantity >= item.stock ? 'disabled' : ''}}"
                  data-index="{{index}}"
                  bindtap="onIncreaseQuantity"
                >+</view>
              </view>
            </view>

            <!-- 库存提示 -->
            <view wx:if="{{item.isValid && item.stock < 10}}" class="stock-tip">
              仅剩 {{item.stock}} 件
            </view>
          </view>

          <!-- 删除按钮 -->
          <view class="item-delete" data-index="{{index}}" bindtap="onDeleteItem">
            <icon type="clear" size="20" color="#999"></icon>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 底部结算栏 -->
  <view wx:if="{{cartItems.length > 0}}" class="footer-bar">
    <view class="footer-left">
      <view class="home-btn" bindtap="goHome">
        <text class="home-icon">🏠</text>
        <text class="home-text">首页</text>
      </view>
      <view class="select-all" bindtap="onSelectAll">
        <icon class="checkbox" type="{{allSelected ? 'success' : 'circle'}}" size="20"></icon>
        <text class="select-text">全选</text>
      </view>
      <view class="total-info">
        <text class="total-label">合计：</text>
        <text class="total-price">¥{{totalPrice}}</text>
      </view>
    </view>
    <view
      class="checkout-btn {{selectedCount > 0 ? 'active' : 'disabled'}}"
      bindtap="onCheckout"
    >
      去结算{{selectedCount > 0 ? '(' + selectedCount + ')' : ''}}
    </view>
  </view>
</view>
