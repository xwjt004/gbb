/* 购物车页面样式 - 儿童影楼欢快风格 */

.cart-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #FFF9E6 0%, #FFE9F3 50%, #E6F3FF 100%);
  padding-bottom: 120rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.loading-text {
  color: #FF6B9D;
  font-size: 28rpx;
  font-weight: 500;
}

/* 空购物车 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 60rpx 40rpx;
}

.empty-icon-wrapper {
  width: 300rpx;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  background: linear-gradient(135deg, #FFE5F0 0%, #FFF0F5 100%);
  border-radius: 50%;
  box-shadow: 0 10rpx 30rpx rgba(255, 107, 157, 0.15);
}

.empty-icon-text {
  font-size: 160rpx;
}

.empty-text {
  font-size: 34rpx;
  color: #FF6B9D;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #FFA0C1;
  margin-bottom: 60rpx;
}

.continue-btn {
  width: 300rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FFAB8E 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.4);
}

/* 购物车内容 */
.cart-content {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 顶部操作栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF5F8 100%);
  border-bottom: 2rpx solid #FFE5EE;
  border-radius: 0 0 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 157, 0.08);
}

.select-all {
  display: flex;
  align-items: center;
}

.checkbox {
  margin-right: 16rpx;
}

.select-text {
  font-size: 28rpx;
  color: #FF6B9D;
  font-weight: 600;
}

.clear-btn {
  font-size: 26rpx;
  color: #FFA0C1;
  padding: 10rpx 20rpx;
  background: #FFF0F5;
  border-radius: 16rpx;
  font-weight: 500;
}

/* 失效商品提示 */
.invalid-tip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE5CC 100%);
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.15);
}

.tip-text {
  font-size: 26rpx;
  color: #FF9800;
  font-weight: 500;
}

.delete-invalid {
  font-size: 26rpx;
  color: #FF6B35;
  padding: 10rpx 20rpx;
  background: #FFF;
  border-radius: 12rpx;
  font-weight: 500;
}

/* 商品列表 */
.cart-list {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx 0;
}

.cart-item {
  display: flex;
  align-items: flex-start;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFFBFC 100%);
  padding: 24rpx 30rpx;
  margin: 0 30rpx 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 157, 0.12);
  border: 2rpx solid rgba(255, 107, 157, 0.1);
  transition: all 0.3s;
}

.cart-item.invalid {
  opacity: 0.5;
  background: linear-gradient(135deg, #F5F5F5 0%, #FAFAFA 100%);
}

.item-checkbox {
  padding: 20rpx 16rpx 20rpx 0;
}

.item-content {
  flex: 1;
  display: flex;
  position: relative;
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: linear-gradient(135deg, #FFE5F0 0%, #FFF0F5 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 157, 0.15);
  border: 3rpx solid #FFF;
}

.item-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 160rpx;
}

.item-name {
  font-size: 30rpx;
  color: #FF6B9D;
  font-weight: 600;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-spec {
  font-size: 24rpx;
  color: #FFA0C1;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.invalid-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
  color: #fff;
  font-size: 22rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  align-self: flex-start;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.3);
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-price {
  font-size: 36rpx;
  color: #FF6B9D;
  font-weight: 700;
}

.item-price::before {
  content: '¥';
  font-size: 26rpx;
  font-weight: 600;
}

/* 数量控制器 */
.quantity-control {
  display: flex;
  align-items: center;
  border: 2rpx solid #FFD6E8;
  border-radius: 20rpx;
  overflow: hidden;
  background: #FFF;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 157, 0.1);
}

.quantity-btn {
  width: 60rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFE5F0 0%, #FFF0F5 100%);
  font-size: 32rpx;
  color: #FF6B9D;
  transition: all 0.3s;
  font-weight: 600;
}

.quantity-btn.disabled {
  color: #FFD6E8;
  background: #FAFAFA;
}

.quantity-btn.minus {
  border-right: 2rpx solid #FFD6E8;
}

.quantity-btn.plus {
  border-left: 2rpx solid #FFD6E8;
}

.quantity-value {
  min-width: 60rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #FF6B9D;
  background: #FFF;
  padding: 0 12rpx;
  font-weight: 600;
}

.stock-tip {
  font-size: 22rpx;
  color: #FFB74D;
  margin-top: 8rpx;
  font-weight: 500;
}

/* 删除按钮 */
.item-delete {
  position: absolute;
  top: 0;
  right: 0;
  padding: 10rpx;
  color: #FF6B9D;
  font-size: 40rpx;
}

/* 底部结算栏 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF5F8 100%);
  padding: 24rpx 30rpx;
  border-top: 2rpx solid #FFE5EE;
  border-radius: 24rpx 24rpx 0 0;
  box-shadow: 0 -6rpx 24rpx rgba(255, 107, 157, 0.15);
  z-index: 100;
}

.footer-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.home-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #FFE5F0 0%, #FFF0F5 100%);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 157, 0.1);
}

.home-icon {
  font-size: 36rpx;
}

.home-text {
  font-size: 20rpx;
  color: #FF6B9D;
  font-weight: 600;
  margin-top: 4rpx;
}

.footer-left .select-all {
  margin-right: 30rpx;
}

.total-info {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 26rpx;
  color: #FFA0C1;
  font-weight: 500;
}

.total-price {
  font-size: 40rpx;
  color: #FF6B9D;
  font-weight: 700;
  margin-left: 8rpx;
}

.checkout-btn {
  width: 220rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 700;
  transition: all 0.3s;
}

.checkout-btn.active {
  background: linear-gradient(135deg, #FF6B9D 0%, #FFAB8E 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.4);
}

.checkout-btn.disabled {
  background: #FFD6E8;
  color: #FFF;
}
