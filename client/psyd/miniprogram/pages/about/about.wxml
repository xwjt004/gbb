<view class="page">
  <scroll-view scroll-y class="scroll-view" enhanced show-scrollbar="{{false}}">

    <!-- 品牌介绍 -->
    <view class="brand-hero">
      <view class="brand-icon-circle">
        <text class="brand-icon-large">📸</text>
      </view>
      <text class="brand-name">{{shop.name}}</text>
      <text class="brand-desc">{{shop.description}}</text>
    </view>

    <!-- 店铺照片 -->
    <view wx:if="{{shop.shopPhoto}}" class="photo-wrap">
      <image src="{{shop.shopPhoto}}" class="shop-photo" mode="aspectFill" />
    </view>

    <!-- 联系信息 -->
    <view class="info-card">
      <view class="info-row" bindtap="makePhoneCall">
        <view class="info-icon-wrap" style="background:#E8F5E9;">
          <text class="info-icon">📞</text>
        </view>
        <view class="info-content">
          <text class="info-label">客服电话</text>
          <text class="info-value">{{shop.phone}}</text>
        </view>
        <text class="info-action">拨打</text>
      </view>

      <view class="info-row" bindtap="copyAddress">
        <view class="info-icon-wrap" style="background:#FFF8E1;">
          <text class="info-icon">📍</text>
        </view>
        <view class="info-content">
          <text class="info-label">门店地址</text>
          <text class="info-value">{{shop.address}}</text>
        </view>
        <text class="info-action">复制</text>
      </view>

      <view class="info-row">
        <view class="info-icon-wrap" style="background:#E3F2FD;">
          <text class="info-icon">🕐</text>
        </view>
        <view class="info-content">
          <text class="info-label">营业时间</text>
          <text class="info-value">{{shop.businessHours}}</text>
        </view>
      </view>
    </view>

    <!-- 店铺位置地图 -->
    <view wx:if="{{shop.latitude && shop.longitude}}" class="map-card">
      <view class="map-header">
        <text class="map-title">店铺位置</text>
      </view>
      <view class="map-wrap" bindtap="openMap">
        <map
          latitude="{{shop.latitude}}"
          longitude="{{shop.longitude}}"
          markers="{{mapMarkers}}"
          scale="16"
          style="width:100%;height:320rpx;"
          enable-satellite="{{false}}"
          show-compass="{{false}}"
        />
      </view>
      <view class="map-footer" bindtap="openMap">
        <text class="map-nav-btn">导航到店 ›</text>
      </view>
    </view>

    <!-- 版本信息 -->
    <view class="version-row">
      <text class="version-label">应用版本</text>
      <text class="version-value">v{{appVersion}}</text>
    </view>

    <view class="footer-gap"></view>
  </scroll-view>
</view>
