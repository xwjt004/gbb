<view class="page">
  <!-- 顶部渐变区 -->
  <view class="header-area">
    <view class="header-bg"></view>
    <view class="header-content">
      <text class="page-title">我的优惠券</text>
      <text class="page-subtitle">共 {{total}} 张优惠券</text>
    </view>

    <!-- Tab 切换 -->
    <view class="tabs">
      <view
        wx:for="{{tabs}}"
        wx:key="value"
        class="tab {{activeTab === item.value ? 'tab-active' : ''}}"
        data-tab="{{item.value}}"
        bindtap="onTabChange"
      >
        <text class="tab-label">{{item.label}}</text>
        <text wx:if="{{item.count > 0}}" class="tab-count">{{item.count}}</text>
        <view wx:if="{{activeTab === item.value}}" class="tab-line"></view>
      </view>
    </view>
  </view>

  <!-- 列表 -->
  <scroll-view
    scroll-y
    class="list-scroll"
    enhanced
    show-scrollbar="{{false}}"
    refresher-enabled
    refresher-triggered="{{loading}}"
    bindrefresherrefresh="onPullDownRefresh"
    bindscrolltolower="onReachBottom"
  >

    <!-- 优惠券卡片 -->
    <view
      wx:for="{{coupons}}"
      wx:key="id"
      class="coupon-card {{item.status !== 'AVAILABLE' ? 'inactive' : ''}}"
      data-id="{{item.id}}"
      bindtap="viewDetail"
    >
      <!-- 左侧金额 -->
      <view class="coupon-left">
        <view class="coupon-amount">
          <text class="amount-symbol" wx:if="{{item.discountType === 'FIXED'}}">¥</text>
          <text class="amount-value">{{item.discountType === 'FIXED' ? item.discountValue : item.discountValue + '折'}}</text>
        </view>
        <text class="coupon-condition">
          <text wx:if="{{item.minAmount}}">满{{item.minAmount}}可用</text>
          <text wx:else>无门槛</text>
        </text>
      </view>

      <!-- 虚线分隔 -->
      <view class="coupon-divider">
        <view class="dot dot-top"></view>
        <view class="dash"></view>
        <view class="dot dot-bottom"></view>
      </view>

      <!-- 右侧信息 -->
      <view class="coupon-right">
        <view class="coupon-info">
          <text class="coupon-name">{{item.name}}</text>
          <text class="coupon-desc">{{item.description}}</text>
        </view>
        <view class="coupon-bottom">
          <text class="coupon-time">有效期至 {{item.endTime || item.expiredAt}}</text>
          <view class="coupon-status" wx:if="{{item.status !== 'AVAILABLE'}}">
            <text wx:if="{{item.status === 'USED'}}" class="status-used">已使用</text>
            <text wx:elif="{{item.status === 'EXPIRED'}}" class="status-expired">已过期</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && coupons.length === 0}}" class="empty-state">
      <text class="empty-icon">🎫</text>
      <text class="empty-text">{{emptyText}}</text>
      <view class="empty-btn" bindtap="goToList">去领券</view>
    </view>

    <!-- 加载/底部提示 -->
    <view wx:if="{{loading && coupons.length > 0}}" class="list-footer">
      <text class="footer-text">加载中...</text>
    </view>
    <view wx:elif="{{!loading && coupons.length > 0 && !hasMore}}" class="list-footer">
      <text class="footer-text">— 没有更多了 —</text>
    </view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="bar-item" bindtap="goToList">
      <text class="bar-icon">🎁</text>
      <text class="bar-label">领券中心</text>
    </view>
    <view class="bar-divider"></view>
    <view class="bar-item" bindtap="goToProducts">
      <text class="bar-icon">🛍️</text>
      <text class="bar-label">去购物</text>
    </view>
  </view>
</view>
