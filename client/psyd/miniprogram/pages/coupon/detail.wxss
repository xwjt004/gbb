/* 优惠券详情页 - 粉色主题 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F7 0%, #FFE4E8 30%, #FFF0F5 60%, #F8F6F7 100%);
  padding: 40rpx 30rpx 140rpx;
}

/* 优惠券卡片 */
.coupon-card {
  position: relative;
  background: #fff;
  border-radius: 28rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 40rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.06), 0 0 0 1rpx rgba(255,105,180,0.08);
}

.coupon-card.expired,
.coupon-card.claimed {
  opacity: 0.8;
}

/* 装饰背景 */
.card-bg {
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(135deg, #FF9A9E, #FBC2EB);
  border-radius: 50%;
  opacity: 0.08;
}

/* 折扣展示 */
.discount-section {
  text-align: center;
  margin-bottom: 40rpx;
  position: relative;
  z-index: 1;
}

.discount-main {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 20rpx;
}

.discount-symbol {
  font-size: 60rpx;
  font-weight: bold;
  color: #FF6B9D;
  margin-right: 10rpx;
}

.discount-number {
  font-size: 120rpx;
  font-weight: bold;
  color: #FF6B9D;
  line-height: 1;
}

.discount-unit {
  font-size: 60rpx;
  font-weight: bold;
  color: #FF6B9D;
  margin-left: 10rpx;
}

.discount-condition {
  font-size: 28rpx;
  color: #A88C96;
  background: #FFF0F6;
  padding: 12rpx 36rpx;
  border-radius: 40rpx;
  display: inline-block;
}

/* 优惠券信息 */
.coupon-info {
  text-align: center;
  padding: 30rpx 0;
  border-top: 2rpx dashed #F0EDEF;
  border-bottom: 2rpx dashed #F0EDEF;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.coupon-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #3D2C33;
  display: block;
  margin-bottom: 20rpx;
}

.coupon-code {
  font-size: 26rpx;
  color: #FF9A9E;
  font-family: 'Courier New', monospace;
  display: block;
  margin-bottom: 20rpx;
}

.copy-btn {
  background: linear-gradient(135deg, #FF9A9E, #FBC2EB);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 12rpx 36rpx;
  font-size: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255,154,158,0.25);
}

.copy-btn::after {
  border: none;
}

/* 状态标签 */
.status-badge {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  background: linear-gradient(135deg, #A8D8B0, #7EC890);
  color: #fff;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 600;
  z-index: 2;
}

.status-badge.expired {
  background: linear-gradient(135deg, #D5A0A0, #C08080);
}

.status-badge.used {
  background: linear-gradient(135deg, #C8BCC2, #A8A0A4);
}

/* 使用说明 */
.detail-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #4A2C3A;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #FF9A9E;
}

.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 36rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  border: 1rpx solid rgba(255,105,180,0.08);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #FFF0F6;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #A88C96;
  flex-shrink: 0;
  width: 160rpx;
}

.info-value {
  font-size: 26rpx;
  color: #3D2C33;
  text-align: right;
  flex: 1;
  word-break: break-all;
}

/* 温馨提示 */
.tips-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  border: 1rpx solid rgba(255,105,180,0.08);
}

.tip-item {
  display: block;
  font-size: 24rpx;
  color: #A88C96;
  line-height: 2;
  margin-bottom: 8rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

/* 底部操作按钮 */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.04);
  z-index: 100;
}

.action-btn {
  width: 100%;
  border-radius: 48rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  text-align: center;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #FF9A9E, #FBC2EB);
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(255,154,158,0.3);
}

.action-btn.disabled {
  background: #F0EDEF;
  color: #C8BCC2;
  box-shadow: none;
}

/* 加载状态 */
.loading-container {
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(180deg, #FFF5F7, #FFE4E8);
}

.loading-text {
  font-size: 28rpx;
  color: #B8ADB2;
}
