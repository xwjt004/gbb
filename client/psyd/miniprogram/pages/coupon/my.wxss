/* ============================================
   我的优惠券 — 柔和可爱风
   ============================================ */

.page {
  width: 100%;
  min-height: 100vh;
  background: #F8F6F7;
}

/* ===== 顶部渐变区 ===== */
.header-area {
  position: relative;
  padding-bottom: 24rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #FF9A9E 0%, #FAD0C4 50%, #FBC2EB 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.header-content {
  position: relative;
  padding: 32rpx 32rpx 0;
  z-index: 1;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #4A2C3A;
  display: block;
}

.page-subtitle {
  font-size: 24rpx;
  color: rgba(74,44,58,0.6);
  display: block;
  margin-top: 8rpx;
}

/* ===== Tab切换 ===== */
.tabs {
  position: relative;
  display: flex;
  margin: 24rpx 24rpx 0;
  background: rgba(255,255,255,0.85);
  border-radius: 20rpx;
  padding: 6rpx;
  backdrop-filter: blur(10px);
  z-index: 1;
}

.tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  border-radius: 16rpx;
  position: relative;
  cursor: pointer;
  transition: all 0.3s;
}

.tab-active {
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255,154,158,0.15);
}

.tab-label {
  font-size: 26rpx;
  color: #A88C96;
  font-weight: 500;
}

.tab-active .tab-label {
  color: #4A2C3A;
  font-weight: 600;
}

.tab-count {
  font-size: 22rpx;
  color: #fff;
  background: #FF9A9E;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  text-align: center;
  border-radius: 16rpx;
  font-weight: 600;
}

.tab-line {
  display: none;
}

/* ===== 列表 ===== */
.list-scroll {
  height: calc(100vh - 300rpx);
  padding: 16rpx 24rpx 180rpx;
}

/* ===== 优惠券卡片 ===== */
.coupon-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  cursor: pointer;
  transition: all 0.2s;
}

.coupon-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.coupon-card.inactive {
  opacity: 0.55;
}

/* 左侧金额区 */
.coupon-left {
  width: 220rpx;
  background: linear-gradient(135deg, #FFF0F6, #FFE4EC);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 16rpx;
  flex-shrink: 0;
}

.inactive .coupon-left {
  background: #F0EDEF;
}

.coupon-amount {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.amount-symbol {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF6B9D;
  margin-right: 4rpx;
}

.amount-value {
  font-size: 56rpx;
  font-weight: 800;
  color: #FF6B9D;
  line-height: 1;
  letter-spacing: -2rpx;
}

.inactive .amount-symbol,
.inactive .amount-value {
  color: #A8A0A4;
}

.coupon-condition {
  font-size: 22rpx;
  color: #A88C96;
  background: rgba(255,255,255,0.6);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* ===== 虚线分隔 ===== */
.coupon-divider {
  position: relative;
  width: 2rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: #F8F6F7;
  border-radius: 50%;
  position: absolute;
  left: -7rpx;
  z-index: 1;
}

.dot-top {
  top: -8rpx;
}

.dot-bottom {
  bottom: -8rpx;
}

.dash {
  flex: 1;
  width: 2rpx;
  background-image: linear-gradient(to bottom, #EDE8EA 50%, transparent 50%);
  background-size: 2rpx 8rpx;
}

/* ===== 右侧信息区 ===== */
.coupon-right {
  flex: 1;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.coupon-info {
  margin-bottom: 16rpx;
}

.coupon-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2C33;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.coupon-desc {
  display: block;
  font-size: 24rpx;
  color: #A88C96;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.coupon-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.coupon-time {
  font-size: 22rpx;
  color: #C8BCC2;
}

/* 状态标签 */
.coupon-status {
  flex-shrink: 0;
}

.status-used {
  font-size: 22rpx;
  color: #A8D8B0;
  padding: 4rpx 16rpx;
  background: #F0FAF2;
  border-radius: 16rpx;
}

.status-expired {
  font-size: 22rpx;
  color: #D5A0A0;
  padding: 4rpx 16rpx;
  background: #FFF0F0;
  border-radius: 16rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 40rpx 80rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #B8ADB2;
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 20rpx 64rpx;
  background: linear-gradient(135deg, #FF9A9E, #FBC2EB);
  border-radius: 40rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(255,154,158,0.3);
}

.empty-btn:active {
  opacity: 0.85;
  transform: scale(0.96);
}

/* ===== 底部提示 ===== */
.list-footer {
  text-align: center;
  padding: 24rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #C8BCC2;
}

/* ===== 底部操作栏 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background: #fff;
  border-top: 1rpx solid #F0EDEF;
  padding: 16rpx 0 calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.03);
  z-index: 100;
}

.bar-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 16rpx 0;
  cursor: pointer;
  transition: all 0.2s;
}

.bar-item:active {
  opacity: 0.6;
}

.bar-icon {
  font-size: 36rpx;
}

.bar-label {
  font-size: 26rpx;
  color: #5C4A52;
  font-weight: 500;
}

.bar-divider {
  width: 1rpx;
  height: 40rpx;
  background: #F0EDEF;
}
