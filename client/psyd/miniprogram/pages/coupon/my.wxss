/* 银行风格 - 我的优惠券页面 */

.container {
  min-height: 100vh;
  background: #F5F7FA;
  display: flex;
  flex-direction: column;
}

/* ========== 顶部标题栏 ========== */
.header {
  background: linear-gradient(135deg, #1E3A8A 0%, #3B82F6 100%);
  padding: 40rpx 32rpx 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(30, 58, 138, 0.15);
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}

/* ========== Tab切换 ========== */
.tabs-wrapper {
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tabs {
  display: flex;
  padding: 0 32rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 32rpx 0 28rpx;
  position: relative;
}

.tab-text {
  font-size: 30rpx;
  color: #64748B;
  font-weight: 400;
  transition: all 0.3s;
}

.tab-item.active .tab-text {
  color: #1E3A8A;
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #1E3A8A 0%, #3B82F6 100%);
  border-radius: 2rpx;
}

/* ========== 优惠券列表 ========== */
.coupon-list {
  flex: 1;
  padding: 24rpx 32rpx 200rpx;
}

.coupon-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  position: relative;
  transition: all 0.3s;
}

.coupon-item.used,
.coupon-item.expired {
  opacity: 0.5;
}

/* 优惠券主体 */
.coupon-main {
  display: flex;
  padding: 32rpx 24rpx;
}

/* 左侧金额区 */
.amount-section {
  width: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
}

.amount-wrapper {
  display: flex;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.currency {
  font-size: 32rpx;
  font-weight: 600;
  color: #DC2626;
  margin-right: 4rpx;
}

.amount {
  font-size: 64rpx;
  font-weight: 700;
  color: #DC2626;
  line-height: 1;
  font-family: 'DIN Alternate', 'Arial', sans-serif;
}

.threshold {
  font-size: 24rpx;
  color: #64748B;
  padding: 6rpx 16rpx;
  background: #F1F5F9;
  border-radius: 24rpx;
}

/* 分隔线 */
.divider {
  position: relative;
  width: 2rpx;
  background: #E2E8F0;
  margin: 0 16rpx;
}

.circle {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  background: #F5F7FA;
  border-radius: 50%;
  left: -7rpx;
}

.circle.top {
  top: -8rpx;
}

.circle.bottom {
  bottom: -8rpx;
}

.dash-line {
  position: absolute;
  top: 8rpx;
  bottom: 8rpx;
  left: 0;
  width: 2rpx;
  background-image: linear-gradient(to bottom, #E2E8F0 50%, transparent 50%);
  background-size: 2rpx 8rpx;
}

/* 右侧信息区 */
.info-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.coupon-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.coupon-subtitle {
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.validity {
  display: flex;
  align-items: center;
}

.validity-text {
  font-size: 24rpx;
  color: #94A3B8;
}

/* 底部操作栏 */
.coupon-footer {
  padding: 0 24rpx 28rpx;
  display: flex;
  justify-content: flex-end;
}

.use-button {
  background: linear-gradient(135deg, #1E3A8A 0%, #3B82F6 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 24rpx;
  padding: 12rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

/* 状态标签 */
.status-tag {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  padding: 8rpx 20rpx;
  background: rgba(15, 23, 42, 0.6);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #94A3B8;
  margin-bottom: 40rpx;
}

.empty-button {
  background: linear-gradient(135deg, #1E3A8A 0%, #3B82F6 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 80rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
}

/* ========== 加载提示 ========== */
.loading-tip {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #94A3B8;
}

.list-footer {
  text-align: center;
  padding: 32rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #CBD5E1;
}

/* ========== 底部导航栏 ========== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #FFFFFF;
  border-top: 1rpx solid #E2E8F0;
  padding: 16rpx 0 env(safe-area-inset-bottom);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
  z-index: 100;
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  transition: all 0.3s;
}

.nav-item:active {
  opacity: 0.7;
}

.nav-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
  line-height: 1;
}

.nav-label {
  font-size: 24rpx;
  color: #64748B;
  font-weight: 500;
}


/* 头部 */
.header {
  padding: 40rpx 30rpx 20rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

/* Tab切换 */
.tabs {
  display: flex;
  background: #fff;
  margin: 0 30rpx 30rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: #667eea;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  width: 50%;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 3rpx;
}

.tab-label {
  margin-right: 5rpx;
}

.tab-count {
  font-size: 24rpx;
  color: #ff6b6b;
}

/* 优惠券列表 */
.coupon-list {
  padding: 0 30rpx;
}

.coupon-card {
  position: relative;
  display: flex;
  background: #fff;
  margin-bottom: 30rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.coupon-card.expired,
.coupon-card.used {
  opacity: 0.6;
}

/* 左侧折扣区 */
.coupon-left {
  width: 220rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}

.coupon-card.expired .coupon-left,
.coupon-card.used .coupon-left {
  background: linear-gradient(135deg, #bbb 0%, #999 100%);
}

/* 折扣数值 */
.discount-value {
  display: flex;
  align-items: baseline;
  margin-bottom: 15rpx;
}

.discount-number {
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1;
}

.discount-unit {
  font-size: 36rpx;
  color: #fff;
  margin-left: 5rpx;
}

.condition {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

/* 右侧信息区 */
.coupon-right {
  flex: 1;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.coupon-info {
  flex: 1;
}

.coupon-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.coupon-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 15rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.coupon-time {
  margin-bottom: 10rpx;
}

.time-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 10rpx;
}

.time-text {
  font-size: 24rpx;
  color: #667eea;
}

.coupon-meta {
  display: flex;
  flex-direction: column;
  gap: 5rpx;
  margin-bottom: 15rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #999;
}

/* 操作按钮 */
.coupon-action {
  display: flex;
  justify-content: flex-end;
}

.use-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 15rpx 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.status-badge {
  padding: 10rpx 25rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  text-align: center;
}

.used-badge {
  background: #e8f5e9;
  color: #4caf50;
}

.expired-badge {
  background: #ffe0e0;
  color: #ff6b6b;
}

/* 状态遮罩 */
.status-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  justify-content: center;
  align-items: center;
  pointer-events: none;
}

.status-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #999;
  transform: rotate(-15deg);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-bottom: 40rpx;
}

.go-get-btn {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  font-size: 30rpx;
  font-weight: bold;
}

/* 加载状态 */
.loading-more,
.no-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 底部导航 */
.footer-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.nav-btn {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 25rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  margin-right: 15rpx;
  font-size: 36rpx;
}

.nav-label {
  font-size: 30rpx;
}
