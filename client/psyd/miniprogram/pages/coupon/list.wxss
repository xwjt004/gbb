/* 优惠券列表页 - 粉色主题 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F7 0%, #FFE4E8 30%, #FFF0F5 60%, #F8F6F7 100%);
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  padding: 40rpx 30rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title-section {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #4A2C3A;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #B8ADB2;
}

.my-coupon-btn {
  background: linear-gradient(135deg, #FF9A9E, #FBC2EB);
  color: #fff;
  border: none;
  font-size: 26rpx;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(255,154,158,0.3);
}

.my-coupon-btn::after {
  border: none;
}

/* 筛选栏 */
.filter-bar {
  background: #fff;
  margin: 0 30rpx 30rpx;
  padding: 24rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(255,105,180,0.08);
}

.filter-group {
  display: flex;
  justify-content: space-around;
}

.filter-item {
  display: flex;
  align-items: center;
}

.filter-label {
  margin-left: 10rpx;
  font-size: 26rpx;
  color: #5C4A52;
}

/* 优惠券列表 */
.coupon-list {
  padding: 0 30rpx;
}

.coupon-card {
  position: relative;
  display: flex;
  background: #fff;
  margin-bottom: 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(255,105,180,0.08);
  transition: all 0.2s;
}

.coupon-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* 左侧折扣区 */
.coupon-left {
  width: 220rpx;
  background: linear-gradient(135deg, #FFF0F6, #FFE4EC);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
  position: relative;
}

.coupon-left.expired,
.coupon-left.claimed {
  background: #F0EDEF;
}

/* 折扣数值 */
.discount-value {
  display: flex;
  align-items: baseline;
  margin-bottom: 15rpx;
}

.discount-number {
  font-size: 72rpx;
  font-weight: bold;
  color: #FF6B9D;
  line-height: 1;
}

.discount-unit {
  font-size: 36rpx;
  color: #FF6B9D;
  margin-left: 5rpx;
}

.coupon-left.expired .discount-number,
.coupon-left.expired .discount-unit,
.coupon-left.claimed .discount-number,
.coupon-left.claimed .discount-unit {
  color: #A8A0A4;
}

.condition {
  font-size: 22rpx;
  color: #A88C96;
  background: rgba(255,255,255,0.6);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* 右侧信息区 */
.coupon-right {
  flex: 1;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.coupon-info {
  flex: 1;
}

.coupon-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D2C33;
  display: block;
  margin-bottom: 8rpx;
}

.coupon-desc {
  font-size: 24rpx;
  color: #A88C96;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.coupon-time {
  margin-bottom: 6rpx;
}

.time-text {
  font-size: 22rpx;
  color: #C8BCC2;
}

.coupon-stock {
  margin-bottom: 12rpx;
}

.stock-text {
  font-size: 22rpx;
  color: #C8BCC2;
}

/* 操作按钮 */
.coupon-action {
  display: flex;
  justify-content: flex-end;
}

.claim-btn {
  background: linear-gradient(135deg, #FF9A9E, #FBC2EB);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 12rpx 36rpx;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(255,154,158,0.25);
}

.claim-btn::after {
  border: none;
}

.status-badge {
  padding: 10rpx 25rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  text-align: center;
}

.claimed-badge {
  background: #F0FAF2;
  color: #A8D8B0;
}

.expired-badge {
  background: #FFF0F0;
  color: #D5A0A0;
}

.unavailable-badge {
  background: #F0EDEF;
  color: #A8A0A4;
}

/* 过期遮罩 */
.expired-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  justify-content: center;
  align-items: center;
  pointer-events: none;
}

.expired-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #D5A0A0;
  transform: rotate(-15deg);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  display: block;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #B8ADB2;
}

/* 加载状态 */
.loading-more,
.no-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #C8BCC2;
}
