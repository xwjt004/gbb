.favorite-page {
  width: 100%;
  min-height: 100vh;
  background: #f5f7fa;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.go-btn {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.list-scroll {
  height: 100vh;
}

.favorite-list {
  padding: 16rpx;
}

.favorite-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  cursor: pointer;
}

.favorite-item:active {
  transform: scale(0.98);
}

.item-image-wrapper {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  flex-shrink: 0;
}

.item-image {
  width: 100%;
  height: 100%;
}

.item-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.overlay-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.item-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-price {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 12rpx;
}

.price-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff6b9d;
}

.price-deposit {
  font-size: 24rpx;
  color: #999;
}

.item-type {
  font-size: 22rpx;
  color: #999;
  align-self: flex-start;
  padding: 4rpx 12rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
}

.load-more {
  text-align: center;
  padding: 24rpx;
}

.load-more-text {
  font-size: 24rpx;
  color: #999;
}

.bottom-placeholder {
  height: 32rpx;
}
