.page {
  width: 100%;
  min-height: 100vh;
  background: #F8F6F7;
}

.scroll-view {
  width: 100%;
  height: 100vh;
}

/* ===== 分组 ===== */
.group {
  margin: 24rpx 24rpx 0;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.group-title {
  font-size: 24rpx;
  color: #B8ADB2;
  padding: 28rpx 28rpx 16rpx;
}

/* ===== 行 ===== */
.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid #F5F0F2;
  transition: background 0.2s;
}

.row:last-child {
  border-bottom: none;
}

.row:active {
  background: #FAF8F9;
}

.row-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.row-icon {
  font-size: 32rpx;
  width: 44rpx;
  text-align: center;
}

.row-label {
  font-size: 28rpx;
  color: #3D2C33;
}

.logout-label {
  color: #FF6B6B;
  font-weight: 500;
}

.row-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.row-value {
  font-size: 26rpx;
  color: #B8ADB2;
}

.row-arrow {
  font-size: 32rpx;
  color: #D5CDD1;
}

.footer-gap {
  height: 48rpx;
}
