<view class="page">
  <scroll-view scroll-y class="scroll-view" enhanced show-scrollbar="{{false}}">

    <!-- 缓存清理 -->
    <view class="group">
      <view class="group-title">数据管理</view>
      <view class="row" bindtap="clearCache">
        <view class="row-left">
          <text class="row-icon">🗑️</text>
          <text class="row-label">清除缓存</text>
        </view>
        <view class="row-right">
          <text class="row-value">{{cacheSize}}</text>
          <text class="row-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 账号操作 -->
    <view class="group">
      <view class="group-title">账号</view>
      <view class="row" bindtap="logout">
        <view class="row-left">
          <text class="row-icon">🚪</text>
          <text class="row-label logout-label">退出登录</text>
        </view>
        <view class="row-right">
          <text class="row-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 关于 -->
    <view class="group">
      <view class="group-title">关于</view>
      <view class="row" bindtap="showAgreement">
        <view class="row-left">
          <text class="row-icon">📄</text>
          <text class="row-label">用户协议</text>
        </view>
        <view class="row-right">
          <text class="row-arrow">›</text>
        </view>
      </view>
      <view class="row" bindtap="showPrivacy">
        <view class="row-left">
          <text class="row-icon">🔒</text>
          <text class="row-label">隐私政策</text>
        </view>
        <view class="row-right">
          <text class="row-arrow">›</text>
        </view>
      </view>
      <view class="row">
        <view class="row-left">
          <text class="row-icon">📱</text>
          <text class="row-label">应用版本</text>
        </view>
        <view class="row-right">
          <text class="row-value">{{appVersion}}</text>
        </view>
      </view>
      <view class="row">
        <view class="row-left">
          <text class="row-icon">🌐</text>
          <text class="row-label">运行环境</text>
        </view>
        <view class="row-right">
          <text class="row-value">{{env}}</text>
        </view>
      </view>
    </view>

    <view class="footer-gap"></view>
  </scroll-view>
</view>
