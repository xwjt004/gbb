/* 订单详情页样式 */
.detail-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

/* 滚动区域 */
.detail-scroll {
  flex: 1;
  height: 100%;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #ff5722;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #999;
}

/* 状态头部 */
.status-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  color: #fff;
  position: relative;
}

.status-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  background: #f5f5f5;
  border-radius: 40rpx 40rpx 0 0;
}

.status-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.payment-status {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 时间线区域 */
.timeline-section {
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
}

.timeline-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
}

.timeline-list {
  position: relative;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  position: relative;
  padding-bottom: 40rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  z-index: 2;
}

.timeline-item.active .timeline-dot {
  background: linear-gradient(135deg, #ff5722, #ff9800);
}

.timeline-icon {
  font-size: 28rpx;
}

.timeline-content {
  flex: 1;
  padding-top: 12rpx;
}

.timeline-label {
  font-size: 28rpx;
  color: #999;
}

.timeline-item.active .timeline-label {
  color: #333;
  font-weight: 600;
}

.timeline-line {
  position: absolute;
  left: 28rpx;
  top: 56rpx;
  bottom: 0;
  width: 2rpx;
  background: #e0e0e0;
  z-index: 1;
}

.timeline-item.active .timeline-line {
  background: linear-gradient(180deg, #ff5722, #e0e0e0);
}

/* 通用区块样式 */
.section {
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

/* 收货地址 */
.address-card {
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.address-user {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-right: 24rpx;
}

.user-phone {
  font-size: 28rpx;
  color: #ff5722;
  text-decoration: underline;
}

.address-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 商品列表 */
.goods-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.goods-item {
  display: flex;
  align-items: center;
}

.goods-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  margin-right: 24rpx;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goods-spec {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-price {
  font-size: 30rpx;
  color: #ff5722;
  font-weight: 600;
}

.goods-quantity {
  font-size: 26rpx;
  color: #999;
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
  width: 180rpx;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
  word-break: break-all;
}

.info-value.remark {
  text-align: left;
  margin-left: 24rpx;
  line-height: 1.6;
}

.info-value-with-action {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}

.copy-btn {
  padding: 8rpx 24rpx;
  background: #ff5722;
  color: #fff;
  border-radius: 24rpx;
  font-size: 24rpx;
  border: none;
}

/* 金额明细 */
.amount-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.amount-label {
  font-size: 28rpx;
  color: #666;
}

.coupon-name {
  font-size: 24rpx;
  color: #ff5722;
}

.amount-value {
  font-size: 28rpx;
  color: #333;
}

.amount-row.discount .amount-value {
  color: #ff5722;
}

.amount-row.total {
  margin-top: 16rpx;
  padding-top: 24rpx;
  border-top: 1rpx dashed #e0e0e0;
}

.amount-row.total .amount-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.amount-row.total .amount-value {
  font-size: 36rpx;
  font-weight: 600;
}

.amount-value.primary {
  color: #ff5722;
}

/* 底部占位 */
.bottom-placeholder {
  height: 120rpx;
}

/* 底部操作栏 */
.footer-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.footer-left {
  flex-shrink: 0;
}

.contact-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 24rpx;
  background: #fff;
  border: 1rpx solid #e0e0e0;
  border-radius: 48rpx;
  font-size: 24rpx;
  color: #666;
}

.btn-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.footer-right {
  display: flex;
  gap: 16rpx;
  flex: 1;
  justify-content: flex-end;
}

.action-btn {
  padding: 20rpx 48rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  border: none;
}

.cancel-btn {
  background: #fff;
  color: #ff5722;
  border: 1rpx solid #ff5722;
}

.primary-btn {
  background: linear-gradient(135deg, #ff5722, #ff9800);
  color: #fff;
}

.delete-btn {
  background: #fff;
  color: #999;
  border: 1rpx solid #ddd;
}
