/* ============================================
   流光金属 · 时间段选择页
   Luminous Metal — Time Slot Selection
   ============================================ */

page {
  background: #fff5f7;
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  padding-bottom: 200rpx;
}

/* ==================== 进度指示器 ==================== */
.stepper {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 48rpx 16rpx;
  gap: 0;
}

.step-item {
  display: flex;
  align-items: center;
  flex: 1;
}

.step-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.step-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  border: 2rpx solid rgba(42, 39, 36, 0.2);
  background: #ffffff;
  color: rgba(26, 24, 22, 0.86);
}

.step-circle.active {
  background: linear-gradient(135deg, #ff69b4, #ff85c8);
  border-color: transparent;
  color: #ffffff;
  box-shadow: 0 4rpx 24rpx rgba(255, 105, 180, 0.45);
  transform: scale(1.08);
}

.step-circle.done {
  background: rgba(76, 175, 132, 0.15);
  border-color: #4caf84;
  color: #4caf84;
  font-size: 28rpx;
}

.step-label {
  font-size: 20rpx;
  color: rgba(26, 24, 22, 0.93);
  font-weight: 500;
  letter-spacing: 0.5rpx;
  white-space: nowrap;
}

.step-label.active {
  color: #ff69b4;
}

.step-label.done {
  color: rgba(76, 175, 132, 0.7);
}

.step-line {
  flex: 1;
  height: 2rpx;
  background: rgba(0, 0, 0, 0.06);
  margin: 0 16rpx;
  margin-bottom: 48rpx;
  position: relative;
  overflow: hidden;
}

.step-line-fill {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  background: linear-gradient(90deg, #ff69b4, #4caf84);
  transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* ==================== 套系信息卡片 ==================== */
.package-card {
  margin: 12rpx 28rpx 20rpx;
  padding: 32rpx 36rpx;
  background: linear-gradient(135deg, rgba(255, 105, 180, 0.08), rgba(255, 255, 255, 0.95));
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 105, 180, 0.2);
  border-radius: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06), 0 0 0 1rpx rgba(255, 105, 180, 0.05);
  position: relative;
  overflow: hidden;
}

.package-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4rpx;
  height: 100%;
  background: linear-gradient(180deg, #ff69b4, #ff9ec4);
  border-radius: 0 2rpx 2rpx 0;
  box-shadow: 0 0 16rpx rgba(255, 105, 180, 0.25);
}

.package-card::after {
  content: '';
  position: absolute;
  top: -40%;
  right: -20%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 105, 180, 0.08) 0%, transparent 70%);
  pointer-events: none;
}

.package-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.package-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.package-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1816;
  letter-spacing: 1rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  margin-right: 16rpx;
}

.package-price {
  font-size: 34rpx;
  font-weight: 800;
  color: #ff69b4;
  letter-spacing: 0.5rpx;
  flex-shrink: 0;
}

.package-hint {
  font-size: 26rpx;
  color: rgba(26, 24, 22, 0.72);
  font-weight: 400;
  letter-spacing: 1rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255, 105, 180, 0.12);
}

/* ==================== 日期显示 ==================== */
.date-banner {
  margin: 0 28rpx 24rpx;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, #ffffff, rgba(255, 105, 180, 0.04));
  border: 1rpx solid rgba(255, 105, 180, 0.15);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04), 0 0 0 1rpx rgba(255, 105, 180, 0.04);
  display: flex;
  align-items: center;
  gap: 20rpx;
  position: relative;
  overflow: hidden;
}

.date-banner::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4rpx;
  height: 100%;
  background: linear-gradient(180deg, #ff69b4, #ff9ec4);
  border-radius: 0 2rpx 2rpx 0;
  opacity: 0.6;
}

.date-banner-icon {
  font-size: 40rpx;
  opacity: 0.7;
}

.date-banner-text {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.date-banner-day {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1816;
  letter-spacing: 1rpx;
}

.date-banner-week {
  font-size: 26rpx;
  color: rgba(26, 24, 22, 0.86);
  font-weight: 500;
}

/* ==================== 时间段列表 ==================== */
.time-slots {
  margin: 0 28rpx;
}

.time-period {
  margin-bottom: 28rpx;
}

.period-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
  gap: 10rpx;
}

.period-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #ff69b4;
  box-shadow: 0 0 12rpx rgba(255, 105, 180, 0.5);
}

.period-title {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(26, 24, 22, 0.93);
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.period-line {
  flex: 1;
  height: 1rpx;
  background: rgba(0, 0, 0,0.05);
}

.slot-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.slot-item {
  background: #ffffff;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(0, 0, 0,0.08);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  min-height: 80rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.slot-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4rpx;
  height: 100%;
  background: transparent;
  transition: all 0.3s ease;
  border-radius: 0 2rpx 2rpx 0;
}

.slot-item.selected {
  border-color: rgba(255, 105, 180, 0.4);
  background: rgba(255, 105, 180, 0.08);
  transform: translateX(4rpx);
}

.slot-item.selected::before {
  background: linear-gradient(180deg, #ff69b4, #ff85c8);
  box-shadow: 0 0 16rpx rgba(255, 105, 180, 0.3);
}

.slot-item.disabled {
  opacity: 0.35;
  background: rgba(0, 0, 0,0.02);
}

.slot-time {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.slot-time-main {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1816;
  letter-spacing: 0.5rpx;
}

.slot-item.selected .slot-time-main {
  color: #ff69b4;
}

.slot-status {
  display: flex;
  align-items: center;
}

.status-tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.status-tag.available {
  background: rgba(76, 175, 132, 0.12);
  color: #4caf84;
  border: 1rpx solid rgba(76, 175, 132, 0.15);
}

.status-tag.expired {
  background: rgba(255, 107, 107, 0.08);
  color: rgba(255, 107, 107, 0.5);
  border: 1rpx solid rgba(255, 107, 107, 0.1);
}

.status-tag.full {
  background: rgba(0, 0, 0, 0.03);
  color: rgba(26, 24, 22, 0.78);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

/* ==================== 加载状态 ==================== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.loading-ring {
  width: 72rpx;
  height: 72rpx;
  border: 4rpx solid rgba(0, 0, 0,0.06);
  border-top-color: #ff69b4;
  border-right-color: rgba(255, 105, 180, 0.4);
  border-radius: 50%;
  animation: spin 0.8s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 28rpx;
  font-size: 26rpx;
  color: rgba(26, 24, 22, 0.9);
  letter-spacing: 1rpx;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0,0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  font-size: 56rpx;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(26, 24, 22, 0.93);
  margin-bottom: 8rpx;
  font-weight: 500;
}

.empty-hint {
  font-size: 24rpx;
  color: rgba(26, 24, 22, 0.78);
}

/* ==================== 底部操作栏 ==================== */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 28rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 100;
  background: rgba(255, 245, 247, 0.95);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border-top: 1rpx solid rgba(0, 0, 0,0.06);
}

.footer-inner {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.footer-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.info-label {
  font-size: 22rpx;
  color: rgba(26, 24, 22, 0.86);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.info-value {
  font-size: 26rpx;
  color: #ff69b4;
  font-weight: 600;
}

.info-placeholder {
  font-size: 26rpx;
  color: rgba(26, 24, 22, 0.72);
}

.confirm-btn {
  flex: 1;
  height: 96rpx;
  background: #ffffff;
  color: rgba(26, 24, 22, 0.72);
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 48rpx;
  border: none;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.confirm-btn.active {
  background: linear-gradient(135deg, #ff69b4, #ff85c8);
  color: #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(255, 105, 180, 0.35);
}

.confirm-btn.active:active {
  transform: translateY(1rpx) scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 105, 180, 0.3);
}

.confirm-btn[disabled] {
  opacity: 1;
}
