/* pages/booking/time/time.wxss */

page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.container {
  padding-bottom: 160rpx;
}

/* ==================== 顶部导航栏 ==================== */
.navbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.08);
}

.navbar-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #333;
}

.navbar-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.navbar-placeholder {
  width: 60rpx;
}

/* ==================== 套系信息卡片 ==================== */
.package-card {
  margin: 16rpx 24rpx;
  padding: 20rpx;
  background: white;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.package-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.package-info {
  flex: 1;
  min-width: 0;
}

.package-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.package-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.package-price {
  font-size: 30rpx;
  font-weight: 600;
  color: #ff6b6b;
}

.package-duration {
  font-size: 24rpx;
  color: #999;
}

/* ==================== 日期信息 ==================== */
.date-info {
  margin: 0 24rpx 16rpx;
  padding: 24rpx;
  background: white;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.date-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.date-text {
  flex: 1;
}

.date-display {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.date-week {
  font-size: 28rpx;
  color: #666;
}

/* ==================== 时间段列表 ==================== */
.time-slots {
  padding: 0 24rpx;
}

.time-period {
  margin-bottom: 24rpx;
}

.period-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  padding: 0 8rpx;
}

.period-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.period-title {
  font-size: 30rpx;
  font-weight: 600;
  color: white;
}

.slot-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.slot-item {
  background: white;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  border: 3rpx solid transparent;
  min-height: 80rpx;
}

.slot-item.selected {
  border-color: #07c160;
  background: linear-gradient(135deg, #e8f5e9 0%, #f1f8f4 100%);
  box-shadow: 0 4rpx 20rpx rgba(7, 193, 96, 0.2);
}

.slot-item.disabled {
  opacity: 0.5;
  background: #f5f5f5;
}

.slot-time {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.slot-status {
  display: flex;
  align-items: center;
}

.status-tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-tag.expired {
  background: #ffe0e0;
  color: #ff4d4f;
}

.status-tag.full {
  background: #fff7e6;
  color: #fa8c16;
}

.slot-count {
  font-size: 26rpx;
  color: #07c160;
  font-weight: 500;
}

/* ==================== 加载状态 ==================== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: white;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: white;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ==================== 底部确认按钮 ==================== */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.footer-info {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 8rpx;
}

.info-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #07c160;
}

.info-placeholder {
  font-size: 28rpx;
  color: #999;
}

.confirm-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #cccccc 0%, #999999 100%);
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.confirm-btn.active {
  background: linear-gradient(135deg, #07c160 0%, #05a550 100%);
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.confirm-btn.active:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.2);
}

.confirm-btn[disabled] {
  opacity: 1;
}
