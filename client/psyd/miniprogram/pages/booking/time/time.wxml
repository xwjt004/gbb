<!--pages/booking/time/time.wxml-->
<view class="container">
  <!-- 顶部导航栏 -->
  <view class="navbar">
    <view class="navbar-back" bindtap="goBack">
      <text class="iconfont icon-back">‹</text>
    </view>
    <view class="navbar-title">选择时间段</view>
    <view class="navbar-placeholder"></view>
  </view>

  <!-- 套系信息卡片 -->
  <view class="package-card" wx:if="{{packageInfo}}">
    <image class="package-image" src="{{packageInfo.image}}" mode="aspectFill" />
    <view class="package-info">
      <view class="package-name">{{packageInfo.name}}</view>
      <view class="package-meta">
        <text class="package-price">¥{{packageInfo.price}}</text>
        <text class="package-duration">约{{packageInfo.duration}}分钟</text>
      </view>
    </view>
  </view>

  <!-- 选中日期显示 -->
  <view class="date-info">
    <view class="date-icon">📅</view>
    <view class="date-text">
      <text class="date-display">{{dateDisplay}}</text>
      <text class="date-week">{{weekDay}}</text>
    </view>
  </view>

  <!-- 时间段列表 -->
  <view class="time-slots" wx:if="{{!loading && hasSlots}}">
    <!-- 上午时段 -->
    <view class="time-period" wx:if="{{morningSlots.length > 0}}">
      <view class="period-header">
        <view class="period-icon">🌅</view>
        <view class="period-title">上午</view>
      </view>
      <view class="slot-list">
        <view 
          class="slot-item {{item.isAvailable ? '' : 'disabled'}} {{selectedSlotId === item.id ? 'selected' : ''}}"
          wx:for="{{morningSlots}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="selectTimeSlot"
        >
          <view class="slot-time">{{item.startTime}} - {{item.endTime}}</view>
          <view class="slot-status">
            <text wx:if="{{item.isExpired}}" class="status-tag expired">已过期</text>
            <text wx:elif="{{!item.isAvailable}}" class="status-tag full">已满</text>
            <text wx:else class="slot-count">剩余 {{item.maxBookings - item.currentBookings}} 个名额</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 下午时段 -->
    <view class="time-period" wx:if="{{afternoonSlots.length > 0}}">
      <view class="period-header">
        <view class="period-icon">☀️</view>
        <view class="period-title">下午</view>
      </view>
      <view class="slot-list">
        <view 
          class="slot-item {{item.isAvailable ? '' : 'disabled'}} {{selectedSlotId === item.id ? 'selected' : ''}}"
          wx:for="{{afternoonSlots}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="selectTimeSlot"
        >
          <view class="slot-time">{{item.startTime}} - {{item.endTime}}</view>
          <view class="slot-status">
            <text wx:if="{{item.isExpired}}" class="status-tag expired">已过期</text>
            <text wx:elif="{{!item.isAvailable}}" class="status-tag full">已满</text>
            <text wx:else class="slot-count">剩余 {{item.maxBookings - item.currentBookings}} 个名额</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 晚上时段 -->
    <view class="time-period" wx:if="{{eveningSlots.length > 0}}">
      <view class="period-header">
        <view class="period-icon">🌙</view>
        <view class="period-title">晚上</view>
      </view>
      <view class="slot-list">
        <view 
          class="slot-item {{item.isAvailable ? '' : 'disabled'}} {{selectedSlotId === item.id ? 'selected' : ''}}"
          wx:for="{{eveningSlots}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="selectTimeSlot"
        >
          <view class="slot-time">{{item.startTime}} - {{item.endTime}}</view>
          <view class="slot-status">
            <text wx:if="{{item.isExpired}}" class="status-tag expired">已过期</text>
            <text wx:elif="{{!item.isAvailable}}" class="status-tag full">已满</text>
            <text wx:else class="slot-count">剩余 {{item.maxBookings - item.currentBookings}} 个名额</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <view class="loading-text">加载中...</view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && !hasSlots}}">
    <view class="empty-icon">📭</view>
    <view class="empty-text">当前日期暂无可用时间段</view>
    <view class="empty-hint">请返回选择其他日期</view>
  </view>

  <!-- 底部确认按钮 -->
  <view class="footer" wx:if="{{hasSlots}}">
    <view class="footer-info">
      <text class="info-label">已选择：</text>
      <text class="info-value" wx:if="{{selectedSlotId}}">
        {{selectedSlotTime}}
      </text>
      <text class="info-placeholder" wx:else>请选择时间段</text>
    </view>
    <button 
      class="confirm-btn {{selectedSlotId ? 'active' : ''}}" 
      bindtap="confirmSelection"
      disabled="{{!selectedSlotId}}"
    >
      下一步
    </button>
  </view>
</view>
