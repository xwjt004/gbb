<!-- 流光金属 · 确认预约页 -->
<view class="container">
  <!-- 进度指示器 -->
  <view class="stepper">
    <view class="step-item">
      <view class="step-indicator">
        <view class="step-circle done">✓</view>
        <text class="step-label done">选日期</text>
      </view>
    </view>
    <view class="step-line">
      <view class="step-line-fill" style="width: 100%;"></view>
    </view>
    <view class="step-item">
      <view class="step-indicator">
        <view class="step-circle done">✓</view>
        <text class="step-label done">选时间</text>
      </view>
    </view>
    <view class="step-line">
      <view class="step-line-fill" style="width: 100%;"></view>
    </view>
    <view class="step-item">
      <view class="step-indicator">
        <view class="step-circle done">✓</view>
        <text class="step-label done">填信息</text>
      </view>
    </view>
    <view class="step-line">
      <view class="step-line-fill" style="width: 100%;"></view>
    </view>
    <view class="step-item">
      <view class="step-indicator">
        <view class="step-circle active">4</view>
        <text class="step-label active">确认</text>
      </view>
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="content" wx:if="{{bookingData}}">

    <!-- 预约信息卡片 -->
    <view class="info-card">
      <view class="card-header">
        <text class="header-icon">📋</text>
        <text class="header-title">预约信息</text>
      </view>
      <view class="info-item">
        <text class="item-label">套系名称</text>
        <text class="item-value">{{bookingData.packageInfo.name}}</text>
      </view>
      <view class="info-item">
        <text class="item-label">预约日期</text>
        <text class="item-value">{{bookingData.dateDisplay}} {{bookingData.weekDay}}</text>
      </view>
      <view class="info-item">
        <text class="item-label">预约时间</text>
        <text class="item-value">{{bookingData.slotInfo.startTime}} — {{bookingData.slotInfo.endTime}}</text>
      </view>
      <view class="info-item">
        <text class="item-label">服务时长</text>
        <text class="item-value">约{{bookingData.packageInfo.duration_minutes}}分钟</text>
      </view>
      <view class="info-item">
        <text class="item-label">儿童数量</text>
        <text class="item-value">{{bookingData.childrenCount}}位</text>
      </view>
    </view>

    <!-- 联系人信息 -->
    <view class="info-card">
      <view class="card-header">
        <text class="header-icon">👤</text>
        <text class="header-title">联系人信息</text>
      </view>
      <view class="info-item">
        <text class="item-label">联系人</text>
        <text class="item-value">{{bookingData.contactName}}</text>
      </view>
      <view class="info-item">
        <text class="item-label">联系电话</text>
        <text class="item-value">{{bookingData.contactPhone}}</text>
      </view>
      <view class="info-item" wx:if="{{bookingData.notes}}">
        <text class="item-label">备注信息</text>
        <text class="item-value notes">{{bookingData.notes}}</text>
      </view>
    </view>

    <!-- 价格明细 -->
    <view class="info-card">
      <view class="card-header">
        <text class="header-icon">💰</text>
        <text class="header-title">价格明细</text>
      </view>
      <view class="price-item">
        <text class="price-label">套系价格</text>
        <text class="price-amount">¥{{bookingData.packageInfo.price}}</text>
      </view>
      <view class="price-item">
        <text class="price-label">定金金额</text>
        <text class="price-amount deposit">¥{{bookingData.packageInfo.depositAmount}}</text>
      </view>
      <view class="price-divider"></view>
      <view class="price-item total">
        <text class="price-label">应付金额</text>
        <text class="price-amount highlight">¥{{payAmount}}</text>
      </view>
    </view>

    <!-- 支付方式 -->
    <view class="payment-section">
      <view class="section-title">
        <text class="title-icon">💳</text>
        <text>选择支付方式</text>
      </view>
      <view class="payment-options">
        <view
          class="payment-option {{paymentType === 'full' ? 'selected' : ''}}"
          data-type="full"
          bindtap="selectPaymentType"
        >
          <view class="option-header">
            <view class="option-left">
              <view class="option-radio">
                <view class="radio-inner" wx:if="{{paymentType === 'full'}}"></view>
              </view>
              <text class="option-title">全款支付</text>
            </view>
            <text class="option-tag">推荐</text>
          </view>
          <view class="option-desc">一次性支付全款 ¥{{bookingData.packageInfo.price}}</view>
        </view>

        <view
          class="payment-option {{paymentType === 'deposit' ? 'selected' : ''}}"
          data-type="deposit"
          bindtap="selectPaymentType"
        >
          <view class="option-header">
            <view class="option-left">
              <view class="option-radio">
                <view class="radio-inner" wx:if="{{paymentType === 'deposit'}}"></view>
              </view>
              <text class="option-title">定金支付</text>
            </view>
          </view>
          <view class="option-desc">先付定金 ¥{{bookingData.packageInfo.depositAmount}}，到店后补齐余款</view>
        </view>
      </view>
    </view>

    <!-- 预约须知 -->
    <view class="notice-section">
      <view class="notice-title">
        <text class="notice-icon">⚠</text>
        <text>预约须知</text>
      </view>
      <view class="notice-content">
        1. 请提前10分钟到店，以便做好拍摄准备
        2. 如需改期或取消，请提前24小时联系客服
        3. 定金支付后，到店时需补齐余款
        4. 全款支付后如需退款，将按照退款政策执行
        5. 拍摄当天请保持儿童良好的精神状态
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="footer">
    <view class="footer-left">
      <view class="contact-service" bindtap="contactService">
        <text class="service-icon">📞</text>
        <text class="service-text">客服</text>
      </view>
      <view class="total-info">
        <text class="total-label">实付</text>
        <text class="total-amount">¥{{payAmount}}</text>
      </view>
    </view>
    <button
      class="submit-btn {{submitting ? 'disabled' : ''}}"
      bindtap="submitOrder"
      disabled="{{submitting}}"
      loading="{{submitting}}"
    >
      {{submitting ? '提交中...' : '确认支付'}}
    </button>
  </view>
</view>
