/* ============================================
   流光金属 · 日期选择页
   Luminous Metal — Date Selection
   ============================================ */

page {
  background: #fff5f7;
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  padding-bottom: 180rpx;
}

/* ==================== 进度指示器 ==================== */
.stepper {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx 20rpx;
  gap: 0;
}

.step-item {
  display: flex;
  align-items: center;
  flex: 1;
}

.step-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  position: relative;
}

.step-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  border: 2rpx solid rgba(42, 39, 36, 0.2);
  background: #ffffff;
  color: rgba(26, 24, 22, 0.96);
}

.step-circle.active {
  background: linear-gradient(135deg, #ff69b4, #ff85c8);
  border-color: transparent;
  color: #ffffff;
  box-shadow: 0 4rpx 24rpx rgba(255, 105, 180, 0.45);
  transform: scale(1.08);
}

.step-circle.done {
  background: rgba(76, 175, 132, 0.15);
  border-color: #4caf84;
  color: #4caf84;
  font-size: 28rpx;
}

.step-label {
  font-size: 20rpx;
  color: rgba(26, 24, 22, 0.93);
  font-weight: 500;
  letter-spacing: 0.5rpx;
  white-space: nowrap;
}

.step-label.active {
  color: #ff69b4;
}

.step-label.done {
  color: rgba(76, 175, 132, 0.7);
}

.step-line {
  flex: 1;
  height: 2rpx;
  background: rgba(0, 0, 0, 0.06);
  margin: 0 16rpx;
  margin-bottom: 48rpx;
  position: relative;
  overflow: hidden;
}

.step-line-fill {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  background: linear-gradient(90deg, #ff69b4, #4caf84);
  transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* ==================== 套系信息卡片 ==================== */
.package-card {
  margin: 4rpx 28rpx 20rpx;
  padding: 32rpx 32rpx;
  background: linear-gradient(135deg, rgba(255, 105, 180, 0.12), rgba(232, 201, 160, 0.06));
  border: 1rpx solid rgba(255, 105, 180, 0.2);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
}

.package-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(255, 105, 180, 0.08) 0%, transparent 70%);
  pointer-events: none;
}

.package-card::after {
  content: '';
  position: absolute;
  bottom: -50%;
  left: -50%;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(255, 105, 180, 0.05) 0%, transparent 70%);
  pointer-events: none;
}

.package-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1816;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
  position: relative;
  z-index: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.package-price {
  display: flex;
  align-items: baseline;
  gap: 20rpx;
  position: relative;
  z-index: 1;
}

.price {
  font-size: 48rpx;
  font-weight: 800;
  color: #ff69b4;
  letter-spacing: 1rpx;
}

.price::before {
  content: '¥';
  font-size: 30rpx;
  margin-right: 4rpx;
  font-weight: 700;
}

.deposit {
  font-size: 24rpx;
  color: rgba(26, 24, 22, 0.9);
  background: rgba(42, 39, 36, 0.04);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 500;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

/* ==================== 日历容器 ==================== */
.calendar-container {
  margin: 0 28rpx 20rpx;
  padding: 28rpx 28rpx 24rpx;
  background: #ffffff;
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 1rpx solid rgba(0, 0, 0,0.08);
  border-radius: 28rpx;
  box-shadow: 0 4rpx 28rpx rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
}

.calendar-container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 105, 180, 0.3), transparent);
}

/* 月份切换 */
.month-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
  padding: 0 8rpx;
}

.month-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0,0.08);
  transition: all 0.3s ease;
}

.month-btn:active {
  background: rgba(255, 105, 180, 0.2);
  transform: scale(0.92);
}

.month-btn text {
  font-size: 32rpx;
  color: #1a1816;
  font-weight: 600;
}

.month-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1816;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 20rpx rgba(42, 39, 36, 0.08);
}

/* 星期标题 */
.week-header {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
  margin-bottom: 16rpx;
  padding: 16rpx 0 20rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0,0.06);
}

.week-item {
  text-align: center;
  font-size: 24rpx;
  color: rgba(26, 24, 22, 0.96);
  font-weight: 600;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

/* 日期网格 */
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
}

.calendar-cell {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  position: relative;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  min-height: 88rpx;
  border: 1rpx solid transparent;
}

.calendar-cell.disabled {
  opacity: 0.2;
  cursor: default;
}

.calendar-cell.today {
  border-color: rgba(255, 105, 180, 0.35);
  background: rgba(255, 105, 180, 0.1);
}

.calendar-cell.has-slots {
  border-color: rgba(76, 175, 132, 0.25);
  background: rgba(76, 175, 132, 0.06);
}

.calendar-cell.has-slots .day-number {
  color: #2e7d5e;
}

.calendar-cell.selected {
  background: linear-gradient(135deg, #ff69b4, #ff85c8);
  box-shadow: 0 8rpx 32rpx rgba(255, 105, 180, 0.4);
  transform: scale(1.1);
  border-color: transparent;
  z-index: 10;
}

.calendar-cell:not(.disabled):active {
  transform: scale(0.92);
}

.day-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  position: relative;
}

.day-number {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1816;
  line-height: 1;
  margin-bottom: 4rpx;
  transition: all 0.3s ease;
}

.calendar-cell.selected .day-number {
  color: #ffffff;
  font-weight: 800;
}

.calendar-cell.today .day-number {
  color: #ff69b4;
  font-weight: 700;
}

.calendar-cell.disabled .day-number {
  color: rgba(26, 24, 22, 0.5);
}

/* 日期底部标签 */
.day-footer {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.slots-tag {
  font-size: 18rpx;
  color: #4caf84;
  font-weight: 600;
  background: rgba(76, 175, 132, 0.12);
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  line-height: 1.3;
}

.calendar-cell.selected .slots-tag {
  color: rgba(255, 255, 255, 0.85);
  background: rgba(255, 255, 255, 0.2);
}

.full-tag {
  font-size: 18rpx;
  color: rgba(255, 107, 107, 0.6);
  font-weight: 600;
}

.holiday-tag {
  font-size: 18rpx;
  color: #ff69b4;
  font-weight: 600;
  line-height: 1.3;
}

.today-tag {
  font-size: 18rpx;
  color: #ff69b4;
  font-weight: 500;
  line-height: 1.3;
}

/* 月视图切换提示 */
.month-hint {
  text-align: center;
  padding: 20rpx 0 0;
  font-size: 22rpx;
  color: rgba(26, 24, 22, 0.78);
  letter-spacing: 1rpx;
}

/* ==================== 选中日期信息 ==================== */
.selected-info {
  margin: 0 28rpx 24rpx;
  padding: 28rpx 32rpx;
  background: #ffffff;
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 105, 180, 0.15);
  border-radius: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.selected-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.selected-label {
  font-size: 22rpx;
  color: rgba(26, 24, 22, 0.9);
  font-weight: 500;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

.selected-date {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1816;
  letter-spacing: 1rpx;
}

.selected-weekday {
  font-size: 24rpx;
  color: rgba(26, 24, 22, 0.93);
  font-weight: 500;
}

.selected-glow {
  width: 8rpx;
  height: 48rpx;
  background: linear-gradient(180deg, #ff69b4, #ff85c8);
  border-radius: 4rpx;
  box-shadow: 0 0 20rpx rgba(255, 105, 180, 0.3);
}

/* ==================== 图例说明 ==================== */
.legend-container {
  margin: 0 28rpx 24rpx;
  padding: 24rpx 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0,0.05);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.legend-title {
  font-size: 22rpx;
  color: rgba(26, 24, 22, 0.96);
  font-weight: 600;
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

.legend-list {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  justify-content: center;
}

.legend-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.legend-dot.today {
  background: rgba(255, 105, 180, 0.15);
  border: 1rpx solid rgba(255, 105, 180, 0.3);
}

.legend-dot.available {
  background: rgba(76, 175, 132, 0.15);
  border: 1rpx solid rgba(76, 175, 132, 0.35);
}

.legend-dot.selected-dot {
  background: linear-gradient(135deg, #ff69b4, #ff85c8);
}

.legend-dot.disabled {
  background: rgba(0, 0, 0, 0.03);
  opacity: 0.3;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.legend-item text {
  font-size: 22rpx;
  color: rgba(26, 24, 22, 0.9);
  font-weight: 500;
}

/* ==================== 底部操作栏 ==================== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 28rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 100;
  background: rgba(255, 245, 247, 0.95);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border-top: 1rpx solid rgba(0, 0, 0,0.06);
}

.bottom-inner {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.bottom-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.bottom-label {
  font-size: 22rpx;
  color: rgba(26, 24, 22, 0.96);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.bottom-date {
  font-size: 28rpx;
  color: #ff69b4;
  font-weight: 600;
}

.confirm-btn {
  flex: 1;
  height: 96rpx;
  background: linear-gradient(135deg, #ff69b4, #ff85c8);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(255, 105, 180, 0.35);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.confirm-btn:active {
  transform: translateY(1rpx) scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 105, 180, 0.3);
}

.confirm-btn.disabled {
  background: rgba(0, 0, 0, 0.04);
  color: rgba(26, 24, 22, 0.72);
  box-shadow: none;
}

.confirm-btn::after {
  border: none;
}

.btn-arrow {
  font-size: 28rpx;
  transition: transform 0.3s ease;
}

.confirm-btn:not(.disabled):active .btn-arrow {
  transform: translateX(4rpx);
}

/* ==================== 加载状态 ==================== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.loading-ring {
  width: 72rpx;
  height: 72rpx;
  border: 4rpx solid rgba(0, 0, 0,0.06);
  border-top-color: #ff69b4;
  border-right-color: rgba(255, 105, 180, 0.4);
  border-radius: 50%;
  animation: spin 0.8s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 28rpx;
  font-size: 26rpx;
  color: rgba(26, 24, 22, 0.9);
  letter-spacing: 1rpx;
}
