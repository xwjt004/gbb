/* ============================================
   我的页面 — 柔和可爱风（儿童摄影主题）
   ============================================ */

.page {
  width: 100%;
  min-height: 100vh;
  background: #f8f6f7;
}

.scroll-view {
  width: 100%;
  height: 100vh;
}

/* ===== 用户信息头部 ===== */
.header {
  position: relative;
  padding: 48rpx 32rpx 100rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #FF9A9E 0%, #FAD0C4 50%, #FBC2EB 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.header-content {
  position: relative;
  display: flex;
  align-items: center;
  z-index: 1;
}

.avatar-wrapper {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  flex-shrink: 0;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.6);
}

.avatar-placeholder {
  background: rgba(255,255,255,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-emoji {
  font-size: 64rpx;
}

.vip-badge {
  position: absolute;
  right: -8rpx;
  bottom: 0;
  padding: 4rpx 16rpx;
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #8B4513;
  font-size: 20rpx;
  font-weight: 700;
  border-radius: 20rpx;
  border: 2rpx solid #fff;
}

.user-meta {
  flex: 1;
  margin-left: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #4A2C3A;
  line-height: 1.2;
}

.phone {
  font-size: 26rpx;
  color: rgba(74,44,58,0.7);
}

.arrow-icon {
  font-size: 48rpx;
  color: rgba(74,44,58,0.4);
  font-weight: 300;
  padding-left: 16rpx;
}

/* ===== 通用卡片 ===== */
.card {
  margin: 20rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D2C33;
  position: relative;
  padding-left: 20rpx;
}

.card-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #FF9A9E, #FBC2EB);
  border-radius: 3rpx;
}

.card-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 26rpx;
  color: #A8A0A4;
}

.arrow {
  font-size: 36rpx;
  font-weight: 300;
}

/* ===== 快捷入口网格 ===== */
.grid-card {
  position: relative;
  z-index: 2;
  margin: -48rpx 24rpx 20rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 16rpx 8rpx;
  box-shadow: 0 8rpx 32rpx rgba(255,154,158,0.15);
}

.grid-row {
  display: flex;
}

.grid-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  cursor: pointer;
  transition: transform 0.2s;
}

.grid-item:active {
  transform: scale(0.92);
}

.grid-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.icon-fav { background: #FFF0F6; }
.icon-addr { background: #E8F4FD; }
.icon-cpn { background: #FFF8E1; }
.icon-pts { background: #F3E8FF; }

.grid-label {
  font-size: 24rpx;
  color: #5C4A52;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.grid-value {
  font-size: 22rpx;
  color: #FF9A9E;
  font-weight: 600;
}

/* ===== 订单区域 ===== */
.order-grid {
  display: flex;
  justify-content: space-around;
  padding: 8rpx 0;
}

.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
  padding: 8rpx 16rpx;
}

.order-item:active {
  opacity: 0.6;
}

.order-icon-wrap {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #f8f6f7;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.order-icon {
  font-size: 40rpx;
}

.order-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 8rpx;
  background: #FF6B6B;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  text-align: center;
  border-radius: 18rpx;
  border: 2rpx solid #fff;
}

.order-label {
  font-size: 24rpx;
  color: #6B5B62;
}

/* ===== 常用工具 ===== */
.tools-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tool-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: calc(50% - 8rpx);
  padding: 24rpx 20rpx;
  background: #FAF8F9;
  border-radius: 18rpx;
  cursor: pointer;
  transition: all 0.2s;
  box-sizing: border-box;
}

.tool-item:active {
  transform: scale(0.97);
  background: #F5F0F2;
}

.tool-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.tool-label {
  font-size: 26rpx;
  color: #4A3B42;
  font-weight: 500;
}

/* ===== 底部 ===== */
.footer-placeholder {
  height: 40rpx;
}
