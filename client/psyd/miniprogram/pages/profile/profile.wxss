/* pages/profile/profile.wxss */

.profile-page {
  width: 100%;
  min-height: 100vh;
  background: #f5f7fa;
}

.scroll-container {
  width: 100%;
  height: 100vh;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 48rpx 32rpx 32rpx;
  margin-bottom: 16rpx;
}

.user-header {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #ffffff;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-default {
  background: linear-gradient(135deg, #e0e7ff 0%, #f0e7ff 100%);
}

.avatar-emoji {
  font-size: 60rpx;
  color: #667eea;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-right: 12rpx;
}

.vip-badge {
  display: flex;
  align-items: center;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(255,215,0,0.3);
}

.vip-icon {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.vip-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #8b5a00;
}

.user-phone {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
}

/* 区块容器 */
.section {
  background: #ffffff;
  margin-bottom: 16rpx;
  padding: 24rpx 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #999999;
}

.arrow {
  font-size: 28rpx;
  margin-left: 4rpx;
  color: #999999;
}

/* 订单状态网格 */
.order-status-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.order-status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  cursor: pointer;
}

.status-icon-wrapper {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 12rpx;
}

.status-icon {
  width: 100%;
  height: 100%;
}

.status-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #ff4444;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 600;
  border: 2rpx solid #ffffff;
}

.status-label {
  font-size: 24rpx;
  color: #666666;
  text-align: center;
}

/* 资产网格 */
.assets-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.asset-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: #f9fafb;
  border-radius: 16rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.asset-item:active {
  background: #f0f2f5;
  transform: scale(0.98);
}

.asset-icon-wrapper {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 12rpx;
}

.asset-icon {
  width: 100%;
  height: 100%;
}

.asset-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #ff4444;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 600;
}

.asset-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.asset-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #667eea;
}

.asset-value.vip {
  color: #ffd700;
}

.asset-value.no-data {
  color: #999999;
  font-size: 24rpx;
  font-weight: normal;
}

/* 功能列表 */
.function-list {
  display: flex;
  flex-direction: column;
}

.function-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  cursor: pointer;
  transition: background 0.3s ease;
}

.function-item:last-child {
  border-bottom: none;
}

.function-item:active {
  background: #f9fafb;
}

.function-left {
  display: flex;
  align-items: center;
}

.function-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.function-label {
  font-size: 28rpx;
  color: #333333;
}

/* 底部占位 */
.bottom-placeholder {
  height: 32rpx;
}
