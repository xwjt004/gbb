<view class="page">
  <scroll-view scroll-y class="scroll-view" enhanced show-scrollbar="{{false}}">

    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="loading-wrap">
      <text class="loading-text">加载中...</text>
    </view>

    <block wx:else>

      <!-- ===== 头像 ===== -->
      <view class="avatar-section" bindtap="chooseAvatar">
        <view class="avatar-wrap">
          <image wx:if="{{avatar && avatar !== ''}}" src="{{avatar}}" class="avatar" mode="aspectFill" />
          <view wx:else class="avatar avatar-placeholder">
            <text class="avatar-emoji">👶</text>
          </view>
          <view class="avatar-overlay">
            <text class="camera-icon">📷</text>
          </view>
        </view>
        <text class="avatar-tip">点击更换头像</text>
      </view>

      <!-- ===== 基本信息 ===== -->
      <view class="form-group">
        <view class="group-title">基本信息</view>
        <view class="form-row">
          <text class="form-label">昵称</text>
          <input
            class="form-input"
            type="nickname"
            placeholder="请输入昵称"
            placeholder-class="form-ph"
            value="{{nickname}}"
            data-field="nickname"
            bindinput="onInput"
          />
        </view>
        <view class="form-row">
          <text class="form-label">真实姓名</text>
          <input
            class="form-input"
            placeholder="请输入真实姓名"
            placeholder-class="form-ph"
            value="{{realName}}"
            data-field="realName"
            bindinput="onInput"
          />
        </view>
        <view class="form-row">
          <text class="form-label">联系电话</text>
          <input
            class="form-input"
            type="number"
            maxlength="11"
            placeholder="请输入手机号"
            placeholder-class="form-ph"
            value="{{phone}}"
            data-field="phone"
            bindinput="onInput"
          />
        </view>
        <view class="form-row">
          <text class="form-label">家庭地址</text>
          <input
            class="form-input"
            placeholder="请输入家庭地址"
            placeholder-class="form-ph"
            value="{{address}}"
            data-field="address"
            bindinput="onInput"
          />
        </view>
      </view>

      <!-- ===== 宝宝信息 ===== -->
      <view class="form-group">
        <view class="group-title">宝宝信息</view>
        <view class="form-row">
          <text class="form-label">身高 (cm)</text>
          <input
            class="form-input"
            type="number"
            placeholder="请输入身高"
            placeholder-class="form-ph"
            value="{{height}}"
            data-field="height"
            bindinput="onInput"
          />
        </view>
        <view class="form-row">
          <text class="form-label">体重 (kg)</text>
          <input
            class="form-input"
            type="number"
            placeholder="请输入体重"
            placeholder-class="form-ph"
            value="{{weight}}"
            data-field="weight"
            bindinput="onInput"
          />
        </view>
        <view class="form-row">
          <text class="form-label">生肖</text>
          <picker
            range="{{ZODIACS}}"
            value="{{zodiacIndex}}"
            bindchange="onZodiacChange"
          >
            <text class="form-input form-picker {{zodiac ? '' : 'form-ph'}}">
              {{zodiac || '请选择生肖'}}
            </text>
          </picker>
        </view>
        <view class="form-row">
          <text class="form-label">星座</text>
          <picker
            range="{{CONSTELLATIONS}}"
            value="{{constellationIndex}}"
            bindchange="onConstellationChange"
          >
            <text class="form-input form-picker {{constellation ? '' : 'form-ph'}}">
              {{constellation || '请选择星座'}}
            </text>
          </picker>
        </view>
        <view class="form-row">
          <text class="form-label">幼儿园/学校</text>
          <input
            class="form-input"
            placeholder="请输入学校名称"
            placeholder-class="form-ph"
            value="{{schoolName}}"
            data-field="schoolName"
            bindinput="onInput"
          />
        </view>
        <view class="form-row">
          <text class="form-label">才艺/兴趣</text>
          <input
            class="form-input"
            placeholder="请输入才艺兴趣"
            placeholder-class="form-ph"
            value="{{talent}}"
            data-field="talent"
            bindinput="onInput"
          />
        </view>
      </view>

      <!-- ===== 纪念日 ===== -->
      <view class="form-group">
        <view class="group-title">纪念日</view>
        <view class="form-row">
          <text class="form-label">百日纪念</text>
          <picker
            mode="date"
            value="{{hundredDaysDate}}"
            data-field="hundredDaysDate"
            bindchange="onDateChange"
          >
            <text class="form-input form-picker {{hundredDaysDate ? '' : 'form-ph'}}">
              {{hundredDaysDate || '请选择日期'}}
            </text>
          </picker>
        </view>
        <view class="form-row">
          <text class="form-label">周岁纪念</text>
          <picker
            mode="date"
            value="{{firstBirthdayDate}}"
            data-field="firstBirthdayDate"
            bindchange="onDateChange"
          >
            <text class="form-input form-picker {{firstBirthdayDate ? '' : 'form-ph'}}">
              {{firstBirthdayDate || '请选择日期'}}
            </text>
          </picker>
        </view>
      </view>

      <!-- ===== 保存按钮 ===== -->
      <view class="save-wrap">
        <button
          class="save-btn {{saving ? 'save-btn-loading' : ''}}"
          disabled="{{saving}}"
          bindtap="save"
        >
          <text>{{saving ? '保存中...' : '保存资料'}}</text>
        </button>
      </view>

      <view class="footer-gap"></view>
    </block>
  </scroll-view>
</view>
