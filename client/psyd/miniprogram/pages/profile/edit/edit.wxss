.page {
  width: 100%;
  min-height: 100vh;
  background: #F8F6F7;
}

.scroll-view {
  width: 100%;
  height: 100vh;
}

/* ===== 加载 ===== */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #B8ADB2;
}

/* ===== 头像 ===== */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 32rpx;
  background: linear-gradient(180deg, #FFF0F5, #F8F6F7);
}

.avatar-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: block;
}

.avatar-placeholder {
  background: linear-gradient(135deg, #FF9A9E, #FBC2EB);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-emoji {
  font-size: 64rpx;
}

.avatar-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: rgba(0,0,0,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.2s;
}

.avatar-wrap:active .avatar-overlay {
  opacity: 1;
}

.camera-icon {
  font-size: 44rpx;
  color: #fff;
}

.avatar-tip {
  font-size: 24rpx;
  color: #B8ADB2;
}

/* ===== 表单分组 ===== */
.form-group {
  margin: 24rpx 24rpx 0;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.group-title {
  font-size: 24rpx;
  color: #B8ADB2;
  padding: 28rpx 28rpx 12rpx;
  font-weight: 500;
}

/* ===== 表单项 ===== */
.form-row {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F5F0F2;
  min-height: 88rpx;
}

.form-row:last-child {
  border-bottom: none;
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #4A2C3A;
  flex-shrink: 0;
  font-weight: 500;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #3D2C33;
  text-align: right;
  height: 100%;
  min-height: 48rpx;
  background: transparent;
  border: none;
  padding: 0;
}

.form-picker {
  display: block;
  line-height: 48rpx;
}

.form-ph {
  font-size: 28rpx;
  color: #C8BCC2;
}

/* ===== 保存按钮 ===== */
.save-wrap {
  padding: 48rpx 24rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF9A9E, #FBC2EB);
  border-radius: 48rpx;
  border: none;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 32rpx rgba(255,154,158,0.3);
  letter-spacing: 4rpx;
}

.save-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.save-btn::after {
  border: none;
}

.save-btn-loading {
  opacity: 0.6;
  box-shadow: none;
  transform: none !important;
}

.footer-gap {
  height: 48rpx;
}
