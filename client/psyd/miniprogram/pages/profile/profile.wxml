<view class="page">
  <scroll-view scroll-y class="scroll-view" enhanced show-scrollbar="{{false}}">

    <!-- ===== 用户信息头部 ===== -->
    <view class="header" bindtap="onUserCardTap">
      <view class="header-bg"></view>
      <view class="header-content">
        <view class="avatar-wrapper">
          <image wx:if="{{userInfo.avatar}}" src="{{userInfo.avatar}}" class="avatar" mode="aspectFill" />
          <view wx:else class="avatar avatar-placeholder">
            <text class="avatar-emoji">👶</text>
          </view>
          <view wx:if="{{userInfo.isVip}}" class="vip-badge">VIP</view>
        </view>
        <view class="user-meta">
          <text class="nickname">{{userInfo.nickname || '点击登录'}}</text>
          <text class="phone">{{userInfo.phone || '未绑定手机号'}}</text>
        </view>
        <text class="arrow-icon">›</text>
      </view>
    </view>

    <!-- ===== 快捷入口网格 ===== -->
    <view class="grid-card">
      <view class="grid-row">
        <view class="grid-item" bindtap="goToGroupBuy">
          <view class="grid-icon icon-group-buy">🎯</view>
          <text class="grid-label">我的团购</text>
        </view>
        <view class="grid-item" bindtap="goToFavorite">
          <view class="grid-icon icon-fav">❤️</view>
          <text class="grid-label">我的收藏</text>
        </view>
        <view class="grid-item" bindtap="goToAddress">
          <view class="grid-icon icon-addr">📍</view>
          <text class="grid-label">地址管理</text>
        </view>
        <!-- 第二阶段开放：优惠券 -->
        <!-- <view class="grid-item" bindtap="goToCoupon">
          <view class="grid-icon icon-cpn">🎫</view>
          <text class="grid-label">优惠券</text>
          <text wx:if="{{assetCount.coupon > 0}}" class="grid-value">{{assetCount.coupon}}张</text>
        </view> -->
        <!-- 第二阶段开放：积分 -->
        <!-- <view class="grid-item" bindtap="goToPoints">
          <view class="grid-icon icon-pts">⭐</view>
          <text class="grid-label">积分</text>
          <text class="grid-value">{{assetCount.points || 0}}</text>
        </view> -->
      </view>
    </view>

    <!-- ===== 订单中心 ===== -->
    <view class="card">
      <view class="card-header" bindtap="goToOrderList">
        <text class="card-title">订单中心</text>
        <view class="card-more">
          <text>全部订单</text>
          <text class="arrow">›</text>
        </view>
      </view>
      <view class="order-grid">
        <view class="order-item" bindtap="goToOrderList" data-status="PENDING_PAYMENT">
          <view class="order-icon-wrap">
            <text class="order-icon">📋</text>
            <view wx:if="{{orderCount.unpaid > 0}}" class="order-badge">{{orderCount.unpaid > 99 ? '99+' : orderCount.unpaid}}</view>
          </view>
          <text class="order-label">待支付</text>
        </view>
        <view class="order-item" bindtap="goToOrderList" data-status="PENDING_SHOOTING">
          <view class="order-icon-wrap">
            <text class="order-icon">📸</text>
            <view wx:if="{{orderCount.shooting > 0}}" class="order-badge">{{orderCount.shooting}}</view>
          </view>
          <text class="order-label">待拍摄</text>
        </view>
        <view class="order-item" bindtap="goToOrderList" data-status="PENDING_PICKUP">
          <view class="order-icon-wrap">
            <text class="order-icon">🖼️</text>
            <view wx:if="{{orderCount.pickup > 0}}" class="order-badge">{{orderCount.pickup}}</view>
          </view>
          <text class="order-label">待取件</text>
        </view>
        <view class="order-item" bindtap="goToOrderList" data-status="REFUNDING">
          <view class="order-icon-wrap">
            <text class="order-icon">🔄</text>
            <view wx:if="{{orderCount.refund > 0}}" class="order-badge">{{orderCount.refund}}</view>
          </view>
          <text class="order-label">售后</text>
        </view>
      </view>
    </view>

    <!-- ===== 宝宝幸福空间 ===== -->
    <view class="happiness-card" bindtap="goToMilestones">
      <view class="happiness-left">
        <view class="happiness-icon">🌟</view>
        <view class="happiness-info">
          <text class="happiness-title">宝宝幸福空间</text>
          <text class="happiness-desc">记录宝宝成长的每一个珍贵瞬间</text>
        </view>
      </view>
      <text class="arrow">›</text>
    </view>

    <!-- ===== 常用工具 ===== -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">常用工具</text>
      </view>
      <view class="tools-grid">
        <view class="tool-item" bindtap="goToSamples">
          <view class="tool-icon" style="background:#E8F5E9;">
            <text>🖼️</text>
          </view>
          <text class="tool-label">样片展示</text>
        </view>
        <view class="tool-item" bindtap="goToAlbum">
          <view class="tool-icon" style="background:#FFF8E1;">
            <text>📷</text>
          </view>
          <text class="tool-label">电子相册</text>
        </view>
        <view class="tool-item" bindtap="goToPoints">
          <view class="tool-icon" style="background:#F3E8FF;">
            <text>💎</text>
          </view>
          <text class="tool-label">我的积分</text>
        </view>
        <!-- 第二阶段开放：会员中心 -->
        <!-- <view class="tool-item" bindtap="goToVip">
          <view class="tool-icon" style="background:#FFF8E1;">
            <text>👑</text>
          </view>
          <text class="tool-label">会员中心</text>
        </view> -->
        <view class="tool-item" bindtap="contactService">
          <view class="tool-icon" style="background:#E8F5E9;">
            <text>💬</text>
          </view>
          <text class="tool-label">联系客服</text>
        </view>
        <view class="tool-item" bindtap="goToSettings">
          <view class="tool-icon" style="background:#E3F2FD;">
            <text>⚙️</text>
          </view>
          <text class="tool-label">设置</text>
        </view>
        <view class="tool-item" bindtap="goToAbout">
          <view class="tool-icon" style="background:#F3E5F5;">
            <text>📖</text>
          </view>
          <text class="tool-label">关于我们</text>
        </view>
      </view>
    </view>

    <view class="footer-placeholder"></view>
  </scroll-view>
</view>
