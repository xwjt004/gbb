  @@index([isActive])
  @@index([createdAt])
  @@map("discount_rules")
}

model DiyPackage {
  id             Int           @id @default(autoincrement())
  packageName    String        @map("package_name")
  customerId     Int?          @map("customer_id")
  customerInfo   Json?         @map("customer_info")
  selectedItems  Json          @map("selected_items")
  originalAmount Decimal       @map("original_amount") @db.Decimal(10, 2)
  discountAmount Decimal       @map("discount_amount") @db.Decimal(10, 2)
  discountRate   Decimal       @map("discount_rate") @db.Decimal(5, 2)
  savedAmount    Decimal       @map("saved_amount") @db.Decimal(10, 2)
  discountRuleId Int?          @map("discount_rule_id")
  status         String        @default("DRAFT")
  expiresAt      DateTime?     @map("expires_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  wxUserId       String?       @map("wx_user_id")
  discountRule   DiscountRule? @relation(fields: [discountRuleId], references: [id])
  wxUser         WxUser?       @relation("WxDiyPackages", fields: [wxUserId], references: [id])
  orders         Order[]

  @@index([customerId])
  @@index([wxUserId])
  @@index([status])
  @@index([createdAt])
  @@index([expiresAt])
  @@index([discountRuleId])
  @@map("diy_packages")
}

model WxUser {
  id             String            @id @default(uuid())
  openid         String            @unique
  unionid        String?           @unique
  sessionKey     String?           @map("session_key")
  nickname       String?
  avatar         String?
  gender         Int?
  phone          String?
  phoneEncrypted String?           @map("phone_encrypted")
  realName       String?           @map("real_name")
  birthday       DateTime?         // 生日（月日，用于生日关怀）
  height         Float?            // 身高(cm)
  weight         Float?            // 体重(kg)
  zodiac         String?           // 生肖
  constellation  String?           // 星座
  hundredDaysDate DateTime?        @map("hundred_days_date") // 百天日期
  firstBirthdayDate DateTime?     @map("first_birthday_date") // 周岁日期
  graspGift      String?           @map("grasp_gift")       // 抓周礼物
  handFootPrint  String?           @map("hand_foot_print")  // 手脚印图
  walletPhoto    String?           @map("wallet_photo")     // 钱包照
  address        String?           // 家庭住址
  schoolName     String?           @map("school_name")      // 学校名称
  talent         String?           // 宝宝特长
  status         WxUserStatus      @default(ACTIVE)
  linkedUserId   Int?              @map("linked_user_id")
  totalOrders    Int               @default(0) @map("total_orders")
  totalAmount    Decimal           @default(0) @map("total_amount") @db.Decimal(12, 2)
  memberLevel    String            @default("NORMAL") @map("member_level")
  growthPoints   Int               @default(0) @map("growth_points")
  lastOrderAt    DateTime?         @map("last_order_at")
  churnStatus    String            @default("ACTIVE") @map("churn_status")
  lastLoginAt    DateTime?         @map("last_login_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  cartItems      CartItem[]
  diyPackages    DiyPackage[]      @relation("WxDiyPackages")
  orders         Order[]           @relation("WxOrders")
  addresses      ShippingAddress[]
  coupons        UserCoupon[]
  complaints     Complaint[]
  linkedUser     User?             @relation(fields: [linkedUserId], references: [id])

  @@index([openid])
  @@index([phone])
  @@index([status])
  @@index([memberLevel])
  @@index([churnStatus])
  @@index([lastOrderAt])
  @@map("wx_users")
}

model CartItem {
  id            String       @id @default(uuid())
  wxUserId      String       @map("wx_user_id")
  itemType      CartItemType @map("item_type")
  productId     Int?         @map("product_id")
  packageId     Int?         @map("package_id")
  diyComponents Json?        @map("diy_components")
  quantity      Int          @default(1)
  isSelected    Boolean      @default(true) @map("is_selected")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  package       Package?     @relation(fields: [packageId], references: [id])
  product       Product?     @relation(fields: [productId], references: [id])
  wxUser        WxUser       @relation(fields: [wxUserId], references: [id], onDelete: Cascade)

  @@index([wxUserId])
  @@index([productId])
  @@index([packageId])
  @@map("cart_items")
}

model ShippingAddress {
  id           String   @id @default(uuid())
  wxUserId     String   @map("wx_user_id")
  receiverName String   @map("receiver_name") @db.VarChar(50)
  phone        String   @db.VarChar(20)
  province     String   @db.VarChar(50)
  city         String   @db.VarChar(50)
  district     String   @db.VarChar(50)
  detail       String   @db.VarChar(200)
  postalCode   String?  @map("postal_code") @db.VarChar(10)
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  wxUser       WxUser   @relation(fields: [wxUserId], references: [id], onDelete: Cascade)

  @@index([wxUserId])
  @@index([isDefault])
  @@map("shipping_addresses")
}

model MemberLevel {
  id         Int      @id @default(autoincrement())
  level      Int      @unique          // 1=普通, 2=白银, 3=黄金, 4=铂金, 5=钻石
  name       String   @db.VarChar(50)  // 等级名称
  minGrowth  Int      @map("min_growth")
  maxGrowth  Int      @map("max_growth")
  benefits   Json?    // 权益描述（JSON 数组）
  icon       String?  // 等级图标
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([level])
  @@map("member_levels")
}

model Complaint {
  id          String   @id @default(uuid())
  complaintNo String   @unique @map("complaint_no") // 自动生成投诉编号
  wxUserId    String   @map("wx_user_id")
  orderId     String?  @map("order_id")
  title       String   @db.VarChar(200)
  description String   @db.Text
  status      String   @default("PENDING") // PENDING / PROCESSING / RESOLVED / CLOSED
  priority    String   @default("NORMAL")  // LOW / NORMAL / HIGH / URGENT
  handlerId   Int?     @map("handler_id")
  resolution  String?  @db.Text           // 处理结果说明
  handledAt   DateTime? @map("handled_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  wxUser      WxUser   @relation(fields: [wxUserId], references: [id])
  handler     User?    @relation("ComplaintHandler", fields: [handlerId], references: [id])

  @@index([wxUserId])
  @@index([status])
  @@index([createdAt])
  @@index([handlerId])
  @@map("complaints")
}

model Coupon {
  id             String       @id @default(uuid())
  couponCode     String       @unique @map("coupon_code")
  couponName     String       @map("coupon_name")
  couponType     CouponType   @map("coupon_type")
  discountType   DiscountType @map("discount_type")
  discountValue  Decimal      @map("discount_value") @db.Decimal(10, 2)
  minAmount      Decimal?     @map("min_amount") @db.Decimal(10, 2)
  maxDiscount    Decimal?     @map("max_discount") @db.Decimal(10, 2)
  totalCount     Int          @map("total_count")
  usedCount      Int          @default(0) @map("used_count")
  perUserLimit   Int          @default(1) @map("per_user_limit")
  applicableType String       @default("ALL") @map("applicable_type")
  applicableIds  Int[]        @map("applicable_ids")
  startTime      DateTime     @map("start_time")
  endTime        DateTime     @map("end_time")
  status         CouponStatus @default(ACTIVE)
  description    String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  userCoupons    UserCoupon[]

  @@index([couponCode])
  @@index([status])
  @@index([startTime, endTime])
  @@map("coupons")
}

model UserCoupon {
  id         String           @id @default(uuid())
  wxUserId   String           @map("wx_user_id")
  couponId   String           @map("coupon_id")
  status     UserCouponStatus @default(UNUSED)
  usedAt     DateTime?        @map("used_at")
  orderId    String?          @map("order_id")
  receivedAt DateTime         @default(now()) @map("received_at")
  expiredAt  DateTime         @map("expired_at")
  coupon     Coupon           @relation(fields: [couponId], references: [id])
  wxUser     WxUser           @relation(fields: [wxUserId], references: [id], onDelete: Cascade)

  @@index([wxUserId])
  @@index([couponId])
  @@index([status])
  @@map("user_coupons")
}

model AutomationRule {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?
  trigger     String   @db.VarChar(50)
  conditions  Json?
  actions     Json
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([trigger, enabled])
  @@map("automation_rules")
}

model OrderItem {
  id            String        @id @default(uuid())
  orderId       String        @map("order_id")
  itemType      OrderItemType @map("item_type")
  productId     Int?          @map("product_id")
  packageId     Int?          @map("package_id")
  itemName      String        @map("item_name")
  itemImage     String?       @map("item_image")
  specification String?
  quantity      Int           @default(1)
  unitPrice     Decimal       @map("unit_price") @db.Decimal(10, 2)
  totalPrice    Decimal       @map("total_price") @db.Decimal(10, 2)
  diyMeta       Json?         @map("diy_meta")
  createdAt     DateTime      @default(now()) @map("created_at")
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  package       Package?      @relation(fields: [packageId], references: [id])
  product       Product?      @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([packageId])
  @@map("order_items")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum PackageStatus {
  ACTIVE
  INACTIVE
}

enum TimeSlotStatus {
  AVAILABLE
  BOOKED
  UNAVAILABLE
}

enum RefundType {
  FULL
  PARTIAL
  DEPOSIT_ONLY
}

enum RefundMethod {
  ORIGINAL
  CASH
  BANK
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum RefundExecutionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentMode {
  FULL_ONLINE
  DEPOSIT_ONLINE
  FULL_OFFLINE
  DEPOSIT_OFFLINE
}

enum PaymentType {
  DEPOSIT
  FINAL
  FULL
  REFUND
}

enum PaymentMethod {
  WECHAT_PAY
  CASH
  WECHAT_TRANSFER
  ALIPAY_TRANSFER
  BANK_CARD
}

enum PaymentStatus {
  PENDING_PAYMENT
  PARTIAL_PAID
  FULLY_PAID
  REFUNDING
  PARTIAL_REFUNDED
  REFUNDED
  CANCELLED
