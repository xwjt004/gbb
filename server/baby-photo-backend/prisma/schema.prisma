enum OrderStatus {
  PENDING
  CONFIRMED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum WxUserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum CartItemType {
  PRODUCT
  PACKAGE
  DIY_COMPONENT
}

enum CouponType {
  REGISTER
  PROMOTION
  REBATE
  BIRTHDAY
}

enum DiscountType {
  PERCENT
  FIXED
}

enum CouponStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum UserCouponStatus {
  UNUSED
  USED
  EXPIRED
}

enum OrderItemType {
  PRODUCT
  PACKAGE
  DIY_PACKAGE
  SERVICE
}

enum OrderSource {
  ADMIN
  WXAPP
  H5
  API
}

enum NotificationType {
  PUSH
  EMAIL
  SYSTEM
  WECHAT
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model AppNotification {
  id           String             @id @default(uuid())
  type         NotificationType
  title        String
  content      String
  status       NotificationStatus @default(PENDING)
  recipient    String?            // email 地址或用户 ID
  errorMessage String?            @map("error_message") // 发送失败时的错误信息
  sentAt       DateTime?
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("app_notifications")
}

model NotificationTemplate {
  id        String           @id @default(uuid())
  name      String           @unique
  type      NotificationType
  title     String
  content   String
  variables String?          // JSON: ["name", "orderNo"]
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@map("notification_templates")
}

model OperationLog {
  id           String   @id @default(uuid())
  module       String   // 模块名: orders, users, payments 等
  action       String   // 操作类型: CREATE, UPDATE, DELETE, APPROVE, REFUND 等
  operatorId   String?  @map("operator_id")
  operatorName String?  @map("operator_name")
  targetId     String?  @map("target_id")
  targetDesc   String?  @map("target_desc")
  method       String   // HTTP 方法
  path         String   // 请求路径
  params       Json?    // 请求参数（脱敏后）
  ip           String?  // 客户端 IP
  duration     Int      // 耗时（ms）
  statusCode   Int      @map("status_code")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([module])
  @@index([operatorId])
  @@index([createdAt])
  @@index([module, createdAt])
  @@map("operation_logs")
}

model CustomerSegment {
  id             String   @id @default(uuid())
  name           String   @db.VarChar(100)
  description    String?
  rules          Json                // [{field, operator, value}] same format as AutomationRule conditions
  memberCount    Int      @default(0)
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  campaigns      MarketingCampaign[]

  @@map("customer_segments")
}

model MarketingCampaign {
  id             String            @id @default(uuid())
  name           String            @db.VarChar(100)
  description    String?
  segmentId      String?
  campaignType   String            // COUPON_PUSH | NOTIFICATION_PUSH
  couponId       String?
  title          String?
  content        String?
  status         String            @default("DRAFT") // DRAFT | SENDING | SENT | COMPLETED | CANCELLED
  scheduledAt    DateTime?
  sentCount      Int               @default(0)
  openedCount    Int               @default(0)
  clickedCount   Int               @default(0)
  convertedCount Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  segment        CustomerSegment?  @relation(fields: [segmentId], references: [id])
  tracks         CampaignTrack[]

  @@index([segmentId])
  @@index([status])
  @@map("marketing_campaigns")
}

model CampaignTrack {
  id         String            @id @default(uuid())
  campaignId String
  wxUserId   String
  event      String            // DELIVERED | OPENED | CLICKED | CONVERTED
  orderId    String?
  metadata   Json?
  createdAt  DateTime          @default(now())
  campaign   MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([wxUserId])
  @@index([event])
  @@map("campaign_tracks")
}
