generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                @id @default(autoincrement())
  openid             String             @unique
  nickname           String?
  avatar             String?
  phone              String?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at")
  status             UserStatus         @default(ACTIVE)
  roleId             Int?                @map("role_id")
  role               Role?               @relation(fields: [roleId], references: [id])
  orders             Order[]
  alertsHandled      StockAlert[]
  checksApproved     StockCheck[]       @relation("CheckApprover")
  checksCreated      StockCheck[]       @relation("CheckCreator")
  outboundsApproved  StockOutbound[]    @relation("OutboundApprover")
  outboundsSubmitted StockOutbound[]    @relation("OutboundSubmitter")
  complaintsHandled  Complaint[]        @relation("ComplaintHandler")
  photographerOrders Order[]           @relation("PhotographerOrders")
  transactions       StockTransaction[]
  transfersApproved  StockTransfer[]    @relation("TransferApprover")
  transfersSubmitted StockTransfer[]    @relation("TransferSubmitter")
  WxUser             WxUser[]

  @@index([openid])
  @@index([phone])
  @@index([status])
  @@map("users")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false) @map("is_system") // 系统角色不可删除
  status      String           @default("ACTIVE")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  users       User[]
  permissions RolePermission[]

  @@index([status])
  @@map("roles")
}

model RolePermission {
  id         Int      @id @default(autoincrement())
  roleId     Int      @map("role_id")
  permission String   // 格式: "module:action"，如 "orders:edit", "users:delete"
  role       Role     @relation(fields: [roleId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([roleId, permission])
  @@index([roleId])
  @@map("role_permissions")
}

model PackageCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  icon        String?
  color       String?
  sortOrder   Int       @default(0) @map("sort_order")
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  packages    Package[]

  @@index([status])
  @@index([sortOrder])
  @@map("package_categories")
}

model Package {
  id              Int              @id @default(autoincrement())
  name            String
  description     String?
  price           Decimal          @db.Decimal(10, 2)
  deposit         Decimal          @db.Decimal(10, 2)
  durationMinutes Int              @map("duration_minutes")
  includes        String[]         @default([])
  createdAt       DateTime         @default(now()) @map("created_at")
  status          PackageStatus    @default(ACTIVE)
  isPopular       Boolean          @default(false) @map("is_popular")
  images          String[]         @default([])
  category        String?
  tags            String[]         @default([])
  categoryId      Int?             @map("category_id")
  packageType     String           @default("CUSTOM") @map("package_type") @db.VarChar(20)
  style           String?          @db.VarChar(100)
  theme           String?          @db.VarChar(100)
  detailImages    String[]         @default([]) @map("detail_images")
  isOnSale        Boolean          @default(true) @map("is_on_sale")
  salesVolume     Int              @default(0) @map("sales_volume")
  baseSales       Int              @default(0) @map("base_sales") // 基础销量（用于展示的初始销量）
  sortOrder       Int              @default(0) @map("sort_order")
  videoUrl        String?          @map("video_url")
  virtualSales    Int              @default(0) @map("virtual_sales")
  // 促销相关
  promotionPrice    Decimal?   @map("promotion_price") @db.Decimal(10, 2)
  promotionStart    DateTime?  @map("promotion_start")
  promotionEnd      DateTime?  @map("promotion_end")
  // 团购相关
  groupMinCount     Int?       @default(0) @map("group_min_count")
  groupPrice        Decimal?   @map("group_price") @db.Decimal(10, 2)
  // 关联
  seasonalPrices    SeasonalPrice[]
  crossSellPackages CrossSellPackage[] @relation("SourcePackage")
  crossSellSource   CrossSellPackage[] @relation("RecommendedPackage")
  cartItems         CartItem[]
  orderItems        OrderItem[]
  orders            Order[]
  packageProducts   PackageProduct[]
  packageServices   PackageService[]
  packageCategory   PackageCategory? @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([packageType])
  @@index([isOnSale])
  @@index([salesVolume])
  @@index([sortOrder])
  @@map("packages")
}

model SeasonalPrice {
  id        Int      @id @default(autoincrement())
  packageId Int      @map("package_id")
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  price     Decimal  @db.Decimal(10, 2)     // override price during this period
  label     String?  @db.VarChar(50)         // e.g. "旺季", "淡季"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  package   Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId, startDate, endDate])
  @@map("seasonal_prices")
}

model CrossSellPackage {
  id                Int      @id @default(autoincrement())
  sourcePkgId       Int      @map("source_pkg_id")
  recommendedPkgId  Int      @map("recommended_pkg_id")
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")
  sourcePkg         Package  @relation("SourcePackage", fields: [sourcePkgId], references: [id], onDelete: Cascade)
  recommended       Package  @relation("RecommendedPackage", fields: [recommendedPkgId], references: [id], onDelete: Cascade)

  @@unique([sourcePkgId, recommendedPkgId])
  @@map("cross_sell_packages")
}

model TimeSlot {
  id              Int            @id @default(autoincrement())
  date            DateTime       @db.Date
  startTime       DateTime       @map("start_time") @db.Time(6)
  endTime         DateTime       @map("end_time") @db.Time(6)
  isBooked        Boolean        @default(false) @map("is_booked")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at")
  availableCount  Int?           @map("available_count")
  bookedCount     Int            @default(0) @map("booked_count")
  capacity        Int            @default(3)
  isHoliday       Boolean        @default(false) @map("is_holiday")
  notes           String?
  priceMultiplier Float          @default(1.0) @map("price_multiplier")
  status          TimeSlotStatus @default(AVAILABLE)
  orders          Order[]

  @@unique([date, startTime])
  @@index([date])
  @@index([isBooked])
  @@index([status])
  @@map("time_slots")
}

model Order {
  id                String            @id @default(uuid())
  orderNo           String            @unique @map("order_no")
  userId            Int               @map("user_id")
  packageId         Int?              @map("package_id")
  timeSlotId        Int?              @map("time_slot_id")
  appointmentDate   DateTime?         @map("appointment_date")
  totalAmount       Decimal           @map("total_amount") @db.Decimal(10, 2)
  depositAmount     Decimal           @map("deposit_amount") @db.Decimal(10, 2)
  paidAmount        Decimal           @default(0) @map("paid_amount") @db.Decimal(10, 2)
  notes             String?
  childrenCount     Int               @default(1) @map("children_count")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  customerName      String?           @map("customer_name")
  customerPhone     String?           @map("customer_phone")
  diyPackageId      Int?              @map("diy_package_id")
  couponId          String?           @map("coupon_id")
  discountAmount    Decimal           @default(0) @map("discount_amount") @db.Decimal(10, 2)
  shippingAddressId String?           @map("shipping_address_id")
  shippingInfo      Json?             @map("shipping_info")
  source            OrderSource       @default(ADMIN)
  wxUserId          String?           @map("wx_user_id")
  deletedAt         DateTime?         @map("deleted_at")
  depositTimeout    DateTime?         @map("deposit_timeout")
  finalTimeout      DateTime?         @map("final_timeout")
  paymentMode       PaymentMode       @default(FULL_ONLINE) @map("payment_mode")
  paymentSummary    Json?             @map("payment_summary")
  refundedAmount    Decimal           @default(0) @map("refunded_amount") @db.Decimal(10, 2)
  remainingAmount   Decimal           @default(0) @map("remaining_amount") @db.Decimal(10, 2)
  paymentStatus     PaymentStatus     @default(PENDING_PAYMENT) @map("payment_status")
  orderStatus       OrderStatus       @default(PENDING) @map("order_status")
  // 支付协议记录（新增字段）
  agreementAccepted     Boolean?   @map("agreement_accepted")
  agreementVersion      String?    @map("agreement_version")
  agreementAcceptedAt   DateTime?  @map("agreement_accepted_at")
  // 调度相关字段
  photographerId     Int?        @map("photographer_id")
  checkinStatus      String      @default("PENDING") @map("checkin_status")
  checkinTime        DateTime?   @map("checkin_time")
  reminderSentAt           DateTime?   @map("reminder_sent_at")
  completedAt              DateTime?   @map("completed_at")
  photoPickReminderSentAt  DateTime?   @map("photo_pick_reminder_sent_at")
  items             OrderItem[]
  diyPackage        DiyPackage?       @relation(fields: [diyPackageId], references: [id])
  package           Package?          @relation(fields: [packageId], references: [id])
  timeSlot          TimeSlot?         @relation(fields: [timeSlotId], references: [id])
  user              User              @relation(fields: [userId], references: [id])
  photographer      User?             @relation("PhotographerOrders", fields: [photographerId], references: [id])
  wxUser            WxUser?           @relation("WxOrders", fields: [wxUserId], references: [id])
  payments          Payment[]
  refunds           Refund[]
  statusChangeLogs  StatusChangeLog[]
  outbounds         StockOutbound[]

  @@index([diyPackageId])
  @@index([wxUserId])
  @@index([source])
  @@index([depositTimeout])
  @@index([finalTimeout])
  @@index([checkinStatus])
  @@map("orders")
}

model Payment {
  id             String        @id @default(uuid())
  orderId        String        @map("order_id")
  amount         Decimal       @db.Decimal(10, 2)
  transactionId  String?       @unique @map("transaction_id")
  paidAt         DateTime?     @map("paid_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  notes          String?
  refundReason   String?       @map("refund_reason")
  refundedAt     DateTime?     @map("refunded_at")
  expiredAt      DateTime?     @map("expired_at")
  idempotencyKey String?       @unique @map("idempotency_key")
  operatorId     String?       @map("operator_id")
  operatorName   String?       @map("operator_name")
  paymentMethod  PaymentMethod @map("payment_method")
  receiptImage   String?       @map("receipt_image")
  receiptImages  String[]      @default([]) @map("receipt_images")
  receiptNo      String?       @map("receipt_no")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  paymentType    PaymentType   @map("payment_type")
  status         PaymentStatus @default(PENDING_PAYMENT)
  order          Order         @relation(fields: [orderId], references: [id])
  sourceRefunds  Refund[]      @relation("RefundSource")

  @@index([status, createdAt])
  @@index([paymentType, status])
  @@index([orderId])
  @@index([transactionId])
  @@index([idempotencyKey])
  @@index([expiredAt])
  @@map("payments")
}

model StatusChangeLog {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  fieldName String   @map("field_name")
  oldValue  String   @map("old_value")
  newValue  String   @map("new_value")
  operator  String?
  reason    String?
  ip        String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  order     Order    @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([fieldName])
  @@index([createdAt])
  @@map("status_change_logs")
}

model RefundRequest {
  id             String         @id @default(uuid())
  orderId        String         @map("order_id")
  orderNo        String         @map("order_no")
  refundNo       String         @unique @map("refund_no")
  refundType     RefundType     @default(PARTIAL) @map("refund_type")
  refundAmount   Decimal        @map("refund_amount") @db.Decimal(10, 2)
  refundReason   String         @map("refund_reason")
  refundMethod   RefundMethod   @default(ORIGINAL) @map("refund_method")
  applicantType  String         @default("USER") @map("applicant_type")
  applicantId    String?        @map("applicant_id")
  applicantName  String?        @map("applicant_name")
  status         RefundStatus   @default(PENDING)
  approvedBy     String?        @map("approved_by")
  approvedAt     DateTime?      @map("approved_at")
  rejectedBy     String?        @map("rejected_by")
  rejectedAt     DateTime?      @map("rejected_at")
  rejectReason   String?        @map("reject_reason")
  refundedBy     String?        @map("refunded_by")
  refundedAt     DateTime?      @map("refunded_at")
  transactionId  String?        @map("transaction_id")
  notes          String?
  attachments    String[]       @default([])
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  refundToMethod PaymentMethod? @map("refund_to_method")
  audits         RefundAudit[]
  refunds        Refund[]

  @@index([orderId])
  @@index([orderNo])
  @@index([refundNo])
  @@index([status])
  @@index([createdAt])
  @@map("refund_requests")
}

model RefundAudit {
  id              String         @id @default(uuid())
  refundRequestId String?        @map("refund_request_id")
  orderId         String         @map("order_id")
  orderNo         String         @map("order_no")
  action          String         @map("action")
  amount          Decimal        @map("amount") @db.Decimal(10, 2)
  beforePaid      Decimal        @map("before_paid") @db.Decimal(10, 2)
  afterPaid       Decimal        @map("after_paid") @db.Decimal(10, 2)
  operatorId      String?        @map("operator_id")
  operatorName    String?        @map("operator_name")
  notes           String?        @map("notes")
  createdAt       DateTime       @default(now()) @map("created_at")
  refundRequest   RefundRequest? @relation(fields: [refundRequestId], references: [id])

  @@index([refundRequestId])
  @@index([orderId])
  @@index([action])
  @@map("refund_audits")
}

model Refund {
  id                String                @id @default(uuid())
  refundRequestId   String                @map("refund_request_id")
  orderId           String                @map("order_id")
  originalPaymentId String                @map("original_payment_id")
  refundAmount      Decimal               @map("refund_amount") @db.Decimal(10, 2)
  refundType        String                @map("refund_type")
  refundMethod      String                @map("refund_method")
  transactionId     String?               @map("transaction_id")
  executionStatus   RefundExecutionStatus @default(PENDING) @map("execution_status")
  retryCount        Int                   @default(0) @map("retry_count")
  maxRetries        Int                   @default(3) @map("max_retries")
  nextRetryAt       DateTime?             @map("next_retry_at")
  errorMessage      String?               @map("error_message")
  receiptImages     String[]              @default([]) @map("receipt_images")
  notes             String?
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  completedAt       DateTime?             @map("completed_at")
  order             Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  originalPayment   Payment               @relation("RefundSource", fields: [originalPaymentId], references: [id], onDelete: Cascade)
  refundRequest     RefundRequest         @relation(fields: [refundRequestId], references: [id], onDelete: Cascade)

  @@index([executionStatus])
  @@index([originalPaymentId])
  @@index([refundRequestId])
  @@index([createdAt])
  @@index([nextRetryAt])
  @@index([orderId])
  @@index([transactionId])
  @@index([executionStatus, createdAt])
  @@map("refunds")
}

model ProductCategory {
  id          Int          @id @default(autoincrement())
  name        String       @db.VarChar(50)
  code        String       @unique @db.VarChar(20)
  description String?
  sortOrder   Int          @default(0) @map("sort_order")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  products    Product[]
  stockChecks StockCheck[]

  @@index([code])
  @@index([isActive])
  @@index([sortOrder])
  @@map("product_categories")
}

model Product {
  id              Int                 @id @default(autoincrement())
  productNo       String              @unique @map("product_no") @db.VarChar(50)
  name            String              @db.VarChar(100)
  categoryId      Int                 @map("category_id")
  specification   String?             @db.VarChar(100)
  unit            String              @default("件") @db.VarChar(20)
  costPrice       Decimal             @default(0) @map("cost_price") @db.Decimal(10, 2)
  salePrice       Decimal             @default(0) @map("sale_price") @db.Decimal(10, 2)
  marketPrice     Decimal?            @map("market_price") @db.Decimal(10, 2)
  stockQuantity   Int                 @default(0) @map("stock_quantity")
  lowStock        Int                 @default(10) @map("low_stock")
  isTrackStock    Boolean             @default(true) @map("is_track_stock")
  description     String?
  images          Json?
  attributes      Json?
  status          String              @default("ACTIVE") @db.VarChar(20)
  isActive        Boolean             @default(true) @map("is_active")
  isFeatured      Boolean             @default(false) @map("is_featured")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  maxStock        Int?                @map("max_stock")
  minStock        Int?                @map("min_stock")
  reorderPoint    Int?                @map("reorder_point")
  safetyStock     Int                 @default(0) @map("safety_stock")
  dailyConsumption Int                @default(0) @map("daily_consumption")
  slowMovingDays  Int                 @default(90) @map("slow_moving_days")
  brand           String?             @db.VarChar(50)
  model           String?             @db.VarChar(50)
  detailImages    String[]            @default([]) @map("detail_images")
  isOnSale        Boolean             @default(true) @map("is_on_sale")
  salesVolume     Int                 @default(0) @map("sales_volume")
  sortOrder       Int                 @default(0) @map("sort_order")
  virtualSales    Int                 @default(0) @map("virtual_sales")
  deletedAt       DateTime?           @map("deleted_at")
  detailContent   Json?               @map("detail_content")
  baseSales       Int                 @default(0) @map("base_sales")
  cartItems       CartItem[]
  orderItems      OrderItem[]
  packageProducts PackageProduct[]
  category        ProductCategory     @relation(fields: [categoryId], references: [id])
  purchaseItems   PurchaseOrderItem[]
  alerts          StockAlert[]
  purchaseSuggestions AutoPurchaseSuggestion[]
  checkItems      StockCheckItem[]
  outboundItems   StockOutboundItem[]
  transactions    StockTransaction[]
  transfers       StockTransfer[]

  @@index([categoryId])
  @@index([productNo])
  @@index([status])
  @@index([isActive])
  @@index([isOnSale])
  @@index([salesVolume])
  @@index([sortOrder])
  @@map("products")
}

model ServiceItem {
  id              Int              @id @default(autoincrement())
  serviceNo       String           @unique @map("service_no") @db.VarChar(50)
  name            String           @db.VarChar(100)
  category        String           @db.VarChar(50)
  basePrice       Decimal          @default(0) @map("base_price") @db.Decimal(10, 2)
  unitPrice       Decimal?         @map("unit_price") @db.Decimal(10, 2)
  priceUnit       String?          @map("price_unit") @db.VarChar(20)
  description     String?
  duration        Int?
  requirements    Json?
  isActive        Boolean          @default(true) @map("is_active")
  isRequired      Boolean          @default(false) @map("is_required")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  images          Json?
  packageServices PackageService[]

  @@index([serviceNo])
  @@index([category])
  @@index([isActive])
  @@map("service_items")
}

model PackageProduct {
  id         Int      @id @default(autoincrement())
  packageId  Int      @map("package_id")
  productId  Int      @map("product_id")
  quantity   Int      @default(1)
  isOptional Boolean  @default(false) @map("is_optional")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  package    Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])

  @@unique([packageId, productId])
  @@index([packageId])
  @@index([productId])
  @@map("package_products")
}

model PackageService {
  id          Int         @id @default(autoincrement())
  packageId   Int         @map("package_id")
  serviceId   Int         @map("service_id")
  isIncluded  Boolean     @default(true) @map("is_included")
  isOptional  Boolean     @default(false) @map("is_optional")
  extraCharge Decimal?    @map("extra_charge") @db.Decimal(10, 2)
  sortOrder   Int         @default(0) @map("sort_order")
  createdAt   DateTime    @default(now()) @map("created_at")
  package     Package     @relation(fields: [packageId], references: [id], onDelete: Cascade)
  service     ServiceItem @relation(fields: [serviceId], references: [id])

  @@unique([packageId, serviceId])
  @@index([packageId])
  @@index([serviceId])
  @@map("package_services")
}

model StockOutbound {
  id            String              @id @default(uuid())
  outboundNo    String              @unique @map("outbound_no")
  outboundType  String              @map("outbound_type")
  outboundDate  DateTime            @map("outbound_date")
  orderId       String?             @map("order_id")
  status        String
  totalAmount   Decimal             @map("total_amount") @db.Decimal(10, 2)
  totalQuantity Int                 @map("total_quantity")
  submitterId   Int                 @map("submitter_id")
  submittedAt   DateTime            @default(now()) @map("submitted_at")
  approverId    Int?                @map("approver_id")
  approvedAt    DateTime?           @map("approved_at")
  approvalNote  String?             @map("approval_note")
  remark        String?
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  items         StockOutboundItem[]
  approver      User?               @relation("OutboundApprover", fields: [approverId], references: [id])
  order         Order?              @relation(fields: [orderId], references: [id])
  submitter     User                @relation("OutboundSubmitter", fields: [submitterId], references: [id])
  transactions  StockTransaction[]  @relation("OutboundTransactions")

  @@index([outboundNo])
  @@index([outboundType])
  @@index([status])
  @@index([outboundDate])
  @@index([orderId])
  @@map("stock_outbounds")
}

model StockOutboundItem {
  id         String        @id @default(uuid())
  outboundId String        @map("outbound_id")
  productId  Int           @map("product_id")
  quantity   Int
  unitPrice  Decimal       @map("unit_price") @db.Decimal(10, 2)
  amount     Decimal       @db.Decimal(10, 2)
  remark     String?
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  outbound   StockOutbound @relation(fields: [outboundId], references: [id], onDelete: Cascade)
  product    Product       @relation(fields: [productId], references: [id])

  @@index([outboundId])
  @@index([productId])
  @@map("stock_outbound_items")
}

model StockCheck {
  id             String             @id @default(uuid())
  checkNo        String             @unique @map("check_no")
  checkType      String             @map("check_type")
  checkDate      DateTime           @map("check_date")
  categoryId     Int?               @map("category_id")
  status         String
  totalItems     Int                @default(0) @map("total_items")
  profitItems    Int                @default(0) @map("profit_items")
  lossItems      Int                @default(0) @map("loss_items")
  profitQuantity Int                @default(0) @map("profit_quantity")
  lossQuantity   Int                @default(0) @map("loss_quantity")
