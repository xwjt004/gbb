# ===================================================
# 乖宝宝儿童影楼管理系统 - 生产环境配置模板
# 使用方式: cp .env.production.example .env && 编辑敏感字段
# ===================================================

# ---- 必备配置（必须修改） ----

# JWT 加密密钥（请使用足够长的随机字符串）
JWT_SECRET=change-this-to-a-random-64-char-string

# 前端域名（多个用逗号分隔，影响 CORS）
CORS_ORIGIN=https://guaibaobao.cn,https://www.guaibaobao.cn

# 数据加密密钥（用于敏感数据加密）
ENCRYPT_KEY=change-this-to-a-random-32-char-string

# ---- 微信配置（如需微信登录/支付） ----

# 微信小程序 AppID / AppSecret
WX_APP_ID=your-wechat-app-id
WX_APP_SECRET=your-wechat-app-secret

# 微信支付商户号 / API 密钥
WECHAT_MCH_ID=your-mch-id
WECHAT_API_KEY=your-api-key
WECHAT_API_V3_KEY=your-api-v3-key
WECHAT_SERIAL_NO=your-cert-serial-no
WECHAT_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WECHAT_CERT_PATH=./certs/apiclient_cert.pem
WECHAT_NOTIFY_URL=https://guaibaobao.cn/api/v1/payments/wx-notify

# ---- 可选配置 ----

# Redis 密码（如启用）
# REDIS_PASSWORD=your-redis-password

# Sentry 错误监控 DSN
# SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_TRACES_SAMPLE_RATE=0.1

# 邮件服务（用于通知发送）
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USER=your-email@example.com
# MAIL_PASS=your-email-password
