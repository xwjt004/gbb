# 乖宝宝儿童影楼管理系统 - 环境配置模板
# 复制此文件为 .env 并填写实际值
# 敏感信息请放入 .env.local（该文件不会提交到版本控制）

# 应用配置
NODE_ENV=development
PORT=3000

# 数据库配置
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/baby_photo_db?schema=public"

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 配置
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# 微信小程序配置（替换为实际值）
WX_APP_ID=your-wechat-app-id
WX_APP_SECRET=your-wechat-app-secret

# 微信支付配置
WECHAT_MCH_ID=your-merchant-id
WECHAT_API_KEY=your-wechat-api-key
WECHAT_API_V3_KEY=your-api-v3-key
WECHAT_SERIAL_NO=your-serial-number
WECHAT_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WECHAT_CERT_PATH=./certs/apiclient_cert.pem
WECHAT_NOTIFY_URL=https://guaibaobao.cn/api/v1/payments/wx-notify

# 支付模式配置
PAYMENT_MOCK_MODE=true
PAYMENT_SANDBOX_MODE=true

# 支付宝配置
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key
ALIPAY_PUBLIC_KEY=your-alipay-public-key

# 短信服务配置
SMS_ACCESS_KEY_ID=your-sms-access-key-id
SMS_ACCESS_KEY_SECRET=your-sms-access-key-secret
SMS_SIGN_NAME=乖宝宝儿童影楼

# 邮件服务配置
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USER=your-email@qq.com
MAIL_PASS=your-email-password

# 文件存储配置
STORAGE_TYPE=local
OSS_REGION=oss-cn-beijing
OSS_BUCKET=your-bucket-name
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret

# 日志配置
LOG_LEVEL=info
LOG_MAX_FILES=30

# 微信服务号配置（需在微信公众平台获取）
# WX_OFFICIAL_APPID=
# WX_OFFICIAL_APPSECRET=
# WX_OFFICIAL_TOKEN=

# 模板消息 ID（需在微信后台 → 功能 → 模板消息 中添加模板后获取）
# 用于向关注用户推送新产品/套系/作品/团购通知
# WX_TEMPLATE_NEW_PRODUCT=
# WX_TEMPLATE_NEW_PACKAGE=
# WX_TEMPLATE_NEW_WORK=
# WX_TEMPLATE_GROUP_BUY=

# 系统配置
SYSTEM_NAME=乖宝宝儿童影楼管理系统
SYSTEM_VERSION=1.0.0
ADMIN_EMAIL=admin@babyphoto.com
